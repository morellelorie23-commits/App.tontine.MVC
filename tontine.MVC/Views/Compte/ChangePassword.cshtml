@model tontine.MVC.Models.ChangePasswordViewModel
@{ ViewData["Title"] = "Changer le mot de passe"; }

<div style="max-width:480px;margin:0 auto;">
    <div style="background:white;border-radius:14px;padding:36px 40px;box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px;">
            <div style="width:46px;height:46px;background:#E6F4EE;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i data-lucide="lock" style="width:22px;height:22px;color:#0F6E56;"></i>
            </div>
            <div>
                <h2 style="margin:0;font-size:18px;font-weight:700;color:#1a1a1a;">Changer le mot de passe</h2>
                <p style="margin:2px 0 0;font-size:13px;color:#888;">Choisissez un mot de passe sécurisé</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:#FFF3F3;border:1px solid #F5C6CB;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#C62828;">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom:18px;">
                <label asp-for="AncienMotDePasse" style="display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:6px;"></label>
                <div style="position:relative;">
                    <input asp-for="AncienMotDePasse" id="pwd-ancien" type="password"
                           style="width:100%;padding:11px 42px 11px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    <button type="button" onclick="togglePwd('pwd-ancien','eye-ancien')"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#888;">
                        <i id="eye-ancien" data-lucide="eye" style="width:17px;height:17px;"></i>
                    </button>
                </div>
                <span asp-validation-for="AncienMotDePasse" style="color:#C62828;font-size:12px;"></span>
            </div>

            <div style="margin-bottom:18px;">
                <label asp-for="NouveauMotDePasse" style="display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:6px;"></label>
                <div style="position:relative;">
                    <input asp-for="NouveauMotDePasse" id="pwd-nouveau" type="password"
                           style="width:100%;padding:11px 42px 11px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    <button type="button" onclick="togglePwd('pwd-nouveau','eye-nouveau')"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#888;">
                        <i id="eye-nouveau" data-lucide="eye" style="width:17px;height:17px;"></i>
                    </button>
                </div>
                <span asp-validation-for="NouveauMotDePasse" style="color:#C62828;font-size:12px;"></span>
            </div>

            <div style="margin-bottom:28px;">
                <label asp-for="ConfirmMotDePasse" style="display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:6px;"></label>
                <div style="position:relative;">
                    <input asp-for="ConfirmMotDePasse" id="pwd-confirm" type="password"
                           style="width:100%;padding:11px 42px 11px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    <button type="button" onclick="togglePwd('pwd-confirm','eye-confirm')"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#888;">
                        <i id="eye-confirm" data-lucide="eye" style="width:17px;height:17px;"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmMotDePasse" style="color:#C62828;font-size:12px;"></span>
            </div>

            <div style="display:flex;gap:12px;">
                <button type="submit" style="flex:1;background:#0F6E56;color:white;border:none;border-radius:8px;padding:12px;font-size:14px;font-weight:600;cursor:pointer;">
                    Enregistrer
                </button>
                <a href="/Home/Index" style="flex:1;background:#F4F6F9;color:#444;border-radius:8px;padding:12px;font-size:14px;font-weight:500;text-align:center;text-decoration:none;">
                    Annuler
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function togglePwd(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon  = document.getElementById(iconId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.setAttribute('data-lucide', 'eye-off');
        } else {
            input.type = 'password';
            icon.setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }
    </script>
}
