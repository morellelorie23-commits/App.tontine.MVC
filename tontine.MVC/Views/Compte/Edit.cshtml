@model tontine.MVC.Models.CompteUtilisateurViewModel
@{
    ViewData["Title"] = "Modifier le compte";
}

<div style="max-width:520px;">
    <div style="margin-bottom:24px;">
        <a asp-action="Index" style="color:#0F6E56; font-size:13px; text-decoration:none; font-weight:500;">← Retour à la liste</a>
        <h2 style="margin:8px 0 4px; font-size:22px; font-weight:600;">Modifier le compte</h2>
        <p style="margin:0; color:#888780; font-size:14px;">@Model.Nom @Model.Prenom</p>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data"
          data-confirm="Voulez-vous enregistrer les modifications ?"
          data-confirm-type="edit">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdCompte" />
        <input type="hidden" asp-for="DateCreation" />
        <input type="hidden" asp-for="Photo" />
        <div style="background:white; border-radius:12px; padding:28px; box-shadow:0 1px 4px rgba(0,0,0,0.08);">

            <!-- Photo de profil -->
            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px; padding-bottom:20px; border-bottom:1px solid #F1EFE8;">
                <div id="photo-preview" style="width:72px; height:72px; border-radius:50%; background:#0F6E56; color:white; display:flex; align-items:center; justify-content:center; font-size:26px; font-weight:700; flex-shrink:0; overflow:hidden;">
                    @if (!string.IsNullOrEmpty(Model.Photo))
                    {
                        <img id="preview-img" src="/uploads/@Model.Photo" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <span id="preview-initial">@(Model.Nom.Substring(0, 1).ToUpper())</span>
                    }
                </div>
                <div>
                    <label style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Photo de profil</label>
                    <input type="file" asp-for="PhotoFile" accept="image/*" onchange="previewPhoto(this)"
                           style="font-size:13px; color:#5F5E5A;" />
                    <div style="font-size:11px; color:#888780; margin-top:4px;">JPG, PNG - laissez vide pour conserver l'actuelle</div>
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                <div>
                    <label asp-for="Nom" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Nom" style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    <span asp-validation-for="Nom" style="color:#C62828; font-size:12px;"></span>
                </div>
                <div>
                    <label asp-for="Prenom" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Prenom" style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    <span asp-validation-for="Prenom" style="color:#C62828; font-size:12px;"></span>
                </div>
            </div>

            <div style="margin-bottom:16px;">
                <label asp-for="Email" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                <input asp-for="Email" type="email" style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                <span asp-validation-for="Email" style="color:#C62828; font-size:12px;"></span>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px;">
                <div>
                    <label asp-for="Role" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <select asp-for="Role" asp-items="ViewBag.Roles"
                            style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px; background:white;">
                    </select>
                    <span asp-validation-for="Role" style="color:#C62828; font-size:12px;"></span>
                </div>
                <div>
                    <label asp-for="Statut" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <select asp-for="Statut" asp-items="ViewBag.Statuts"
                            style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px; background:white;">
                    </select>
                    <span asp-validation-for="Statut" style="color:#C62828; font-size:12px;"></span>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:16px; border-top:1px solid #F1EFE8;">
                <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                   border-radius:8px; padding:10px 24px; font-size:14px; text-decoration:none; font-weight:500;">
                    Annuler
                </a>
                <button type="submit" style="background:#E65100; color:white; border:none; border-radius:8px;
                        padding:10px 24px; font-size:14px; font-weight:600; cursor:pointer;">
                    <i data-lucide="save" style="width:15px;height:15px;margin-right:6px;vertical-align:middle;"></i> Enregistrer
                </button>
            </div>
        </div>
    </form>
</div>

<script>
function previewPhoto(input) {
    if (!input.files || !input.files[0]) return;
    const reader = new FileReader();
    reader.onload = function(e) {
        const preview = document.getElementById('photo-preview');
        preview.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;" />';
    };
    reader.readAsDataURL(input.files[0]);
}
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
