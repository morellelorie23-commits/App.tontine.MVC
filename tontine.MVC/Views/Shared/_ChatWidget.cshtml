@* Widget d'assistant conversationnel (chatbot IA) — assistant général, sans accès aux données de l'app. *@
@* Les identifiants évitent le mot "chat" et les styles sont en classes CSS (pas d'attribut `style`
   inline) : certains bloqueurs de publicité/tracker masquent par défaut tout élément dont l'id/la
   classe évoque un widget de chat, ou dont l'attribut `style` inline correspond au motif générique
   "bouton rond fixe en bas à droite" utilisé par ce type de widget. *@
<style>
    .ta-fab {
        position: fixed; bottom: 24px; right: 24px; width: 56px; height: 56px; border-radius: 50%;
        background: #0F6E56; color: white; border: none; box-shadow: 0 4px 16px rgba(0,0,0,0.25);
        cursor: pointer; z-index: 9997; display: flex; align-items: center; justify-content: center;
    }
    .ta-fab svg { width: 24px; height: 24px; }

    .ta-panel {
        display: none; position: fixed; bottom: 92px; right: 24px; width: 340px; max-width: 90vw;
        height: 460px; max-height: 70vh; background: white; border-radius: 14px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.3); z-index: 9997; flex-direction: column; overflow: hidden;
    }
    .ta-panel.ta-panel--open { display: flex; }

    .ta-panel-header {
        background: #0F6E56; color: white; padding: 14px 16px;
        display: flex; align-items: center; justify-content: space-between;
    }
    .ta-panel-header-title { font-weight: 600; font-size: 14px; }
    .ta-close-btn { background: none; border: none; color: white; cursor: pointer; padding: 2px; }
    .ta-close-btn svg { width: 18px; height: 18px; }

    .ta-messages {
        flex: 1; overflow-y: auto; padding: 14px; font-size: 13px;
        display: flex; flex-direction: column; gap: 10px;
    }
    .ta-msg { max-width: 85%; padding: 8px 12px; border-radius: 10px; white-space: pre-wrap; }
    .ta-msg--assistant { align-self: flex-start; background: #F4F6F9; color: #333; }
    .ta-msg--user { align-self: flex-end; background: #0F6E56; color: white; }

    .ta-input-row { padding: 10px; border-top: 1px solid #eee; display: flex; gap: 8px; }
    .ta-input {
        flex: 1; border: 1.5px solid #E0E0E0; border-radius: 20px; padding: 8px 14px;
        font-size: 13px; outline: none;
    }
    .ta-icon-btn {
        background: #F4F6F9; color: #0F6E56; border: none; border-radius: 50%;
        width: 36px; height: 36px; cursor: pointer; display: none;
        align-items: center; justify-content: center; flex-shrink: 0;
    }
    .ta-icon-btn svg { width: 16px; height: 16px; }
    .ta-icon-btn--mic-active { background: #C62828; color: white; }
    .ta-icon-btn--send { display: flex; background: #0F6E56; color: white; }
</style>

<form id="tontine-assist-antiforgery-form" style="display:none;">@Html.AntiForgeryToken()</form>

<button id="tontine-assist-toggle-btn" class="ta-fab" title="Assistant TontineApp">
    <i data-lucide="message-circle"></i>
</button>

<div id="tontine-assist-panel" class="ta-panel">
    <div class="ta-panel-header">
        <div class="ta-panel-header-title">Assistant TontineApp</div>
        <button id="tontine-assist-close-btn" class="ta-close-btn">
            <i data-lucide="x"></i>
        </button>
    </div>
    <div id="tontine-assist-messages" class="ta-messages">
        <div class="ta-msg ta-msg--assistant">
            Bonjour ! Je peux vous aider à comprendre le fonctionnement de TontineApp, expliquer des notions OHADA, ou répondre à vos questions générales. Je n'ai pas accès à vos données personnelles.
        </div>
    </div>
    <div class="ta-input-row">
        <input id="tontine-assist-input" type="text" class="ta-input" placeholder="Écrivez ou dictez votre message..." />
        <button id="tontine-assist-mic-btn" type="button" class="ta-icon-btn" title="Message vocal">
            <i data-lucide="mic"></i>
        </button>
        <button id="tontine-assist-send-btn" class="ta-icon-btn ta-icon-btn--send">
            <i data-lucide="send"></i>
        </button>
    </div>
</div>

<script>
(function () {
    var toggleBtn = document.getElementById('tontine-assist-toggle-btn');
    var closeBtn  = document.getElementById('tontine-assist-close-btn');
    var panel     = document.getElementById('tontine-assist-panel');
    var messages  = document.getElementById('tontine-assist-messages');
    var input     = document.getElementById('tontine-assist-input');
    var sendBtn   = document.getElementById('tontine-assist-send-btn');
    var micBtn    = document.getElementById('tontine-assist-mic-btn');

    function togglePanel(show) {
        panel.classList.toggle('ta-panel--open', show);
        if (show) input.focus();
    }
    toggleBtn.addEventListener('click', function () { togglePanel(!panel.classList.contains('ta-panel--open')); });
    closeBtn.addEventListener('click', function () { togglePanel(false); });

    function ajouterMessage(texte, role) {
        var bulle = document.createElement('div');
        bulle.className = 'ta-msg ' + (role === 'user' ? 'ta-msg--user' : 'ta-msg--assistant');
        bulle.textContent = texte;
        messages.appendChild(bulle);
        messages.scrollTop = messages.scrollHeight;
        return bulle;
    }

    function envoyer() {
        var texte = input.value.trim();
        if (!texte) return;
        input.value = '';
        ajouterMessage(texte, 'user');
        var attente = ajouterMessage('...', 'assistant');

        var token = document.querySelector('#tontine-assist-antiforgery-form input[name="__RequestVerificationToken"]').value;

        fetch('@Url.Action("Envoyer", "Chat")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: JSON.stringify({ message: texte })
        })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
        .then(function (data) { attente.textContent = data.reponse; messages.scrollTop = messages.scrollHeight; })
        .catch(function () { attente.textContent = "Désolé, l'assistant est momentanément indisponible."; });
    }

    sendBtn.addEventListener('click', envoyer);
    input.addEventListener('keydown', function (e) { if (e.key === 'Enter') envoyer(); });

    // --- Message vocal (reconnaissance vocale du navigateur, Chrome/Edge) ---
    var SpeechRecognitionApi = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SpeechRecognitionApi) {
        var recognition = new SpeechRecognitionApi();
        recognition.lang = 'fr-FR';
        recognition.interimResults = false;
        recognition.maxAlternatives = 1;
        var enEcoute = false;

        micBtn.style.display = 'flex';

        recognition.addEventListener('result', function (e) {
            var transcript = e.results[0][0].transcript;
            input.value = input.value ? (input.value.trim() + ' ' + transcript) : transcript;
            input.focus();
        });

        function arreterEcoute() {
            enEcoute = false;
            micBtn.classList.remove('ta-icon-btn--mic-active');
        }
        recognition.addEventListener('end', arreterEcoute);
        recognition.addEventListener('error', arreterEcoute);

        micBtn.addEventListener('click', function () {
            if (enEcoute) { recognition.stop(); return; }
            enEcoute = true;
            micBtn.classList.add('ta-icon-btn--mic-active');
            recognition.start();
        });
    }
    // Si le navigateur ne supporte pas la reconnaissance vocale (ex: Firefox),
    // le bouton micro reste caché et l'utilisateur écrit normalement.

    if (window.lucide) { lucide.createIcons(); }
})();
</script>
