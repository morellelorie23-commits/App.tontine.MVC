!DOCTYPE html>

<html lang="fr">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0F6E56" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="TontineApp" />
    <link rel="manifest" href="/manifest.json" />

    <title>@ViewData["Title"] - Tontine</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/theme.css" />

    <style>

        * {

            margin: 0;

            padding: 0;

            box-sizing: border-box;

        }



        body {

            font-family: 'Poppins', 'Segoe UI', sans-serif;

            background: #F4F6F9;

            display: flex;

            min-height: 100vh;

        }



        .sidebar {

            width: 260px;

            height: 100vh;

            background: linear-gradient(180deg, #0B5940 0%, #0F6E56 60%, #128060 100%);

            display: flex;

            flex-direction: column;

            position: fixed;

            top: 0;

            left: 0;

            z-index: 100;

            box-shadow: 4px 0 20px rgba(0,0,0,0.15);

            overflow: hidden;

        }



        .sidebar-brand {

            padding: 22px 20px 18px;

            border-bottom: 1px solid rgba(255,255,255,0.12);

            display: flex;

            align-items: center;

            gap: 12px;

        }



        .sidebar-brand-icon {

            width: 40px;

            height: 40px;

            background: rgba(255,255,255,0.15);

            border-radius: 10px;

            display: flex;

            align-items: center;

            justify-content: center;

            font-size: 20px;

            flex-shrink: 0;

        }



        .sidebar-brand h1 {

            color: white;

            font-size: 17px;

            font-weight: 700;

            margin: 0;

            letter-spacing: 0.3px;

        }



        .sidebar-brand p {

            color: rgba(255,255,255,0.55);

            font-size: 11px;

            margin: 2px 0 0;

        }



        .sidebar-menu {

            padding: 12px 0;

            flex: 1;

            overflow-y: auto;

        }



        .menu-section-btn {

            width: calc(100% - 20px);

            margin: 5px 10px 2px;

            background: rgba(255,255,255,0.08);

            border: none;

            border-left: 3px solid transparent;

            border-radius: 10px;

            cursor: pointer;

            display: flex;

            align-items: center;

            gap: 10px;

            padding: 11px 14px;

            color: white;

            font-size: 13px;

            font-weight: 600;

            letter-spacing: 0.2px;

            text-transform: none;

            transition: background 0.2s, border-left-color 0.2s, transform 0.15s;

        }

            .menu-section-btn:hover {

                background: rgba(255,255,255,0.15);

                transform: translateX(2px);

            }

            .menu-section-btn:not(.collapsed) {

                background: rgba(255,255,255,0.13);

                border-left-color: #9FE1CB;

                box-shadow: inset 0 0 0 1px rgba(159,225,203,0.2);

            }

            .menu-section-btn .chevron {

                margin-left: auto;

                width: 14px;

                height: 14px;

                transition: transform 0.22s ease;

                flex-shrink: 0;

                opacity: 0.7;

            }

            .menu-section-btn.collapsed .chevron {

                transform: rotate(-90deg);

            }



        .menu-submenu {

            overflow: hidden;

            transition: max-height 0.28s ease, opacity 0.22s ease;

            max-height: 2000px;

            opacity: 1;

        }



            .menu-submenu.collapsed {

                max-height: 0;

                opacity: 0;

            }



        .menu-item {

            display: flex;

            align-items: center;

            gap: 10px;

            padding: 9px 16px 9px 20px;

            color: rgba(255,255,255,0.75);

            text-decoration: none;

            font-size: 13.5px;

            transition: all 0.18s;

            border-left: 3px solid transparent;

            margin: 1px 0;

        }



            .menu-item:hover {

                background: rgba(255,255,255,0.1);

                color: white;

                border-left-color: rgba(255,255,255,0.5);

            }



            .menu-item.active {

                background: rgba(255,255,255,0.18);

                color: white;

                border-left-color: #9FE1CB;

                font-weight: 600;

            }



            .menu-item.disabled {

                opacity: 0.4;

                cursor: not-allowed;

                pointer-events: none;

            }



        /* Sous-liens à l'intérieur d'une section déroulante */

        .menu-submenu .menu-item {

            padding-left: 40px;

            font-size: 13px;

            color: rgba(255,255,255,0.68);

            margin: 1px 8px;

            border-radius: 7px;

            position: relative;

            overflow: hidden;

            transition: padding-left 0.22s ease, background 0.22s ease,
                        color 0.22s ease, transform 0.22s ease,
                        box-shadow 0.22s ease !important;

        }

            /* Shimmer sweep au survol */
            .menu-submenu .menu-item::before {

                content: '';

                position: absolute;

                inset: 0;

                background: linear-gradient(105deg,
                    transparent 25%,
                    rgba(255,255,255,0.07) 50%,
                    transparent 75%);

                transform: translateX(-120%);

                transition: transform 0.55s ease;

                pointer-events: none;

                border-radius: inherit;

            }

            .menu-submenu .menu-item:hover::before {

                transform: translateX(120%);

            }

            /* Petit point indicateur animé */
            .menu-submenu .menu-item::after {

                content: '';

                position: absolute;

                left: 22px;

                top: 50%;

                transform: translateY(-50%) scale(0);

                width: 5px;

                height: 5px;

                border-radius: 50%;

                background: #9FE1CB;

                box-shadow: 0 0 6px rgba(159,225,203,0.9);

                transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1);

                pointer-events: none;

            }

            .menu-submenu .menu-item:hover::after,
            .menu-submenu .menu-item.active::after {

                transform: translateY(-50%) scale(1);

            }

            .menu-submenu .menu-item .menu-icon {

                width: 15px;

                height: 15px;

                transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1),
                            filter 0.25s ease !important;

                flex-shrink: 0;

            }

            .menu-submenu .menu-item:hover .menu-icon {

                transform: scale(1.25) rotate(-8deg);

                filter: drop-shadow(0 0 4px rgba(159,225,203,0.95));

            }

            .menu-submenu .menu-item.active .menu-icon {

                filter: drop-shadow(0 0 3px rgba(159,225,203,0.7));

            }

            .menu-submenu .menu-item:hover {

                padding-left: 44px;

                background: rgba(255,255,255,0.1);

                color: white;

                transform: translateY(-1px);

                box-shadow: 0 3px 10px rgba(0,0,0,0.2);

            }

            @@keyframes activePulse {

                0%, 100% { box-shadow: inset 3px 0 0 #9FE1CB, 0 0 6px rgba(159,225,203,0.08); }

                50%       { box-shadow: inset 3px 0 0 #9FE1CB, 0 0 18px rgba(159,225,203,0.28); }

            }

            .menu-submenu .menu-item.active {

                padding-left: 44px;

                background: linear-gradient(90deg, rgba(159,225,203,0.14) 0%, rgba(255,255,255,0.06) 100%);

                color: white;

                animation: activePulse 2.8s ease-in-out infinite;

            }



        .menu-icon {

            width: 17px;

            height: 17px;

            flex-shrink: 0;

        }



        .menu-sublabel {

            padding: 8px 24px 4px;

            margin: 8px 10px 2px;

            color: rgba(255,255,255,0.35);

            font-size: 10px;

            font-weight: 700;

            text-transform: uppercase;

            letter-spacing: 1.2px;

            border-top: 1px solid rgba(255,255,255,0.07);

        }



        .badge-soon {

            margin-left: auto;

            background: rgba(255,255,255,0.15);

            color: rgba(255,255,255,0.6);

            font-size: 9px;

            font-weight: 600;

            padding: 2px 7px;

            border-radius: 10px;

            text-transform: uppercase;

            letter-spacing: 0.5px;

        }



        .sidebar-footer {

            padding: 14px 20px;

            border-top: 1px solid rgba(255,255,255,0.1);

            color: rgba(255,255,255,0.4);

            font-size: 11px;

        }



        .main-wrapper {

            margin-left: 260px;

            flex: 1;

            display: flex;

            flex-direction: column;

        }



        .topbar {

            background: white;

            border-bottom: 1px solid #E8EAF0;

            padding: 13px 28px;

            display: flex;

            justify-content: space-between;

            align-items: center;

            position: sticky;

            top: 0;

            z-index: 50;

            box-shadow: 0 1px 6px rgba(0,0,0,0.06);

        }



        .topbar-left {

            display: flex;

            align-items: center;

            gap: 10px;

        }



        .topbar-title {

            font-size: 15px;

            font-weight: 600;

            color: #1a1a2e;

        }



        .topbar-right {

            display: flex;

            align-items: center;

            gap: 12px;

        }



        .topbar-badge {

            background: #E6F4EE;

            color: #085041;

            font-size: 12px;

            padding: 4px 12px;

            border-radius: 20px;

            font-weight: 600;

        }



        .topbar-user {

            width: 34px;

            height: 34px;

            background: #0F6E56;

            border-radius: 50%;

            display: flex;

            align-items: center;

            justify-content: center;

            color: white;

            font-size: 14px;

            font-weight: 700;

        }



        .breadcrumb-container {

            background: var(--color-breadcrumb-bg, #FAFAFA);

            border-bottom: 1px solid var(--color-border);

            padding: 12px 28px;

            display: flex;

            align-items: center;

            gap: 8px;

            font-size: 14px;

            flex-wrap: wrap;

        }



        .content-area {

            padding: 26px 28px;

            flex: 1;

        }



        .main-footer {

            padding: 13px 28px;

            border-top: 1px solid #E8EAF0;

            color: #9E9E9E;

            font-size: 12px;

            background: white;

            display: flex;

            justify-content: space-between;

            align-items: center;

        }

        /* ── Responsive mobile ── */
        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 6px 8px;
            border-radius: 8px;
            color: #555;
            margin-right: 8px;
            align-items: center;
            justify-content: center;
        }
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 99;
        }
        @@media (max-width: 768px) {
            .hamburger-btn { display: flex; }
            .sidebar {
                transform: translateX(-260px);
                transition: transform 0.3s ease;
                z-index: 200;
            }
            .sidebar.mobile-open { transform: translateX(0); }
            .sidebar-overlay.active { display: block; }
            .main-wrapper { margin-left: 0 !important; }
            .topbar { padding: 10px 14px; }
            .topbar-title { font-size: 14px; }
            .page-content { padding: 12px !important; }
        }

        /* stylelint-disable-next-line */

        @@media print {

            @@page { size: A4 portrait; margin: 15mm 12mm; }

            .sidebar, .topbar, .main-footer, .breadcrumb,
            [onclick], button, a.action-btn, a.btn-add,
            form[asp-action], .btn-login { display: none !important; }

            .main-wrapper { margin-left: 0 !important; }

            .content-area { padding: 8px 0 !important; }

            body { background: white !important; font-size: 11px !important; color: #000 !important; }

            h1 { font-size: 16px !important; margin-bottom: 8px !important; }
            h2 { font-size: 14px !important; margin-bottom: 6px !important; }
            h3, h4 { font-size: 12px !important; }

            table { width: 100% !important; border-collapse: collapse !important;
                    font-size: 10px !important; page-break-inside: auto; }
            tr { page-break-inside: avoid; page-break-after: auto; }
            th { background: #0F6E56 !important; color: white !important;
                 padding: 5px 8px !important; text-align: left; -webkit-print-color-adjust: exact; }
            td { padding: 4px 8px !important; border-bottom: 1px solid #ddd !important; }

            .login-card, div[style*="box-shadow"] { box-shadow: none !important;
                border: 1px solid #ddd !important; }

            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

            .print-hide { display: none !important; }
            .print-only { display: block !important; }

        }

    </style>

    <script src="~/js/theme.js"></script>

    <script src="~/js/lucide.min.js"></script>
    <script src="~/js/tableutils.js"></script>

    <style>

        .lc-icon { display:inline-flex; align-items:center; justify-content:center; }

        .lc-icon svg { stroke-width: 1.8; }

    </style>

</head>

<body>



    <div class="sidebar">

        <div class="sidebar-brand">

            <div class="sidebar-brand-icon">

                <img src="/images/logo.svg" alt="Logo" style="width:36px;height:36px;" />

            </div>

            <div>

                <h1>TontineApp</h1>

                <p>Gestion des associations</p>

            </div>

        </div>



        <nav class="sidebar-menu">



            @{

                var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

                var isParametres = new[] {

                        "Membre","Tontine","Cycle","Poste","Penalite",

                        "CycleTontine","CycleTontinePenalite","MembreCycleTontine","MembrePosteCycle","Pret","Garant"

                        }.Contains(ctrl);

                var isLiaisons = new[] { "CycleTontine","CycleTontinePenalite","MembreCycleTontine","MembrePosteCycle" }.Contains(ctrl);

                var isStatistique = ctrl == "Statistique" || ctrl == "Rapport";

                var isComptabilite = ctrl == "Cotisation" || ctrl == "Versement" || ctrl == "Amende" || ctrl == "GrandLivre" || action == "Tours" || action == "LivreDeCompte" || action == "PaiementCaisse";

                var isSecurite = ctrl == "Compte" || ctrl == "Journal" || ctrl == "Role";

                var isReunion = ctrl == "Reunion";
                var isCalendrier = ctrl == "Calendrier";
                var isFondsSolidarite = ctrl == "FondsSolidarite";
                var isLitige = ctrl == "Litige";
                var isPaiementMobile = ctrl == "PaiementMobile";

            }



            <!-- Tableau de bord -->

            <div style="padding:8px 0 4px;">

                <a class="menu-item @(ctrl == "Home" ? "active" : "")"

                   asp-controller="Home" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />

                    </svg>

                    <span data-i18n="nav.dashboard">Tableau de bord</span>

                </a>

            </div>



            <!-- Paramètres (inclut Liaisons) -->

            <button class="menu-section-btn @(!isParametres ? "collapsed" : "")" data-target="sub-parametres">

                <svg style="width:16px;height:16px;flex-shrink:0;opacity:0.9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                          d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" />

                </svg>

                <span data-i18n="nav.settings">Paramètres</span>

                <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />

                </svg>

            </button>

            <div class="menu-submenu @(!isParametres ? "collapsed" : "")" id="sub-parametres">



                <!-- Données de base -->

                <div class="menu-sublabel" data-i18n="nav.data-base">Données de base</div>

                <a class="menu-item @(ctrl == "Membre" ? "active" : "")" asp-controller="Membre" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />

                    </svg>

                    <span data-i18n="nav.members">Membres</span>

                </a>

                <a class="menu-item @(ctrl == "Tontine" ? "active" : "")" asp-controller="Tontine" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />

                    </svg>

                    <span data-i18n="nav.tontines">Tontines</span>

                </a>

                <a class="menu-item @(ctrl == "Cycle" ? "active" : "")" asp-controller="Cycle" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />

                    </svg>

                    <span data-i18n="nav.cycles">Cycles</span>

                </a>

                <a class="menu-item @(ctrl == "Poste" ? "active" : "")" asp-controller="Poste" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />

                    </svg>

                    <span data-i18n="nav.postes">Postes</span>

                </a>

                <a class="menu-item @(ctrl == "Penalite" ? "active" : "")" asp-controller="Penalite" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />

                    </svg>

                    <span data-i18n="nav.penalties">Pénalités</span>

                </a>

                <a class="menu-item @(ctrl == "Pret" ? "active" : "")" asp-controller="Pret" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />

                    </svg>

                    <span data-i18n="nav.loans">Prêts</span>

                    <span id="badge-prets-retard"

                          style="display:none; margin-left:auto; background:#C62828; color:white;

                                 font-size:10px; font-weight:700; padding:2px 7px; border-radius:10px;

                                 min-width:18px; text-align:center;"></span>

                </a>

                <a class="menu-item @(ctrl == "Garant" ? "active" : "")" asp-controller="Garant" asp-action="Index">

                    <i data-lucide="shield-check" style="width:16px;height:16px;flex-shrink:0;"></i>

                    <span>Garants / Répondants</span>

                </a>



                <!-- Liaisons -->

                <button class="menu-section-btn @(!isLiaisons ? "collapsed" : "")" data-target="sub-liaisons" style="padding: 8px 14px 8px; margin-top: 8px; border-top: 1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); font-size:12px;">

                    <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />

                    </svg>

                    <span data-i18n="nav.liaisons">Liaisons</span>

                    <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />

                    </svg>

                </button>

                <div class="menu-submenu @(!isLiaisons ? "collapsed" : "")" id="sub-liaisons" style="padding-left: 0;">

                    <a class="menu-item @(ctrl == "CycleTontine" ? "active" : "")" asp-controller="CycleTontine" asp-action="Index">

