<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tontine</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F8F9FA; display: flex; min-height: 100vh; }
        .sidebar {
            width: 250px; min-height: 100vh; background: #0F6E56;
            display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
        }
        .sidebar-brand { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-brand h1 { color: white; font-size: 20px; font-weight: 700; margin: 0; }
        .sidebar-brand p { color: rgba(255,255,255,0.6); font-size: 12px; margin: 4px 0 0; }
        .sidebar-menu { padding: 16px 0; flex: 1; }
        .menu-section { padding: 8px 20px 4px; color: rgba(255,255,255,0.4); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 10px 20px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 14px; transition: all 0.2s; border-left: 3px solid transparent; }
        .menu-item:hover { background: rgba(255,255,255,0.1); color: white; border-left-color: #9FE1CB; }
        .menu-item.active { background: rgba(255,255,255,0.15); color: white; border-left-color: white; font-weight: 500; }
        .menu-icon { width: 18px; height: 18px; opacity: 0.8; }
        .sidebar-footer { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); font-size: 12px; }
        .main-wrapper { margin-left: 250px; flex: 1; display: flex; flex-direction: column; }
        .topbar { background: white; border-bottom: 0.5px solid #D3D1C7; padding: 14px 28px; display: flex; justify-content: space-between; align-items: center; }
        .topbar-title { font-size: 16px; font-weight: 500; color: #2C2C2A; }
        .topbar-badge { background: #E1F5EE; color: #085041; font-size: 12px; padding: 4px 12px; border-radius: 20px; font-weight: 500; }
        .content-area { padding: 28px; flex: 1; }
        .main-footer { padding: 14px 28px; border-top: 0.5px solid #D3D1C7; color: #888780; font-size: 12px; background: white; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-brand">
            <h1>Tontine</h1>
            <p>Gestion des associations</p>
        </div>
        <nav class="sidebar-menu">
            <div class="menu-section">Principal</div>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Tableau de bord
            </a>
            <div class="menu-section" style="margin-top:8px;">Gestion</div>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Membre" ? "active" : "")"
               asp-controller="Membre" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Membres
            </a>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tontine" ? "active" : "")"
               asp-controller="Tontine" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Tontines
            </a>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cycle" ? "active" : "")"
               asp-controller="Cycle" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Cycles
            </a>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Poste" ? "active" : "")"
               asp-controller="Poste" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Postes
            </a>
            <a class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Penalite" ? "active" : "")"
               asp-controller="Penalite" asp-action="Index">
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Pénalités
            </a>
        </nav>
        <div class="sidebar-footer">&copy; 2026 Tontine App</div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <span class="topbar-title">@ViewData["Title"]</span>
            <span class="topbar-badge">Tontine v1.0</span>
        </div>
        <div class="content-area">
            @RenderBody()
        </div>
        <div class="main-footer">
            &copy; 2026 - Tontine.MVC — Système de gestion des associations
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>