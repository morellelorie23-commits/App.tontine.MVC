                              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />

                    </svg>

                    <span data-i18n="nav.accounts">Comptes utilisateurs</span>

                </a>

                <a class="menu-item @(ctrl == "Role" ? "active" : "")" asp-controller="Role" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />

                    </svg>

                    <span data-i18n="nav.roles-permissions">Rôles &amp; Permissions</span>

                </a>

                <a class="menu-item @(ctrl == "Journal" ? "active" : "")" asp-controller="Journal" asp-action="Index">

                    <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"

                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />

                    </svg>

                    <span data-i18n="nav.journal">Journal d'activité</span>

                </a>

            </div>



        </nav>



        <div style="padding: 14px 20px; border-top: 1px solid rgba(255,255,255,0.1);">

            <a asp-controller="Compte" asp-action="ChangePassword" style="display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.55);font-size:12px;text-decoration:none;padding:6px 4px;margin-bottom:8px;border-radius:6px;transition:color 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">
                <i data-lucide="key-round" style="width:14px;height:14px;"></i> Changer le mot de passe
            </a>

            <button onclick="confirmerDeconnexion()" style="width: 100%; background: rgba(198,40,40,0.1); border: 1px solid rgba(198,40,40,0.3); color: #FF6B6B; border-radius: 6px; padding: 8px 12px; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.2s; display:flex; align-items:center; justify-content:center; gap:8px;">

                <i data-lucide="log-out" style="width:15px;height:15px;"></i> <span data-i18n="btn.logout">Se déconnecter</span>

            </button>

        </div>

        <div class="sidebar-footer">

            &copy; 2026 TontineApp &mdash; v1.0

        </div>

    </div>



    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeMobileSidebar()"></div>

    <div class="main-wrapper">

        <div class="topbar">

            <div class="topbar-left">

                <button class="hamburger-btn" onclick="toggleMobileSidebar()" title="Menu">
                    <i data-lucide="menu" style="width:22px;height:22px;"></i>
                </button>

                <span class="topbar-title">@ViewData["Title"]</span>

            </div>

            <div class="topbar-right">
                @{
                    var cycleNomTopbar = Context.Session.GetString("cycle_nom");
                }
                @if (!string.IsNullOrEmpty(cycleNomTopbar))
                {
                    <div class="topbar-badge" title="Cycle actif">
                        <i data-lucide="repeat" style="width:12px;height:12px;display:inline-block;vertical-align:middle;margin-right:4px;"></i>@cycleNomTopbar
                    </div>
                }

                <!-- Cloche notifications -->
                <a asp-controller="Notification" asp-action="Index"
                   id="notif-bell"
                   style="position:relative;display:flex;align-items:center;justify-content:center;
                          width:36px;height:36px;border-radius:50%;background:#F4F6F9;
                          text-decoration:none;transition:background 0.2s;"
                   title="Notifications"
                   onmouseover="this.style.background='#E6F4EE'" onmouseout="this.style.background='#F4F6F9'">
                    <i data-lucide="bell" style="width:17px;height:17px;color:#555;"></i>
                    <span id="notif-badge"
                          style="display:none;position:absolute;top:0;right:0;
                                 background:#C62828;color:white;font-size:9px;font-weight:700;
                                 min-width:16px;height:16px;border-radius:8px;
                                 padding:0 4px;line-height:16px;text-align:center;
                                 border:2px solid white;"></span>
                </a>

                <!-- Sélecteur de langue -->

                <select id="language-selector" onchange="window.onLanguageChange(this)" style="padding: 6px 10px; border-radius: 6px; border: 1px solid #0F6E56; background: #F0F0F0; font-size: 12px; cursor: pointer;">

                    <option value="fr">Français</option>

                    <option value="en">English</option>

                </select>



                <!-- Toggle thème -->

                <button id="theme-toggle" onclick="toggleTheme()" style="background: none; border: none; font-size: 18px; cursor: pointer; padding: 6px 10px; border-radius: 6px; transition: all 0.2s;" title="Mode sombre">

                    <i data-lucide="moon" style="width:16px;height:16px;"></i>

                </button>



                <button onclick="window.print()"

                        style="background:#E1F5EE; color:#085041; border:1px solid #0F6E56;

                           border-radius:8px; padding:6px 14px; font-size:13px;

                           font-weight:500; cursor:pointer; display:flex; align-items:center; gap:6px;">

                    <i data-lucide="printer" style="width:15px;height:15px;"></i>

                    <span data-i18n="btn.print">Imprimer</span>

                </button>


                <div class="topbar-user" title="@Context.Session.GetString("user_nom") - @Context.Session.GetString("user_role")"
                     style="overflow:hidden; padding:0;">
                    @{
                        var userPhoto = Context.Session.GetString("user_photo");
                    }
                    @if (!string.IsNullOrEmpty(userPhoto))
                    {
                        <img src="/uploads/@userPhoto" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span style="font-size:14px; font-weight:700; color:white;">@(Context.Session.GetString("user_nom")?.Substring(0, 1).ToUpper() ?? "?")</span>
                    }

                </div>

            </div>

        </div>



        <!-- Breadcrumb Navigation -->

        @await Html.PartialAsync("_Breadcrumb")



        <div class="content-area">

            @RenderBody()

        </div>



        <div class="main-footer">

            <span>&copy; 2026 &mdash; Système de gestion des tontines</span>

            <span>TontineApp v1.0</span>

        </div>

    </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/i18n.js"></script>

    <script src="~/js/lucide.min.js"></script>
    <script src="~/js/tableutils.js"></script>

    @await RenderSectionAsync("Scripts", required: false)



    <!-- Modale de confirmation globale -->

    <div id="global-confirm-modal"

         style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5);

            z-index:9999; align-items:center; justify-content:center;">

        <div style="background:white; border-radius:16px; max-width:400px; width:90%;

                padding:32px; box-shadow:0 8px 40px rgba(0,0,0,0.25); text-align:center;">

            <div id="gcm-icon" style="font-size:44px; margin-bottom:12px;"></div>

            <h3 id="gcm-title" style="margin:0 0 8px; font-size:17px; font-weight:700; color:#1a1a1a;"></h3>

            <p id="gcm-message" style="margin:0 0 24px; font-size:14px; color:#666; line-height:1.5;"></p>

            <div style="display:flex; gap:12px; justify-content:center;">

                <button id="gcm-cancel"

                        style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;

                           border-radius:8px; padding:10px 28px; font-size:14px;

                           font-weight:500; cursor:pointer;">

                    Annuler

                </button>

                <button id="gcm-confirm"

                        style="border:none; border-radius:8px; padding:10px 28px;

                           font-size:14px; font-weight:600; cursor:pointer; color:white;">

                    Confirmer

                </button>

            </div>

        </div>

    </div>



    <script>

        document.querySelectorAll('.menu-section-btn').forEach(function(btn) {

            btn.addEventListener('click', function() {

                var targetId = btn.getAttribute('data-target');

                var submenu  = document.getElementById(targetId);

                var isOpen   = !btn.classList.contains('collapsed');

                if (isOpen) {

                    btn.classList.add('collapsed');

                    submenu.classList.add('collapsed');

                } else {

                    btn.classList.remove('collapsed');

                    submenu.classList.remove('collapsed');

                }

            });

        });



        function _setLucideIcon(el, name, size, color) {

            el.innerHTML = '<i data-lucide="' + name + '" style="width:' + size + 'px;height:' + size + 'px;' + (color ? 'color:' + color + ';' : '') + '"></i>';

            lucide.createIcons({ el: el });

        }



        function confirmerDeconnexion() {

            const modal   = document.getElementById('global-confirm-modal');

            const icon    = document.getElementById('gcm-icon');

            const title   = document.getElementById('gcm-title');

            const message = document.getElementById('gcm-message');

            const btnOk   = document.getElementById('gcm-confirm');

            const btnNo   = document.getElementById('gcm-cancel');



            _setLucideIcon(icon, 'log-out', 44, '#C62828');

            title.textContent   = 'Se déconnecter';

            message.textContent = 'Voulez-vous vraiment vous déconnecter de TontineApp ?';

            btnOk.textContent   = 'Se déconnecter';

            btnOk.style.background = '#C62828';

            btnOk.style.boxShadow  = '0 2px 8px rgba(198,40,40,0.35)';

            modal.style.display = 'flex';

            document.body.style.overflow = 'hidden';



            btnOk.onclick = function() {

                window.location.href = '@Url.Action("Logout", "Auth")';

            };

            btnNo.onclick = function() {

                modal.style.display = 'none';

                document.body.style.overflow = 'auto';

            };

        }



        // Badge notifications
        (function() {
            fetch('@Url.Action("Count", "Notification")')
                .then(function(r) { return r.ok ? r.json() : null; })
                .then(function(data) {
                    if (!data || data.count <= 0) return;
                    var badge  = document.getElementById('notif-badge');
                    var badge2 = document.getElementById('notif-badge-menu');
                    var text   = data.count > 99 ? '99+' : String(data.count);
                    if (badge)  { badge.textContent  = text; badge.style.display  = 'block'; }
                    if (badge2) { badge2.textContent = text; badge2.style.display = 'inline-block'; }
                })
                .catch(function() {});
        })();

        // Badge alertes menu

        (function() {

            fetch('@Url.Action("AlerteCount", "Home")')

                .then(function(r) { return r.ok ? r.json() : null; })

                .then(function(data) {

                    if (!data) return;

                    var badge = document.getElementById('badge-prets-retard');

                    if (badge && data.pretsEnRetard > 0) {

                        badge.textContent = data.pretsEnRetard;

                        badge.style.display = 'inline-block';

                    }

                })

                .catch(function() {});

        })();



        (function () {

            let _pendingForm = null;

            let _pendingAction = null;

            const modal   = document.getElementById('global-confirm-modal');

            const icon    = document.getElementById('gcm-icon');

            const title   = document.getElementById('gcm-title');

            const message = document.getElementById('gcm-message');

            const btnOk   = document.getElementById('gcm-confirm');

            const btnNo   = document.getElementById('gcm-cancel');



            function showConfirm(opts) {

                _setLucideIcon(icon, opts.icon || 'help-circle', 44, opts.iconColor || '#888780');

                title.textContent   = opts.title   || 'Confirmation';

                message.textContent = opts.message || 'Voulez-vous continuer ?';

                btnOk.textContent   = opts.okLabel || 'Confirmer';

                btnOk.style.background = opts.danger ? '#C62828' : '#0F6E56';

                btnOk.style.boxShadow  = opts.danger ? '0 2px 8px rgba(198,40,40,0.35)' : '0 2px 8px rgba(15,110,86,0.3)';

                modal.style.display = 'flex';

                document.body.style.overflow = 'hidden';

            }



            function closeModal() {

                modal.style.display = 'none';

                document.body.style.overflow = 'auto';

                _pendingForm = null;

                _pendingAction = null;

            }



            btnNo.addEventListener('click', closeModal);

            modal.addEventListener('click', function (e) { if (e.target === this) closeModal(); });



            btnOk.addEventListener('click', function () {

                modal.style.display = 'none';

                document.body.style.overflow = 'auto';

                if (_pendingForm) {

                    _pendingForm._confirmed = true;

                    if (_pendingAction) _pendingForm.action = _pendingAction;

                    _pendingForm.submit();

                }

            });



            document.addEventListener('submit', function (e) {

                const form = e.target;

                if (!form.dataset.confirm) return;

                if (form._confirmed) return;

                e.preventDefault();

                const type = form.dataset.confirmType || 'default';

                _pendingForm   = form;

                _pendingAction = form.dataset.confirmAction || null;

                if (type === 'delete') {

                    showConfirm({ icon: 'trash-2', iconColor: '#C62828', title: 'Confirmer la suppression', message: form.dataset.confirm, okLabel: 'Supprimer', danger: true });

                } else if (type === 'edit') {

                    showConfirm({ icon: 'save', iconColor: '#0F6E56', title: 'Enregistrer les modifications', message: form.dataset.confirm, okLabel: 'Enregistrer', danger: false });

                } else if (type === 'create') {

                    showConfirm({ icon: 'plus-circle', iconColor: '#0F6E56', title: 'Créer un nouvel enregistrement', message: form.dataset.confirm, okLabel: 'Enregistrer', danger: false });

                } else {

                    showConfirm({ icon: 'help-circle', iconColor: '#888780', title: 'Confirmation', message: form.dataset.confirm, okLabel: 'Confirmer', danger: false });

                }

            }, true);

        })();

    </script>

    <script>lucide.createIcons();</script>
    <script>
        function toggleMobileSidebar() {
            document.querySelector('.sidebar').classList.toggle('mobile-open');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }
        function closeMobileSidebar() {
            document.querySelector('.sidebar').classList.remove('mobile-open');
            document.getElementById('sidebarOverlay').classList.remove('active');
        }
        // Fermer le sidebar quand on clique sur un lien (mobile)
        if (window.innerWidth <= 768) {
            document.querySelectorAll('.sidebar a').forEach(function(link) {
                link.addEventListener('click', closeMobileSidebar);
            });
        }
    </script>

    <!-- ── Bannière hors-ligne ─────────────────────────────────────── -->
    <div id="offline-banner"
         style="display:none;position:fixed;bottom:0;left:0;right:0;background:#E65100;color:white;
                text-align:center;padding:10px 16px;z-index:9998;font-size:13px;font-weight:500;">
        ⚠ Mode hors-ligne - vos actions seront synchronisées au retour de la connexion
    </div>

    <!-- ── PWA Service Worker ──────────────────────────────────────── -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(function() {});
        }
        window.addEventListener('offline', function() {
            document.getElementById('offline-banner').style.display = 'block';
        });
        window.addEventListener('online', function() {
            document.getElementById('offline-banner').style.display = 'none';
            showToast('Connexion rétablie !', 'success');
        });
    </script>


    @{
        var successMsg = TempData["Success"] as string;
        var errorMsg   = TempData["Error"]   as string;
        var infoMsg    = TempData["Info"]     as string;
    }
    @if (!string.IsNullOrEmpty(successMsg) || !string.IsNullOrEmpty(errorMsg) || !string.IsNullOrEmpty(infoMsg))
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                @if (!string.IsNullOrEmpty(successMsg)) {
                    <text>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMsg)), 'success');</text>
                }
                @if (!string.IsNullOrEmpty(errorMsg)) {
                    <text>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMsg)), 'error');</text>
                }
                @if (!string.IsNullOrEmpty(infoMsg)) {
                    <text>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(infoMsg)), 'info');</text>
                }
            });
        </script>
    }

    @await Html.PartialAsync("_ChatWidget")

</body>

</html>