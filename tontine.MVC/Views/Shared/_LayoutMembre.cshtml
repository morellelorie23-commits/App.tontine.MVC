@{
    var userNom   = Context.Session.GetString("user_nom")   ?? "Membre";
    var userPhoto = Context.Session.GetString("user_photo") ?? "";
    var cycleNom  = Context.Session.GetString("cycle_nom")  ?? "";
    var page      = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewBag.CycleNom = cycleNom;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0F6E56" />
    <title>@ViewData["Title"] — TontineApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F4F6F9; display: flex; min-height: 100vh; }

        .sidebar {
            width: 260px; height: 100vh;
            background: linear-gradient(180deg, #0B5940 0%, #0F6E56 60%, #128060 100%);
            display: flex; flex-direction: column; position: fixed; top: 0; left: 0;
            z-index: 100; box-shadow: 4px 0 20px rgba(0,0,0,0.15); overflow: hidden;
        }
        .sidebar-brand {
            padding: 22px 20px 18px; border-bottom: 1px solid rgba(255,255,255,0.12);
            display: flex; align-items: center; gap: 12px;
        }
        .sidebar-brand-icon {
            width: 40px; height: 40px; background: rgba(255,255,255,0.15);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            font-size: 20px; flex-shrink: 0;
        }
        .sidebar-brand h1 { font-size: 16px; font-weight: 700; color: white; letter-spacing: -0.3px; }
        .sidebar-brand p  { font-size: 11px; color: rgba(255,255,255,0.55); margin-top: 2px; }

        .sidebar-menu {
            flex: 1; padding: 16px 12px; overflow-y: auto;
        }
        .sidebar-menu::-webkit-scrollbar { width: 0; }

        .menu-section {
            font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px;
            color: rgba(255,255,255,0.4); padding: 16px 8px 6px; display: block;
        }

        .menu-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px; border-radius: 8px; text-decoration: none;
            color: rgba(255,255,255,0.75); font-size: 13px; font-weight: 500;
            transition: all 0.15s; margin-bottom: 2px;
        }
        .menu-item:hover  { background: rgba(255,255,255,0.1); color: white; text-decoration: none; }
        .menu-item.active { background: rgba(255,255,255,0.18); color: white; font-weight: 600; }
        .menu-icon { width: 17px; height: 17px; flex-shrink: 0; opacity: 0.85; }
        .menu-item.active .menu-icon { opacity: 1; }

        .sidebar-footer {
            padding: 14px 16px; border-top: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar-user {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px; border-radius: 8px;
            background: rgba(255,255,255,0.08); margin-bottom: 8px;
        }
        .sidebar-user-name  { font-size: 12px; font-weight: 600; color: white; }
        .sidebar-user-role  { font-size: 11px; color: rgba(255,255,255,0.55); }

        .main-wrapper { margin-left: 260px; flex: 1; display: flex; flex-direction: column; }

        .topbar {
            background: white; border-bottom: 1px solid #E8EAF0;
            padding: 13px 28px; display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 50; box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        }
        .topbar-badge {
            background: #E6F4EE; color: #085041;
            font-size: 12px; padding: 4px 12px; border-radius: 20px; font-weight: 600;
        }

        .content-area { padding: 28px; flex: 1; }

        .page-title    { font-size: 22px; font-weight: 700; color: #1a1a2e; margin-bottom: 4px; }
        .page-subtitle { font-size: 14px; color: #6B7280; }

        .btn-primary-tontine {
            background: linear-gradient(135deg, #0F6E56, #1D9E75);
            color: white; border: none; border-radius: 10px;
            padding: 9px 18px; font-size: 13px; font-weight: 600;
            text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
            box-shadow: 0 2px 8px rgba(15,110,86,0.3); transition: all 0.2s;
        }
        .btn-primary-tontine:hover { color: white; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(15,110,86,0.4); }

        /* ===== SYSTÈME DE BOUTONS MEMBRE ===== */
        .btn-pm {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            border: none; border-radius: 10px; font-weight: 700; cursor: pointer;
            text-decoration: none; transition: all 0.2s ease;
            padding: 11px 28px; font-size: 14px;
        }
        .btn-pm:active { transform: scale(0.97) !important; }

        .btn-pm-green {
            background: linear-gradient(135deg, #0F6E56, #1D9E75);
            color: white; box-shadow: 0 2px 8px rgba(15,110,86,0.3);
        }
        .btn-pm-green:hover {
            color: white; transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(15,110,86,0.45);
            background: linear-gradient(135deg, #0D5A46, #199E72);
        }

        .btn-pm-amber {
            background: linear-gradient(135deg, #D97706, #F59E0B);
            color: white; box-shadow: 0 2px 8px rgba(217,119,6,0.3);
        }
        .btn-pm-amber:hover {
            color: white; transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(217,119,6,0.45);
        }

        .btn-pm-outline {
            background: white; color: #374151;
            border: 1.5px solid #D1D5DB;
        }
        .btn-pm-outline:hover {
            background: #F9FAFB; border-color: #9CA3AF; color: #111;
            transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        }

        .btn-pm-full { width: 100%; border-radius: 12px; padding: 14px 20px; font-size: 15px; }
        .btn-pm-full:hover { transform: translateY(-2px); }

        /* ===== CARTES INTERACTIVES ===== */
        .card-pm {
            background: white; border-radius: 14px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.07);
            transition: box-shadow 0.2s ease, transform 0.2s ease;
        }
        .card-pm:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.12); }

        .card-pm-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.13); }

        .kpi-card {
            background: white; border-radius: 12px; padding: 18px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.07);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.11); }

        /* ===== TABLEAU PLANNING ===== */
        .planning-row { transition: background 0.12s ease; }
        .planning-row:hover td { background: #F0FDF4 !important; }
        .planning-row-me:hover td { background: #D1FAE5 !important; }

        /* ===== RÉUNIONS ===== */
        .reunion-item {
            display: flex; align-items: center; gap: 16px;
            padding: 12px 16px; border-radius: 10px;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        .reunion-item:hover { transform: translateX(5px); box-shadow: 0 3px 12px rgba(0,0,0,0.09); }

        /* ===== FOND CARDS ===== */
        .fonds-card {
            background: white; border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow: hidden; display: flex; flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .fonds-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.15); }

        /* ===== BOUTON LÉGER (ex: Reçu PDF) ===== */
        .btn-pm-light {
            background: #E6F4EE; color: #0F6E56;
            padding: 5px 12px; border-radius: 6px;
            font-size: 12px; font-weight: 600; text-decoration: none;
            display: inline-flex; align-items: center; gap: 5px;
            transition: all 0.2s ease;
        }
        .btn-pm-light:hover {
            background: #0F6E56; color: white;
            transform: translateY(-1px); box-shadow: 0 3px 10px rgba(15,110,86,0.3);
        }

        /* ===== LIEN RETOUR ===== */
        .lien-retour {
            color: #0F6E56; font-size: 13px; text-decoration: none; font-weight: 500;
            display: inline-flex; align-items: center; gap: 6px;
            transition: gap 0.15s ease, color 0.15s ease;
        }
        .lien-retour:hover { color: #0D5A46; gap: 10px; }

        /* ===== STATUT BADGE ===== */
        .statut-badge { transition: transform 0.15s ease; display: inline-block; }
        .statut-badge:hover { transform: scale(1.06); }

        .main-footer {
            padding: 13px 28px; border-top: 1px solid #E8EAF0;
            color: #9E9E9E; font-size: 12px; background: white;
            display: flex; justify-content: space-between; align-items: center;
        }

        @@media (max-width: 768px) { .sidebar { display: none; } .main-wrapper { margin-left: 0; } }
    </style>
    <script src="~/js/lucide.min.js"></script>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-brand-icon">
            <img src="/images/logo.svg" alt="Logo" style="width:36px;height:36px;" onerror="this.style.display='none';this.parentElement.innerHTML='🏦';" />
        </div>
        <div>
            <h1>TontineApp</h1>
            <p>Espace membre</p>
        </div>
    </div>

    <nav class="sidebar-menu">
        <span class="menu-section">Navigation</span>

        <a href="/PortailMembre/Index" class="menu-item @(page == "Index" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span>Tableau de bord</span>
        </a>

        <a href="/PortailMembre/MesCotisations" class="menu-item @(page == "MesCotisations" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            <span>Mes cotisations</span>
        </a>

        <a href="/PortailMembre/MesVersements" class="menu-item @(page == "MesVersements" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <span>Mes versements</span>
        </a>

        <a href="/PortailMembre/MesPrets" class="menu-item @(page == "MesPrets" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <span>Mes prêts</span>
        </a>

        <a href="/PortailMembre/MesFonds" class="menu-item @(page is "MesFonds" or "DemanderAide" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <span>Fonds de solidarité</span>
        </a>

        <a href="/PortailMembre/MonProfil" class="menu-item @(page == "MonProfil" ? "active" : "")">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>Mon profil</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user">
            @if (!string.IsNullOrEmpty(userPhoto))
            {
                <img src="/uploads/@userPhoto"
                     style="width:32px;height:32px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
            }
            else
            {
                <div style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.2);
                            display:flex;align-items:center;justify-content:center;
                            color:white;font-size:13px;font-weight:700;flex-shrink:0;">
                    @(userNom.Length > 0 ? userNom[0].ToString().ToUpper() : "M")
                </div>
            }
            <div style="overflow:hidden;min-width:0;">
                <div class="sidebar-user-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@userNom</div>
                <div class="sidebar-user-role">Membre</div>
            </div>
        </div>
        <a asp-controller="PortailMembre" asp-action="Deconnexion"
           style="display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:8px;
                  color:rgba(255,255,255,0.65);font-size:13px;font-weight:500;text-decoration:none;
                  background:rgba(255,255,255,0.06);transition:all 0.15s;"
           onmouseover="this.style.background='rgba(220,38,38,0.25)';this.style.color='#fca5a5';"
           onmouseout="this.style.background='rgba(255,255,255,0.06)';this.style.color='rgba(255,255,255,0.65)';">
            <svg style="width:15px;height:15px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Se déconnecter
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-wrapper">
    <div class="topbar">
        <div style="display:flex;align-items:center;gap:10px;">
            <span class="topbar-badge">
                <svg style="width:12px;height:12px;vertical-align:middle;margin-right:4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                @cycleNom
            </span>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:13px;color:#6B7280;">@userNom</span>
            @if (!string.IsNullOrEmpty(userPhoto))
            {
                <img src="/uploads/@userPhoto"
                     style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid #E8EAF0;" />
            }
            else
            {
                <div style="width:34px;height:34px;border-radius:50%;background:#0F6E56;
                            display:flex;align-items:center;justify-content:center;
                            color:white;font-size:13px;font-weight:700;">
                    @(userNom.Length > 0 ? userNom[0].ToString().ToUpper() : "M")
                </div>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="margin:16px 28px 0;padding:12px 16px;background:#E6F4EE;border-left:4px solid #0F6E56;border-radius:6px;color:#085041;font-size:13px;">
            ✓ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="margin:16px 28px 0;padding:12px 16px;background:#FFEBEE;border-left:4px solid #C62828;border-radius:6px;color:#C62828;font-size:13px;">
            ✕ @TempData["Error"]
        </div>
    }

    <main class="content-area">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <span>© 2026 TontineApp — Espace Membre</span>
        <span>v1.0</span>
    </footer>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>lucide.createIcons();</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
