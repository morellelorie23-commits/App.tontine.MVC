@model tontine.MVC.Models.ReunionViewModel
@{
    ViewData["Title"] = "Modifier la réunion";
}

<div style="max-width:520px;">
    <div style="margin-bottom:24px;">
        <a asp-action="Index" style="color:#0F6E56; font-size:13px; text-decoration:none; font-weight:500;">← Retour à la liste</a>
        <h2 style="margin:8px 0 4px; font-size:22px; font-weight:600;">Modifier la réunion</h2>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdReunion" />
        <div style="background:white; border-radius:12px; padding:28px; box-shadow:0 1px 4px rgba(0,0,0,0.08);">

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                <div>
                    <label asp-for="IdCycle" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="IdCycle" type="number" readonly
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px; background:#F8F8F8;" />
                </div>
                <div>
                    <label asp-for="IdTontine" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <select asp-for="IdTontine" asp-items="ViewBag.Tontines"
                            style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px; background:white;">
                        <option value="">-- Choisir --</option>
                    </select>
                </div>
            </div>

            <div style="margin-bottom:16px;">
                <label asp-for="DateReunion" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                <input asp-for="DateReunion" type="datetime-local"
                       style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                <span asp-validation-for="DateReunion" style="color:#C62828; font-size:12px;"></span>
            </div>

            <div style="margin-bottom:16px;">
                <label asp-for="Objet" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                <input asp-for="Objet" type="text"
                       style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                <span asp-validation-for="Objet" style="color:#C62828; font-size:12px;"></span>
            </div>

            <div style="margin-bottom:16px;">
                <label asp-for="Lieu" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                <input asp-for="Lieu" type="text"
                       style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Notes" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                <textarea asp-for="Notes" rows="3"
                          style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;"></textarea>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:16px; border-top:1px solid #F1EFE8;">
                <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px; font-size:14px; text-decoration:none; font-weight:500;">Annuler</a>
                <button type="submit" style="background:#F57F17; color:white; border:none; border-radius:8px; padding:10px 24px; font-size:14px; font-weight:600; cursor:pointer;">Enregistrer les modifications</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
