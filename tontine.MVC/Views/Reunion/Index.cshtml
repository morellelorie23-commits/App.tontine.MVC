@model List<tontine.MVC.Models.ReunionViewModel>
@{
    ViewData["Title"] = "Réunions";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <div>
        <h2 style="margin:0; font-size:22px; font-weight:600;">Réunions</h2>
        <p style="margin:4px 0 0; font-size:13px; color:#888;">Cycle : <strong style="color:#0F6E56;">@ViewData["CycleNom"]</strong></p>
    </div>
    <a asp-action="Create"
       style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:6px;">
        + Nouvelle réunion
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#E8F5E9; border:1px solid #A5D6A7; border-radius:8px; padding:12px 16px; margin-bottom:20px; font-size:14px; color:#2E7D32;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#FFEBEE; border:1px solid #EF9A9A; border-radius:8px; padding:12px 16px; margin-bottom:20px; font-size:14px; color:#C62828;">
        @TempData["Error"]
    </div>
}

<div style="background:white; border-radius:12px; box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden;">
    @if (!Model.Any())
    {
        <div style="padding:48px; text-align:center; color:#888;">
            <p style="font-size:15px;">Aucune réunion enregistrée pour ce cycle.</p>
            <a asp-action="Create" style="color:#0F6E56; font-weight:500; text-decoration:none;">Planifier la première réunion →</a>
        </div>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
            <thead>
                <tr style="background:#F8F7F2; border-bottom:2px solid #E8E6DC;">
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Date</th>
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Objet</th>
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Tontine</th>
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Lieu</th>
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Statut</th>
                    <th style="padding:12px 16px; text-align:left; font-weight:600; color:#444;">Présences</th>
                    <th style="padding:12px 16px; text-align:center; font-weight:600; color:#444;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    var (sBg, sClr) = r.Statut switch {
                        "Planifiée" => ("#E3F2FD", "#1565C0"),
                        "En cours"  => ("#FFF8E1", "#F57C00"),
                        "Terminée"  => ("#E6F4EE", "#0F6E56"),
                        "Annulée"   => ("#F3F3F3", "#888"),
                        _           => ("#F3F3F3", "#888")
                    };
                    <tr style="border-bottom:1px solid #F0EEE8;">
                        <td style="padding:12px 16px; font-weight:500; color:#0F6E56;">
                            @r.DateReunion.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="padding:12px 16px;">@r.Objet</td>
                        <td style="padding:12px 16px; color:#666;">@r.LibelleTontine</td>
                        <td style="padding:12px 16px; color:#666;">@(r.Lieu ?? "-")</td>
                        <td style="padding:12px 16px;">
                            <span style="background:@sBg; color:@sClr; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600;">
                                @r.Statut
                            </span>
                        </td>
                        <td style="padding:12px 16px;">
                            @if (r.TotalPresences > 0)
                            {
                                <span style="font-size:12px; color:#555;">
                                    <span style="color:#0F6E56; font-weight:600;">@r.NombrePresents P</span>
                                    / <span style="color:#F57C00; font-weight:600;">@r.NombreExcuses E</span>
                                    / <span style="color:#C62828; font-weight:600;">@r.NombreAbsents A</span>
                                </span>
                            }
                            else
                            {
                                <span style="font-size:12px; color:#bbb;">—</span>
                            }
                        </td>
                        <td style="padding:12px 16px;">
                            <div style="display:flex; gap:6px; justify-content:center; flex-wrap:wrap;">
                                @* Convocation *@
                                <form asp-action="Convoquer" asp-route-id="@r.IdReunion" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" title="Envoyer convocations par email"
                                            style="background:#E3F2FD; color:#1565C0; border:none; border-radius:6px; padding:5px 10px; font-size:12px; font-weight:600; cursor:pointer;">
                                        ✉ Convoquer
                                    </button>
                                </form>

                                @* Présence *@
                                <a asp-action="GererPresence" asp-route-id="@r.IdReunion"
                                   title="Feuille de présence"
                                   style="background:#E6F4EE; color:#0F6E56; border-radius:6px; padding:5px 10px; font-size:12px; font-weight:600; text-decoration:none;">
                                    ✓ Présence
                                </a>

                                @* PV PDF *@
                                <a asp-action="GenererPV" asp-route-id="@r.IdReunion"
                                   title="Télécharger le procès-verbal PDF"
                                   style="background:#F3E5F5; color:#6A1B9A; border-radius:6px; padding:5px 10px; font-size:12px; font-weight:600; text-decoration:none;">
                                    ↓ PV PDF
                                </a>

                                @* Modifier / Supprimer *@
                                <a asp-action="Edit" asp-route-id="@r.IdReunion"
                                   style="color:#F57F17; font-size:12px; font-weight:500; text-decoration:none; padding:5px 4px;">Modifier</a>
                                <a asp-action="Delete" asp-route-id="@r.IdReunion"
                                   style="color:#C62828; font-size:12px; font-weight:500; text-decoration:none; padding:5px 4px;">Supprimer</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
