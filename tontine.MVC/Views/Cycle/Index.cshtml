@model List<tontine.MVC.Models.CycleViewModel>

@{

    ViewData["Title"] = "Cycles";

}


<div style="background-image:url('/photo/dashboard.jfif');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,60,42,0.88) 0%,rgba(11,89,64,0.82) 60%,rgba(15,110,86,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Paramètres</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Cycles</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">Gestion des périodes et cycles de cotisation</p>
    </div>
</div>
<div style="padding:8px 0;">

    @if (TempData["Success"] != null) {

        <div style="margin-bottom:12px; padding:12px; background:#E6F4EE; border-left:4px solid #0F6E56; border-radius:6px; color:#085041;">@TempData["Success"]</div>

    }

    @if (TempData["Error"] != null) {

        <div style="margin-bottom:12px; padding:12px; background:#FFEBEE; border-left:4px solid #C62828; border-radius:6px; color:#C62828;">@TempData["Error"]</div>

    }



    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; gap:12px; flex-wrap:wrap;">

        <div>

            <h2 style="margin:0; font-size:22px; font-weight:600; color:#1a1a1a;">Gestion des cycles</h2>

            <p style="margin:4px 0 0; color:#888780; font-size:14px;">@Model.Count cycle(s) enregistré(s)</p>

        </div>

        <div style="display:flex; gap:10px; align-items:center;">
            <input id="search-cycle" type="text" placeholder="Rechercher par nom, statut..."
                   oninput="filtrerCycles(this.value)"
                   style="padding:9px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:13px; outline:none; min-width:230px;"
                   onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
            <button type="button" onclick="ouvrirModal()" style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:500; cursor:pointer;">

            + Nouveau cycle

            </button>
        </div>

    </div>



    <div style="background:white; border-radius:12px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.08);">

        <table style="width:100%; border-collapse:collapse; font-size:14px;">

            <thead>

                <tr style="background:linear-gradient(135deg, #0F6E56, #1D9E75); color:white;">

                    <th style="padding:14px 18px; text-align:left;">Nom</th>

                    <th style="padding:14px 18px; text-align:left;">Début</th>

                    <th style="padding:14px 18px; text-align:left;">Fin</th>

                    <th style="padding:14px 18px; text-align:left;">Statut</th>

                    <th style="padding:14px 18px; text-align:left;">Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var c in Model) {

                    <tr class="cycle-row" data-search="@c.NomCycle @c.Statut" style="border-bottom:1px solid #F1EFE8;" onmouseover="this.style.background='#F8FDF9'" onmouseout="this.style.background='white'">

                        <td style="padding:14px 18px; font-weight:600;">@c.NomCycle</td>

                        <td style="padding:14px 18px;">@(c.DateDebut.HasValue ? c.DateDebut.Value.ToString("dd/MM/yyyy") : "-")</td>

                        <td style="padding:14px 18px;">@(c.DateFin.HasValue ? c.DateFin.Value.ToString("dd/MM/yyyy") : "-")</td>

                        <td style="padding:14px 18px;">

                            @{

                                var (statBg, statClr) = c.Statut switch {

                                    "Actif"      => ("#E3F2FD", "#1565C0"),

                                    "Terminé"    => ("#E6F4EE", "#0F6E56"),

                                    "En attente" => ("#FFF8E1", "#F57F17"),

                                    _            => ("#F5F5F5", "#666")

                                };

                            }

                            <span style="background:@statBg; color:@statClr; padding:4px 12px; border-radius:12px; font-size:12px; font-weight:500;">@c.Statut</span>

                        </td>

                        <td style="padding:14px 18px;">

                            <div style="display:flex; gap:6px; flex-wrap:wrap;">

                                @if (c.Statut == "En attente") {

                                    <form asp-action="Demarrer" asp-route-id="@c.IdCycle" method="post" style="display:inline;"

                                          data-confirm="Démarrer le cycle « @c.NomCycle » ? Cette action est irréversible."

                                          data-confirm-type="create">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" style="background:#E3F2FD; color:#1565C0; border:1px solid #90CAF9; border-radius:6px; padding:6px 10px; cursor:pointer; font-size:12px; font-weight:500; display:inline-flex; align-items:center; gap:4px;">

                                            <i data-lucide="play" style="width:13px;height:13px;"></i> Démarrer

                                        </button>

                                    </form>

                                }

                                @if (c.Statut == "Actif") {

                                    <form asp-action="Cloturer" asp-route-id="@c.IdCycle" method="post" style="display:inline;"

                                          data-confirm="Clôturer le cycle « @c.NomCycle » ? Il ne pourra plus être modifié."

                                          data-confirm-type="delete">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" style="background:#FFF8E1; color:#F57F17; border:1px solid #FFE082; border-radius:6px; padding:6px 10px; cursor:pointer; font-size:12px; font-weight:500; display:inline-flex; align-items:center; gap:4px;">

                                            <i data-lucide="square" style="width:13px;height:13px;"></i> Clôturer

                                        </button>

                                    </form>

                                }

                                @if (c.Statut != "Terminé") {

                                    <a asp-action="Edit" asp-route-id="@c.IdCycle" style="background:#F5F5F5; color:#444; border:1px solid #E0E0E0; border-radius:6px; padding:6px 10px; text-decoration:none; font-size:12px; display:inline-flex; align-items:center;">

                                        <i data-lucide="pencil" style="width:13px;height:13px;"></i>

                                    </a>

                                }

                                <button type="button" onclick="confirmerSuppression(@c.IdCycle, '@c.NomCycle')" style="background:#FFEBEE; color:#C62828; border:1px solid #FFCDD2; border-radius:6px; padding:6px 10px; cursor:pointer; font-size:12px; display:inline-flex; align-items:center;">

                                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>

                                </button>

                            </div>

                        </td>

                    </tr>

                }

                @if (!Model.Any()) {

                    <tr>

                        <td colspan="5" style="padding:48px; text-align:center; color:#888780;">

                            <div style="margin-bottom:8px; display:flex; justify-content:center;"><i data-lucide="refresh-cw" style="width:36px;height:36px;opacity:.4;"></i></div>

                            <div style="font-weight:500;">Aucun cycle enregistré</div>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>



<!-- Modal Ajout -->

<div id="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; overflow-y:auto;">

    <div style="background:white; border-radius:16px; max-width:480px; margin:30px auto; padding:24px;">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; border-bottom:1px solid #F1EFE8; padding-bottom:16px;">

            <div>

                <h3 style="margin:0; font-size:18px; font-weight:600; color:#1a1a1a;">Nouveau cycle</h3>

                <p style="margin:4px 0 0; color:#888780; font-size:13px;">Remplissez les informations</p>

            </div>

            <button type="button" onclick="fermerModal()" style="background:#F1EFE8; border:none; border-radius:50%; width:32px; height:32px; cursor:pointer;"><i data-lucide="x" style="width:14px;height:14px;"></i></button>

        </div>



        <form asp-action="Create" method="post"

              data-confirm="Voulez-vous enregistrer ce nouveau cycle ?"

              data-confirm-type="create">

            @Html.AntiForgeryToken()

            <div style="display:grid; gap:12px;">

                <div>

                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Nom du cycle *</label>

                    <input name="NomCycle" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                </div>



                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">

                    <div>

                        <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Date de début</label>

                        <input name="DateDebut" type="date" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    </div>

                    <div>

                        <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Date de fin</label>

                        <input name="DateFin" type="date" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    </div>

                </div>



                <div>

                    <label style="display:block; margin-bottom:8px; font-weight:600; color:#0F6E56;">Statut</label>

                    <select name="Statut" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">

                        <option value="En attente" selected>En attente</option>

                        <option value="Actif">Actif</option>

                        <option value="Terminé">Terminé</option>

                    </select>

                </div>



                <div style="display:flex; justify-content:flex-end; gap:12px;">

                    <button type="button" onclick="fermerModal()" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px;">Annuler</button>

                    <button type="submit" style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 24px;">Enregistrer</button>

                </div>

            </div>

        </form>

    </div>

</div>



<!-- Modal Suppression -->

<div id="modal-suppression" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000;">

    <div style="background:white; border-radius:16px; max-width:420px; margin:120px auto; padding:28px;">

        <div style="text-align:center; margin-bottom:20px;">

            <div style="margin-bottom:12px; display:flex; justify-content:center; color:#C62828;"><i data-lucide="alert-triangle" style="width:40px;height:40px;"></i></div>

            <h3 style="margin:0; font-size:16px; font-weight:600; color:#1a1a1a;">Confirmer la suppression</h3>

            <p id="msg-suppression" style="margin:8px 0 0; color:#888780; font-size:14px;"></p>

        </div>



        <form id="form-suppression" method="post"

              data-confirm="Voulez-vous vraiment supprimer ce cycle ?"

              data-confirm-type="delete">

            @Html.AntiForgeryToken()

            <div style="display:flex; gap:12px; justify-content:center;">

                <button type="button" onclick="fermerSuppression()" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px;">Annuler</button>

                <button type="submit" style="background:#C62828; color:white; border:none; border-radius:8px; padding:10px 24px; display:inline-flex; align-items:center; gap:6px;"><i data-lucide="trash-2" style="width:15px;height:15px;"></i> Supprimer</button>

            </div>

        </form>

    </div>

</div>



@section Scripts {

    <script>

        function filtrerCycles(q) { q = q.toLowerCase().trim(); document.querySelectorAll('.cycle-row').forEach(r => r.style.display = !q || r.dataset.search.toLowerCase().includes(q) ? '' : 'none'); }
        function ouvrirModal(){ document.getElementById('modal-overlay').style.display='block'; document.body.style.overflow='hidden'; }

        function fermerModal(){ document.getElementById('modal-overlay').style.display='none'; document.body.style.overflow='auto'; }

        function confirmerSuppression(id, nom){

            document.getElementById('msg-suppression').textContent = `Voulez-vous supprimer : ${nom} ?`;

            document.getElementById('form-suppression').action = `/Cycle/Delete/${id}`;

            document.getElementById('modal-suppression').style.display = 'block';

            document.body.style.overflow = 'hidden';

        }

        function fermerSuppression(){ document.getElementById('modal-suppression').style.display='none'; document.body.style.overflow='auto'; }

        document.getElementById('modal-overlay').addEventListener('click', function(e){ if(e.target===this) fermerModal(); });

        document.getElementById('modal-suppression').addEventListener('click', function(e){ if(e.target===this) fermerSuppression(); });

    </script>

}