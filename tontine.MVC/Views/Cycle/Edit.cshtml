@model tontine.MVC.Models.CycleViewModel
@{
    ViewData["Title"] = "Modifier le cycle";
}

<div style="background-image:url('/photo/dashboard.jfif');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,60,42,0.88) 0%,rgba(11,89,64,0.82) 60%,rgba(15,110,86,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Paramètres</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Modifier le cycle</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">@Model.NomCycle</p>
    </div>
</div>

<div style="max-width:520px;margin:0 auto;">
    <div style="background:white;border-radius:16px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,0.08);">

        <form asp-action="Edit" asp-route-id="@Model.IdCycle" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdCycle" />

            <div style="display:grid;gap:16px;">

                <div>
                    <label style="font-size:12px;font-weight:600;color:#444;display:block;margin-bottom:6px;">Nom du cycle *</label>
                    <input asp-for="NomCycle" required
                           style="width:100%;padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    <span asp-validation-for="NomCycle" style="color:#C62828;font-size:12px;"></span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:12px;font-weight:600;color:#444;display:block;margin-bottom:6px;">Date de début</label>
                        <input asp-for="DateDebut" type="date"
                               style="width:100%;padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                               onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:#444;display:block;margin-bottom:6px;">Date de fin</label>
                        <input asp-for="DateFin" type="date"
                               style="width:100%;padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;"
                               onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />
                    </div>
                </div>

                <div>
                    <label style="font-size:12px;font-weight:600;color:#444;display:block;margin-bottom:6px;">Statut</label>
                    <select asp-for="Statut"
                            style="width:100%;padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;background:white;outline:none;">
                        <option value="En attente">En attente</option>
                        <option value="Actif">Actif</option>
                        <option value="Terminé">Terminé</option>
                    </select>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background:#FFEBEE;border-left:4px solid #C62828;border-radius:8px;padding:12px 16px;font-size:13px;color:#C62828;">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div style="display:flex;justify-content:flex-end;gap:12px;padding-top:8px;">
                    <a asp-action="Index"
                       style="background:white;color:#5F5E5A;border:1.5px solid #D3D1C7;border-radius:8px;padding:10px 24px;font-size:14px;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;">
                        Annuler
                    </a>
                    <button type="submit"
                            style="background:#0F6E56;color:white;border:none;border-radius:8px;padding:10px 28px;font-size:14px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;box-shadow:0 2px 8px rgba(15,110,86,0.3);">
                        <i data-lucide="save" style="width:15px;height:15px;"></i> Enregistrer
                    </button>
                </div>
            </div>
        </form>

    </div>
</div>
