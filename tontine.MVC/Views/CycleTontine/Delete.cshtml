@model tontine.MVC.Models.CycleTontineViewModel

@{

    ViewData["Title"] = "Supprimer la liaison";

}



<div style="max-width:420px; margin:100px auto; padding:28px; background:white; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,0.08); text-align:center;">

    <div style="margin-bottom:12px; display:flex; justify-content:center; color:#C62828;"><i data-lucide="alert-triangle" style="width:40px;height:40px;"></i></div>

    <h2 style="margin:0 0 12px; font-size:18px; font-weight:600; color:#1a1a1a;">Confirmer la suppression</h2>

    <p style="margin:0 0 24px; color:#888780; font-size:14px;">Êtes-vous sûr de vouloir supprimer cette liaison ?</p>



    <div style="background:#F8FDF9; border-radius:8px; padding:16px; margin-bottom:24px; text-align:left; font-size:13px;">

        <div><strong>Cycle :</strong> @Model.NomCycle</div>

        <div><strong>Tontine :</strong> @Model.LibelleTontine</div>

    </div>



    <form method="post" style="display:flex; gap:12px; justify-content:center;">

        @Html.AntiForgeryToken()

        <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px; text-decoration:none;">Annuler</a>

        <button type="submit" style="background:#C62828; color:white; border:none; border-radius:8px; padding:10px 24px; cursor:pointer; display:inline-flex; align-items:center; gap:6px;"><i data-lucide="trash-2" style="width:15px;height:15px;"></i> Supprimer</button>

    </form>

</div>

