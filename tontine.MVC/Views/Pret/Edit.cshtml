@model tontine.MVC.Models.PretViewModel

@{

    ViewData["Title"] = "Modifier le prêt";

}



<div style="max-width:600px; margin:30px auto; padding:24px; background:white; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,0.08);">

    <h2 style="margin:0 0 24px; font-size:20px; font-weight:600;">Modifier le prêt</h2>



    <form asp-action="Edit" method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IdPret" />



        @if (!ViewData.ModelState.IsValid)

        {

            <div style="margin-bottom:12px; padding:12px; background:#FFEBEE; border-left:4px solid #C62828; border-radius:6px; color:#B71C1C;">

                <div style="font-weight:500;">Erreurs</div>

                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))

                {

                    <p style="margin:4px 0 0; font-size:13px;">› @error.ErrorMessage</p>

                }

            </div>

        }



        <div style="display:grid; gap:16px;">

            <div>

                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Membre *</label>

                <select asp-for="IdMembre" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">

                    <option value="">-- Sélectionner un membre --</option>

                    @foreach(var membre in ViewData["Membres"] as List<MembreViewModel> ?? new())

                    {

                        <option value="@membre.IdMembre" selected="@(Model.IdMembre == membre.IdMembre)">@membre.Nom @membre.Prenom</option>

                    }

                </select>

                @Html.ValidationMessageFor(m => m.IdMembre)

            </div>



            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

                <div>

                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Montant (FCFA) *</label>

                    <input asp-for="Montant" type="number" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    @Html.ValidationMessageFor(m => m.Montant)

                </div>



                <div>

                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Taux d'intérêt (%) *</label>

                    <input asp-for="Taux" type="number" step="0.01" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    @Html.ValidationMessageFor(m => m.Taux)

                </div>

            </div>



            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

                <div>

                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Date du prêt *</label>

                    <input asp-for="DatePret" type="date" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    @Html.ValidationMessageFor(m => m.DatePret)

                </div>



                <div>

                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Date de remboursement *</label>

                    <input asp-for="DateRemboursement" type="date" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;" />

                    @Html.ValidationMessageFor(m => m.DateRemboursement)

                </div>

            </div>



            <div>

                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Statut *</label>

                <select asp-for="Statut" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">

                    <option value="En attente" selected="@(Model.Statut == "En attente")">En attente</option>

                    <option value="Approuvé" selected="@(Model.Statut == "Approuvé")">Approuvé</option>

                    <option value="Remboursé" selected="@(Model.Statut == "Remboursé")">Remboursé</option>

                    <option value="En retard" selected="@(Model.Statut == "En retard")">En retard</option>

                </select>

                @Html.ValidationMessageFor(m => m.Statut)

            </div>



            <div>

                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Description</label>

                <textarea asp-for="Description" rows="3" placeholder="Notes sur le prêt..." style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; resize:vertical;"></textarea>

                @Html.ValidationMessageFor(m => m.Description)

            </div>



            <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:12px;">

                <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px; text-decoration:none; font-weight:500;">Annuler</a>

                <button type="submit" style="background:#F44336; color:white; border:none; border-radius:8px; padding:10px 24px; font-weight:500; cursor:pointer;">Enregistrer</button>

            </div>

        </div>

    </form>

</div>

