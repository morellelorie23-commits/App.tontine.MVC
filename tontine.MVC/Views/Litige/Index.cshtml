@model tontine.MVC.Models.LitigesIndexViewModel
@{
    ViewData["Title"] = "Litiges & Exclusions";
    var ouverts  = Model.Litiges.Count(l => l.Statut == "Ouvert");
    var resolus  = Model.Litiges.Count(l => l.Statut == "Résolu");
    var exclusActifs = Model.Exclusions.Count(e => !e.EstReintegre);
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Litiges & Exclusions</h2>
        <p class="page-subtitle">Gestion des conflits et sanctions disciplinaires</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="SignalerLitige" class="btn-primary-tontine">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Signaler litige
        </a>
        <a asp-action="ExclureMembre" class="btn btn-danger" style="border-radius:10px;font-weight:600;">
            Exclure un membre
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Cartes résumé -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center p-3" style="border:none;border-radius:12px;background:#FEF3C7;">
            <div class="fw-bold fs-4" style="color:#D97706;">@ouverts</div>
            <div style="font-size:12px;color:#6B7280;">Litiges ouverts</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3" style="border:none;border-radius:12px;background:#F0FDF4;">
            <div class="fw-bold fs-4" style="color:#065F46;">@resolus</div>
            <div style="font-size:12px;color:#6B7280;">Résolus</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3" style="border:none;border-radius:12px;background:#FEE2E2;">
            <div class="fw-bold fs-4" style="color:#991B1B;">@exclusActifs</div>
            <div style="font-size:12px;color:#6B7280;">Membres exclus</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3" style="border:none;border-radius:12px;background:#EFF6FF;">
            <div class="fw-bold fs-4" style="color:#1D4ED8;">@Model.Litiges.Count</div>
            <div style="font-size:12px;color:#6B7280;">Total litiges</div>
        </div>
    </div>
</div>

<!-- Onglets -->
<ul class="nav nav-tabs mb-4" id="litigeTab">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-litiges">
            Litiges <span class="badge bg-warning text-dark ms-1">@Model.Litiges.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-exclusions">
            Exclusions <span class="badge bg-danger ms-1">@Model.Exclusions.Count</span>
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- TAB LITIGES -->
    <div class="tab-pane fade show active" id="tab-litiges">
        @if (!Model.Litiges.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:48px;margin-bottom:12px;">✅</div>
                <p>Aucun litige enregistré pour ce cycle.</p>
            </div>
        }
        else
        {
            <div class="card" style="border:none;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead style="background:#F9FAFB;">
                            <tr>
                                <th style="font-size:12px;padding:12px 16px;">Membre accusé</th>
                                <th style="font-size:12px;">Nature</th>
                                <th style="font-size:12px;">Gravité</th>
                                <th style="font-size:12px;">Date</th>
                                <th style="font-size:12px;">Statut</th>
                                <th style="font-size:12px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in Model.Litiges)
                            {
                                var graviteBg = l.Gravite switch {
                                    "Grave"   => "#FEE2E2", "Modérée" => "#FEF3C7", _ => "#F0FDF4"
                                };
                                var graviteColor = l.Gravite switch {
                                    "Grave"   => "#991B1B", "Modérée" => "#92400E", _ => "#065F46"
                                };
                                var statutBg = l.Statut switch {
                                    "Résolu" => "#D1FAE5", "Classé" => "#E5E7EB", _ => "#FEF3C7"
                                };
                                var statutColor = l.Statut switch {
                                    "Résolu" => "#065F46", "Classé" => "#374151", _ => "#92400E"
                                };
                                <tr>
                                    <td style="padding:12px 16px;">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(l.PhotoAccuse))
                                            {
                                                <img src="/uploads/@l.PhotoAccuse" class="rounded-circle"
                                                     style="width:32px;height:32px;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div style="width:32px;height:32px;border-radius:50%;background:#DC2626;
                                                            color:white;display:flex;align-items:center;justify-content:center;
                                                            font-size:12px;font-weight:600;">
                                                    @(l.NomAccuse.Length > 0 ? l.NomAccuse[0] : '?')
                                                </div>
                                            }
                                            <div>
                                                <div style="font-size:13px;font-weight:600;">@l.NomAccuse</div>
                                                @if (!string.IsNullOrEmpty(l.NomDeclarant))
                                                {
                                                    <div style="font-size:11px;color:#6B7280;">par @l.NomDeclarant</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-size:13px;font-weight:500;">@l.Nature</div>
                                        <div style="font-size:11px;color:#6B7280;max-width:180px;overflow:hidden;
                                                    text-overflow:ellipsis;white-space:nowrap;">@l.Description</div>
                                    </td>
                                    <td>
                                        <span style="background:@graviteBg;color:@graviteColor;font-size:11px;
                                                     font-weight:600;padding:3px 9px;border-radius:10px;">
                                            @l.Gravite
                                        </span>
                                    </td>
                                    <td style="font-size:12px;color:#6B7280;">
                                        @l.DateDeclaration.ToString("dd/MM/yyyy")
                                    </td>
                                    <td>
                                        <span style="background:@statutBg;color:@statutColor;font-size:11px;
                                                     font-weight:600;padding:3px 9px;border-radius:10px;">
                                            @l.Statut
                                        </span>
                                    </td>
                                    <td>
                                        @if (l.Statut == "Ouvert")
                                        {
                                            <div class="d-flex gap-1">
                                                <!-- Résoudre -->
                                                <button type="button" class="btn btn-sm btn-success"
                                                        style="font-size:11px;border-radius:6px;"
                                                        data-bs-toggle="modal" data-bs-target="#modalResoudre-@l.IdLitige">
                                                    ✓ Résoudre
                                                </button>
                                                <!-- Classer -->
                                                <form asp-action="Classer" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@l.IdLitige"/>
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                            style="font-size:11px;border-radius:6px;"
                                                            onclick="return confirm('Classer sans suite ?')">
                                                        Classer
                                                    </button>
                                                </form>
                                                <!-- Exclure -->
                                                <a asp-action="ExclureMembre" asp-route-idLitige="@l.IdLitige"
                                                   class="btn btn-sm btn-outline-danger"
                                                   style="font-size:11px;border-radius:6px;">
                                                    Exclure
                                                </a>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex gap-1 align-items-center">
                                                @if (l.DateResolution.HasValue)
                                                {
                                                    <span style="font-size:11px;color:#6B7280;">
                                                        @l.DateResolution.Value.ToString("dd/MM/yyyy")
                                                    </span>
                                                }
                                                <form asp-action="SupprimerLitige" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@l.IdLitige"/>
                                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                                            onclick="return confirm('Supprimer ce litige ?')">✕</button>
                                                </form>
                                            </div>
                                        }

                                        <!-- Modal Résolution -->
                                        <div class="modal fade" id="modalResoudre-@l.IdLitige" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content" style="border-radius:12px;">
                                                    <div class="modal-header">
                                                        <h6 class="modal-title">Résoudre le litige</h6>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <form asp-action="Resoudre" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@l.IdLitige"/>
                                                        <div class="modal-body">
                                                            <p style="font-size:13px;color:#374151;">
                                                                <strong>Litige :</strong> @l.Nature — @l.NomAccuse
                                                            </p>
                                                            <div class="mb-2">
                                                                <label class="form-label small fw-semibold">Résolution / Décision prise</label>
                                                                <textarea name="resolution" class="form-control" rows="4"
                                                                          placeholder="Décrire la résolution adoptée..." required></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="submit" class="btn btn-success w-100">
                                                                Confirmer la résolution
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(l.Resolution))
                                {
                                    <tr style="background:#F9FAFB;">
                                        <td colspan="6" style="font-size:12px;color:#374151;padding:6px 16px;">
                                            📋 <strong>Résolution :</strong> @l.Resolution
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- TAB EXCLUSIONS -->
    <div class="tab-pane fade" id="tab-exclusions">
        @if (!Model.Exclusions.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:48px;margin-bottom:12px;">🤝</div>
                <p>Aucune exclusion enregistrée pour ce cycle.</p>
            </div>
        }
        else
        {
            <div class="card" style="border:none;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead style="background:#F9FAFB;">
                            <tr>
                                <th style="font-size:12px;padding:12px 16px;">Membre exclu</th>
                                <th style="font-size:12px;">Motif</th>
                                <th style="font-size:12px;">Date</th>
                                <th style="font-size:12px;">Type</th>
                                <th style="font-size:12px;">Statut</th>
                                <th style="font-size:12px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.Exclusions)
                            {
                                <tr style="@(e.EstReintegre ? "opacity:0.6;" : "")">
                                    <td style="padding:12px 16px;">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(e.PhotoMembre))
                                            {
                                                <img src="/uploads/@e.PhotoMembre" class="rounded-circle"
                                                     style="width:32px;height:32px;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div style="width:32px;height:32px;border-radius:50%;background:#7C3AED;
                                                            color:white;display:flex;align-items:center;justify-content:center;
                                                            font-size:12px;font-weight:600;">
                                                    @(e.NomMembre.Length > 0 ? e.NomMembre[0] : '?')
                                                </div>
                                            }
                                            <span style="font-size:13px;font-weight:600;">@e.NomMembre</span>
                                        </div>
                                    </td>
                                    <td style="font-size:13px;max-width:200px;">@e.Motif</td>
                                    <td style="font-size:12px;color:#6B7280;">@e.DateExclusion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span style="background:@(e.EstDefinitif ? "#FEE2E2" : "#FEF3C7");
                                                     color:@(e.EstDefinitif ? "#991B1B" : "#92400E");
                                                     font-size:11px;font-weight:600;padding:3px 9px;border-radius:10px;">
                                            @(e.EstDefinitif ? "Définitive" : "Temporaire")
                                        </span>
                                    </td>
                                    <td>
                                        @if (e.EstReintegre)
                                        {
                                            <span style="background:#D1FAE5;color:#065F46;font-size:11px;
                                                         font-weight:600;padding:3px 9px;border-radius:10px;">
                                                Réintégré @e.DateReintegration?.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="background:#FEE2E2;color:#991B1B;font-size:11px;
                                                         font-weight:600;padding:3px 9px;border-radius:10px;">
                                                Exclu
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            @if (!e.EstReintegre && !e.EstDefinitif)
                                            {
                                                <form asp-action="Reintegrer" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@e.IdExclusion"/>
                                                    <button type="submit" class="btn btn-sm btn-success"
                                                            style="font-size:11px;border-radius:6px;"
                                                            onclick="return confirm('Réintégrer ce membre ?')">
                                                        Réintégrer
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="SupprimerExclusion" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@e.IdExclusion"/>
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                                        onclick="return confirm('Supprimer cette exclusion ?')">✕</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(e.Notes))
                                {
                                    <tr style="background:#F9FAFB;">
                                        <td colspan="6" style="font-size:12px;color:#374151;padding:4px 16px;">
                                            📝 @e.Notes
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
