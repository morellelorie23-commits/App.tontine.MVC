@model tontine.MVC.Models.ExclusionViewModel
@{
    ViewData["Title"] = "Exclure un membre";
}

<div style="margin-bottom:24px;">
    <a asp-action="Index" style="color:#0F6E56;font-size:13px;text-decoration:none;font-weight:500;">
        ← Retour aux litiges & exclusions
    </a>
    <h2 style="margin:8px 0 4px;font-size:24px;font-weight:700;color:#1a1a1a;">Exclure un membre</h2>
    <p style="margin:0;color:#888780;font-size:14px;">Enregistrer une sanction disciplinaire pour ce cycle</p>
</div>

@if (Model.IdLitige.HasValue)
{
    <div style="background:#FEF3C7;border:1.5px solid #FCD34D;border-radius:10px;padding:14px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;">
        <span style="font-size:22px;">⚖️</span>
        <span style="font-size:13px;color:#92400E;font-weight:500;">
            Exclusion suite au litige #@Model.IdLitige — le formulaire a été pré-rempli avec les informations du litige.
        </span>
    </div>
}

<form asp-action="ExclureMembre" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IdCycle" />
    <input type="hidden" asp-for="IdLitige" />

    <div style="display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start;">

        <!-- Colonne principale -->
        <div>

            <!-- Membre -->
            <div style="background:white;border-radius:12px;padding:32px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);margin-bottom:20px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
                    <div style="width:4px;height:22px;background:#DC2626;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#DC2626;text-transform:uppercase;letter-spacing:0.6px;">Membre concerné</span>
                </div>
                <div>
                    <label asp-for="IdMembre" style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;"></label>
                    <select asp-for="IdMembre" asp-items="ViewBag.Membres"
                            style="width:100%;padding:12px 16px;border:1.5px solid #E5E7EB;border-radius:10px;
                                   font-size:14px;background:white;outline:none;color:#111;"
                            onfocus="this.style.borderColor='#DC2626';this.style.boxShadow='0 0 0 3px rgba(220,38,38,0.08)'"
                            onblur="this.style.borderColor='#E5E7EB';this.style.boxShadow='none'">
                        <option value="">-- Sélectionner le membre à exclure --</option>
                    </select>
                    <span asp-validation-for="IdMembre" style="color:#DC2626;font-size:12px;"></span>
                </div>
            </div>

            <!-- Motif & détails -->
            <div style="background:white;border-radius:12px;padding:32px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
                    <div style="width:4px;height:22px;background:#0F6E56;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#0F6E56;text-transform:uppercase;letter-spacing:0.6px;">Motif & détails</span>
                </div>

                <div style="margin-bottom:24px;">
                    <label asp-for="Motif" style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;"></label>
                    <textarea asp-for="Motif" rows="5"
                              placeholder="Décrivez le motif de l'exclusion (comportement fautif, non-respect du règlement, fraude...)"
                              style="width:100%;padding:12px 16px;border:1.5px solid #E5E7EB;border-radius:10px;
                                     font-size:14px;outline:none;resize:vertical;color:#111;line-height:1.6;"
                              onfocus="this.style.borderColor='#0F6E56';this.style.boxShadow='0 0 0 3px rgba(15,110,86,0.08)'"
                              onblur="this.style.borderColor='#E5E7EB';this.style.boxShadow='none'"></textarea>
                    <span asp-validation-for="Motif" style="color:#DC2626;font-size:12px;"></span>
                </div>

                <div>
                    <label asp-for="Notes" style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;">
                        Notes complémentaires <span style="font-weight:400;color:#9CA3AF;">(optionnel)</span>
                    </label>
                    <textarea asp-for="Notes" rows="3"
                              placeholder="Références aux réunions, décisions prises, documents joints..."
                              style="width:100%;padding:12px 16px;border:1.5px solid #E5E7EB;border-radius:10px;
                                     font-size:14px;outline:none;resize:vertical;color:#111;line-height:1.6;"
                              onfocus="this.style.borderColor='#0F6E56';this.style.boxShadow='0 0 0 3px rgba(15,110,86,0.08)'"
                              onblur="this.style.borderColor='#E5E7EB';this.style.boxShadow='none'"></textarea>
                </div>
            </div>
        </div>

        <!-- Colonne latérale -->
        <div>

            <!-- Type d'exclusion -->
            <div style="background:white;border-radius:12px;padding:28px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);margin-bottom:16px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
                    <div style="width:4px;height:22px;background:#888780;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.6px;">Type d'exclusion</span>
                </div>

                <div style="display:flex;flex-direction:column;gap:12px;">
                    <label id="card-temporaire"
                           style="display:flex;align-items:center;gap:14px;padding:16px 18px;
                                  border:2px solid #0F6E56;border-radius:10px;cursor:pointer;background:#F0FDF4;">
                        <input type="radio" name="EstDefinitif" value="false" checked
                               style="width:18px;height:18px;accent-color:#0F6E56;flex-shrink:0;"
                               onchange="selectType(false)" />
                        <div>
                            <div style="font-size:14px;font-weight:700;color:#065F46;">Temporaire</div>
                            <div style="font-size:12px;color:#6B7280;margin-top:2px;">Le membre pourra être réintégré</div>
                        </div>
                    </label>

                    <label id="card-definitif"
                           style="display:flex;align-items:center;gap:14px;padding:16px 18px;
                                  border:2px solid #E5E7EB;border-radius:10px;cursor:pointer;background:white;">
                        <input type="radio" name="EstDefinitif" value="true"
                               style="width:18px;height:18px;accent-color:#DC2626;flex-shrink:0;"
                               onchange="selectType(true)" />
                        <div>
                            <div style="font-size:14px;font-weight:700;color:#DC2626;">Définitive</div>
                            <div style="font-size:12px;color:#6B7280;margin-top:2px;">Exclusion permanente du cycle</div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Alerte exclusion définitive -->
            <div id="avertissement-definitif"
                 style="display:none;background:#FEE2E2;border:1.5px solid #FECACA;border-radius:12px;padding:18px;margin-bottom:16px;">
                <div style="font-size:13px;font-weight:700;color:#991B1B;margin-bottom:6px;">⛔ Action irréversible</div>
                <div style="font-size:13px;color:#7F1D1D;line-height:1.5;">
                    Une exclusion définitive ne peut pas être annulée. Assurez-vous que cette décision a été validée par le bureau.
                </div>
            </div>
        </div>
    </div>

    <!-- Barre d'actions -->
    <div style="background:white;border-radius:12px;padding:20px 28px;margin-top:8px;
                box-shadow:0 1px 4px rgba(0,0,0,0.08);display:flex;justify-content:flex-end;gap:12px;align-items:center;">
        <a asp-action="Index"
           style="background:white;color:#5F5E5A;border:1.5px solid #D1D5DB;border-radius:10px;
                  padding:11px 28px;font-size:14px;text-decoration:none;font-weight:600;">
            Annuler
        </a>
        <button type="submit" id="btn-exclure"
                style="background:linear-gradient(135deg,#DC2626,#EF4444);color:white;border:none;
                       border-radius:10px;padding:11px 32px;font-size:14px;font-weight:700;
                       cursor:pointer;box-shadow:0 2px 8px rgba(220,38,38,0.35);">
            ⛔ Exclure le membre
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectType(definitif) {
            var cardTemp = document.getElementById('card-temporaire');
            var cardDef  = document.getElementById('card-definitif');
            var alerte   = document.getElementById('avertissement-definitif');
            var btn      = document.getElementById('btn-exclure');

            if (definitif) {
                cardTemp.style.borderColor = '#E5E7EB';
                cardTemp.style.background  = 'white';
                cardDef.style.borderColor  = '#DC2626';
                cardDef.style.background   = '#FFF5F5';
                alerte.style.display       = 'block';
                btn.style.background       = 'linear-gradient(135deg,#991B1B,#DC2626)';
            } else {
                cardTemp.style.borderColor = '#0F6E56';
                cardTemp.style.background  = '#F0FDF4';
                cardDef.style.borderColor  = '#E5E7EB';
                cardDef.style.background   = 'white';
                alerte.style.display       = 'none';
                btn.style.background       = 'linear-gradient(135deg,#DC2626,#EF4444)';
            }
        }
    </script>
}
