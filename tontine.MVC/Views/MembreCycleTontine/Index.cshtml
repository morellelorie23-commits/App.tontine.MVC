@model List<tontine.MVC.Models.MembreCycleTontineViewModel>

@{

    ViewData["Title"] = "Membres-Cycles-Tontines";

}


<div style="background-image:url('/photo/membres.png');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,60,42,0.88) 0%,rgba(11,89,64,0.82) 60%,rgba(15,110,86,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Liaisons</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Membres - Cycles</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">Participation des membres aux cycles de tontine</p>
    </div>
</div>
<div style="padding:8px 0;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">

        <div>

            <h2 style="margin:0; font-size:22px; font-weight:600; color:#1a1a1a;">Participations aux tontines</h2>

            <p style="margin:4px 0 0; color:#888780; font-size:14px;">@Model.Count participation(s) enregistrée(s)</p>

        </div>

        <div style="display:flex; gap:10px; align-items:center;">
            <a asp-action="SaisieSeance"
               style="background:linear-gradient(135deg,#0F6E56,#198754); color:white; border:none; border-radius:8px;
                      padding:10px 20px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none;
                      display:inline-flex; align-items:center; gap:8px;">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Saisie Séance
            </a>
            <a asp-action="Create"
               style="background:white; color:#0F6E56; border:2px solid #0F6E56; border-radius:8px;
                      padding:9px 20px; font-size:14px; font-weight:500; cursor:pointer; text-decoration:none; display:inline-block;">
                + Nouvelle participation
            </a>
        </div>

    </div>



    <div style="background:white; border-radius:12px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.08);">

        <table style="width:100%; border-collapse:collapse; font-size:14px;">

            <thead>

                <tr style="background:linear-gradient(135deg, #0F6E56, #1D9E75); color:white;">

                    <th style="padding:14px 18px; text-align:left;">Membre</th>

                    <th style="padding:14px 18px; text-align:left;">Cycle</th>

                    <th style="padding:14px 18px; text-align:left;">Tontine</th>

                    <th style="padding:14px 18px; text-align:center;">Rang</th>

                    <th style="padding:14px 18px; text-align:left;">Matricule</th>

                    <th style="padding:14px 18px; text-align:left;">Parts</th>

                    <th style="padding:14px 18px; text-align:left;">Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var m in Model) {

                    <tr style="border-bottom:1px solid #F1EFE8;" onmouseover="this.style.background='#F8FDF9'" onmouseout="this.style.background='white'">

                        <td style="padding:14px 18px; font-weight:600;">@m.NomMembre</td>

                        <td style="padding:14px 18px;">@m.NomCycle</td>

                        <td style="padding:14px 18px;">@m.LibelleTontine</td>

                        <td style="padding:14px 18px; text-align:center; font-weight:600; color:#0F6E56;">@(m.NumeroOrdre?.ToString() ?? "-")</td>

                        <td style="padding:14px 18px; font-size:12px; color:#888780;">@(m.Matricule ?? "-")</td>

                        <td style="padding:14px 18px;">
                            @{
                                var (partsBg, partsColor) = m.NombreParts switch {
                                    0.5m => ("#FFF8E1", "#F57F17"),
                                    2m   => ("#E8F5E9", "#2E7D32"),
                                    _    => ("#F3F3F3", "#555")
                                };
                            }
                            <span style="background:@partsBg; color:@partsColor; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600;">@m.LibelleParts</span>
                        </td>

                        <td style="padding:14px 18px;">

                            <div style="display:flex; gap:8px;">

                                <a asp-action="Edit" asp-route-id="@m.Id" style="background:#FFF8E1; color:#F57F17; border:1px solid #FFE082; border-radius:6px; padding:6px 14px; text-decoration:none; font-weight:500;">

                                    <i data-lucide="pencil" style="width:13px;height:13px;"></i> Modifier

                                </a>

                                <a asp-action="Delete" asp-route-id="@m.Id" style="background:#FFEBEE; color:#C62828; border:1px solid #FFCDD2; border-radius:6px; padding:6px 14px; text-decoration:none; font-weight:500;">

                                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i> Supprimer

                                </a>

                            </div>

                        </td>

                    </tr>

                }

                @if (!Model.Any()) {

                    <tr>

                        <td colspan="7" style="padding:48px; text-align:center; color:#888780;">

                            <div style="margin-bottom:8px;display:flex;justify-content:center;"><i data-lucide="users" style="width:32px;height:32px;opacity:.4;"></i></div>

                            <div style="font-weight:500;">Aucune participation enregistrée</div>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>

