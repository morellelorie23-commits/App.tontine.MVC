@model List<tontine.MVC.Models.VersementViewModel>

@{

    ViewData["Title"] = "Versements";

    var total       = Model.Sum(v => v.Montant);
    var totalNet    = Model.Sum(v => v.MontantNet);
    var totalComm   = Model.Sum(v => v.MontantCommission);

}



<style>

    .kpi-row   { display:grid; grid-template-columns:repeat(5,1fr); gap:16px; margin-bottom:24px; }

    .kpi-card  { background:white; border-radius:12px; padding:18px 20px;

                 box-shadow:0 1px 4px rgba(0,0,0,0.07); display:flex; align-items:center; gap:14px; }

    .kpi-icon  { width:46px; height:46px; border-radius:12px;

                 display:flex; align-items:center; justify-content:center; font-size:22px; }

    .kpi-val   { font-size:22px; font-weight:700; color:#1a1a1a; line-height:1; }

    .kpi-lbl   { font-size:12px; color:#888780; margin-top:3px; }



    .toolbar   { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }

    .btn-add   { background:#0F6E56; color:white; border:none; border-radius:8px;

                 padding:9px 20px; font-size:13px; font-weight:600; cursor:pointer;

                 text-decoration:none; display:inline-flex; align-items:center; gap:6px; }

    .btn-add:hover { background:#0B5940; color:white; }



    .table-card { background:white; border-radius:12px; overflow:hidden;

                  box-shadow:0 1px 4px rgba(0,0,0,0.07); }

    table  { width:100%; border-collapse:collapse; }

    thead  { background:#F8FDF9; }

    th     { padding:12px 16px; font-size:12px; font-weight:600; color:#444;

             text-align:left; text-transform:uppercase; letter-spacing:0.5px;

             border-bottom:1.5px solid #E1F5EE; }

    td     { padding:13px 16px; font-size:13.5px; color:#333; border-bottom:1px solid #F4F4F2; }

    tr:last-child td { border-bottom:none; }

    tr:hover td { background:#FAFFF9; }



    .action-btn { border:none; background:none; cursor:pointer; padding:4px 8px;

                  border-radius:6px; font-size:12px; font-weight:500; text-decoration:none; }

    .btn-del    { color:#C62828; background:#FFF5F5; }

    .empty-msg  { text-align:center; padding:40px; color:#888780; font-size:14px; }

</style>



<div style="background-image:url('/photo/versements.png');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,60,42,0.88) 0%,rgba(11,89,64,0.82) 60%,rgba(15,110,86,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Finance</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Versements</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">@Model.Count versement(s)</p>
    </div>
</div>
<!-- KPIs -->

<div class="kpi-row">

    <div class="kpi-card">

        <div class="kpi-icon" style="background:#E1F5EE; color:#0F6E56;"><i data-lucide="send" style="width:22px;height:22px;"></i></div>

        <div><div class="kpi-val">@Model.Count</div><div class="kpi-lbl">Total versements</div></div>

    </div>

    <div class="kpi-card">

        <div class="kpi-icon" style="background:#FFF3E0; color:#E65100;"><i data-lucide="banknote" style="width:22px;height:22px;"></i></div>

        <div><div class="kpi-val">@total.ToString("N0")</div><div class="kpi-lbl">Montant total versé (FCFA)</div></div>

    </div>

    <div class="kpi-card">

        <div class="kpi-icon" style="background:#E8F5E9; color:#388E3C;"><i data-lucide="users" style="width:22px;height:22px;"></i></div>

        <div><div class="kpi-val">@Model.Select(v => v.IdMembre).Distinct().Count()</div><div class="kpi-lbl">Membres bénéficiaires</div></div>

    </div>

    <div class="kpi-card">

        <div class="kpi-icon" style="background:#EDE7F6; color:#6A1B9A;"><i data-lucide="wallet" style="width:22px;height:22px;"></i></div>

        <div><div class="kpi-val">@totalNet.ToString("N0")</div><div class="kpi-lbl">Total net encaissé (FCFA)</div></div>

    </div>

    <div class="kpi-card">

        <div class="kpi-icon" style="background:#FBE9E7; color:#BF360C;"><i data-lucide="percent" style="width:22px;height:22px;"></i></div>

        <div><div class="kpi-val">@totalComm.ToString("N0")</div><div class="kpi-lbl">Total commissions (FCFA)</div></div>

    </div>

</div>



<div class="toolbar">

    <h2 style="font-size:16px; font-weight:600; color:#1a1a1a; margin:0;">Liste des versements</h2>

    <div style="display:flex; gap:10px; align-items:center;">

        <input id="search-versement" type="text" placeholder="Rechercher par membre, tontineâ€¦"

               oninput="filtrerVersements(this.value)"

               style="padding:9px 14px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:13px; outline:none; min-width:260px;"

               onfocus="this.style.borderColor='#0F6E56'" onblur="this.style.borderColor='#E0E0E0'" />

        <button type="button" onclick="pagerVer.csv(['Membre','Tontine','Cycle','Montant brut','Déduction','Commission','Net encaissé','Date','Notes'],function(r){var c=r.querySelectorAll('td');return[c[0].textContent.trim(),c[1].textContent.trim(),c[2].textContent.trim(),c[3].textContent.trim(),c[4].textContent.trim(),c[5].textContent.trim(),c[6].textContent.trim(),c[7].textContent.trim(),c[8].textContent.trim()]},'versements')" style="background:#1565C0;color:white;border:none;border-radius:8px;padding:9px 14px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;"><i data-lucide="download" style="width:14px;height:14px;"></i> CSV</button>
        <a asp-action="Create" class="btn-add">+ Nouveau versement</a>

    </div>

</div>



<div class="table-card" id="tc-versement">

    @if (!Model.Any())

    {

        <div class="empty-msg">Aucun versement enregistré pour le moment.</div>

    }

    else

    {

        <table>

            <thead>

                <tr>

                    <th>Membre bénéficiaire</th>

                    <th>Tontine</th>

                    <th>Cycle</th>

                    <th>Montant brut</th>

                    <th>Déduction</th>

                    <th>Commission</th>

                    <th>Net encaissé</th>

                    <th>Date</th>

                    <th>Notes</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody id="tbody-versements">

                @foreach (var v in Model)

                {

                    <tr class="versement-row" data-search="@v.NomMembre @v.LibelleTontine @v.NomCycle">

                        <td style=”font-weight:500;”>@v.NomMembre</td>

                        <td>@v.LibelleTontine</td>

                        <td>@v.NomCycle</td>

                        <td style=”font-weight:600; color:#0F6E56;”>@v.Montant.ToString(“N0”) FCFA</td>

                        <td style=”color:#F57F17; font-size:12px;”>- @v.MontantDeduction.ToString(“N0”)</td>

                        <td style=”color:#BF360C; font-size:12px;”>- @v.MontantCommission.ToString(“N0”)</td>

                        <td style=”font-weight:700; color:#1B5E20;”>@v.MontantNet.ToString(“N0”) FCFA</td>

                        <td>@v.DateVersement.ToString(“dd/MM/yyyy”)</td>

                        <td style=”color:#888780; font-size:12px;”>@(v.Notes ?? “—“)</td>

                        <td>

                            <a asp-action=”Delete” asp-route-id=”@v.IdVersement” class=”action-btn btn-del” style=”display:inline-flex;align-items:center;gap:4px;”><i data-lucide=”trash-2” style=”width:13px;height:13px;”></i> Supprimer</a>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    }

</div>



@section Scripts {

<script>

var pagerVer = new TablePager({ rowClass: 'versement-row', pageSize: 15, barParent: 'tc-versement' });
function filtrerVersements(q) { pagerVer.search(q); }

</script>

}


