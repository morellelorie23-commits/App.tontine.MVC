@model tontine.MVC.Models.MembreViewModel
@{ Layout = "~/Views/Shared/_LayoutMembre.cshtml"; ViewData["Title"] = "Mon profil"; }

<div style="max-width:640px;">
    <h2 style="margin:0 0 24px;font-size:22px;font-weight:700;">Mon profil</h2>

    <div style="background:white;border-radius:16px;padding:32px;box-shadow:0 1px 4px rgba(0,0,0,0.07);margin-bottom:20px;">
        <!-- Photo + nom -->
        <div style="display:flex;align-items:center;gap:20px;margin-bottom:28px;padding-bottom:24px;border-bottom:1px solid #F4F4F2;">
            @if (!string.IsNullOrEmpty(Model.Photo))
            {
                <img src="/uploads/@Model.Photo" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid #0F6E56;" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:50%;background:#0F6E56;display:flex;align-items:center;justify-content:center;color:white;font-size:30px;font-weight:700;">
                    @Model.Prenom[0]
                </div>
            }
            <div>
                <div style="font-size:22px;font-weight:700;color:#1a1a1a;">@Model.Prenom @Model.Nom</div>
                @if (!string.IsNullOrEmpty(Model.Profession))
                {
                    <div style="color:#888;font-size:14px;margin-top:4px;">@Model.Profession</div>
                }
            </div>
        </div>

        <!-- Informations personnelles -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            @{
                void Row(string label, string? val)
                {
                    if (string.IsNullOrEmpty(val)) return;
                    <div>
                        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;margin-bottom:4px;">@label</div>
                        <div style="font-size:14px;color:#1a1a1a;font-weight:500;">@val</div>
                    </div>;
                }
            }
            @{ Row("Email", Model.Email); }
            @{ Row("Téléphone", Model.Telephone); }
            @{ Row("Sexe", Model.Sexe); }
            @if (Model.DateNaissance.HasValue)
            {
                <div>
                    <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Date de naissance</div>
                    <div style="font-size:14px;color:#1a1a1a;font-weight:500;">@Model.DateNaissance.Value.ToString("dd/MM/yyyy")</div>
                </div>
            }
            @{ Row("Adresse", Model.Adresse); }
            @{ Row("Ville", Model.Ville); }
            @{ Row("Pays", Model.Pays); }
            @{ Row("N° CNI", Model.NumeroCni); }
        </div>
    </div>

    <div style="background:#F0FAF6;border-radius:10px;padding:16px 20px;border:1px solid #A5D6A7;font-size:13px;color:#085041;">
        <i data-lucide="info" style="width:14px;height:14px;vertical-align:middle;margin-right:6px;"></i>
        Pour modifier vos informations personnelles, contactez votre administrateur.
    </div>
</div>
