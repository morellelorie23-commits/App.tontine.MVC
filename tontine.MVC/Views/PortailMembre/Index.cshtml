@model tontine.MVC.Models.PortailMembreViewModel
@{ Layout = "~/Views/Shared/_LayoutMembre.cshtml"; ViewData["Title"] = "Mon tableau de bord"; string F(decimal v) => v.ToString("N0") + " FCFA"; }

<!-- Bannière statut cotisations -->
@if (Model.CotisationsEnRetard > 0)
{
    <div style="background:#FEE2E2;border:1.5px solid #FCA5A5;border-radius:12px;padding:14px 20px;
                display:flex;align-items:center;gap:12px;margin-bottom:20px;">
        <svg style="width:20px;height:20px;color:#DC2626;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div>
            <span style="font-size:14px;font-weight:700;color:#DC2626;">
                @Model.CotisationsEnRetard cotisation(s) en retard
            </span>
            <span style="font-size:13px;color:#991B1B;margin-left:8px;">
                — Régularisez votre situation au plus vite pour ne pas perdre votre tour.
            </span>
        </div>
    </div>
}
else if (Model.MesCotisations.Any())
{
    <div style="background:#D1FAE5;border:1.5px solid #6EE7B7;border-radius:12px;padding:12px 20px;
                display:flex;align-items:center;gap:10px;margin-bottom:20px;">
        <svg style="width:18px;height:18px;color:#065F46;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span style="font-size:13px;font-weight:600;color:#065F46;">Vous êtes à jour dans vos cotisations.</span>
    </div>
}

<!-- Salutation -->
<div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
    @if (!string.IsNullOrEmpty(Model.Membre.Photo))
    {
        <img src="/uploads/@Model.Membre.Photo" style="width:52px;height:52px;border-radius:50%;object-fit:cover;border:3px solid #0F6E56;" />
    }
    else
    {
        <div style="width:52px;height:52px;border-radius:50%;background:#0F6E56;display:flex;align-items:center;justify-content:center;color:white;font-size:20px;font-weight:700;">
            @Model.Membre.Prenom[0]
        </div>
    }
    <div>
        <h2 style="margin:0;font-size:20px;font-weight:700;color:#1a1a1a;">Bonjour, @Model.Membre.Prenom !</h2>
        <p style="margin:0;color:#6B7280;font-size:13px;">Cycle actif : <strong>@ViewBag.CycleNom</strong></p>
    </div>
</div>

<!-- KPIs -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px;">
    <div class="kpi-card">
        <div style="width:36px;height:36px;border-radius:8px;background:#E6F4EE;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
            <svg style="width:18px;height:18px;color:#0F6E56;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
        </div>
        <div style="font-size:18px;font-weight:700;color:#1a1a1a;">@F(Model.TotalCotise)</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Total cotisé</div>
    </div>
    <div class="kpi-card">
        <div style="width:36px;height:36px;border-radius:8px;background:#EFF6FF;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
            <svg style="width:18px;height:18px;color:#1D4ED8;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
        </div>
        <div style="font-size:18px;font-weight:700;color:#1a1a1a;">@F(Model.TotalRecu)</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Total reçu</div>
    </div>
    <div class="kpi-card">
        <div style="width:36px;height:36px;border-radius:8px;background:@(Model.CotisationsEnRetard>0?"#FEE2E2":"#F3F4F6");display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
            <svg style="width:18px;height:18px;color:@(Model.CotisationsEnRetard>0?"#DC2626":"#6B7280");" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div style="font-size:18px;font-weight:700;color:@(Model.CotisationsEnRetard>0?"#DC2626":"#1a1a1a");">@Model.CotisationsEnRetard</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">En retard</div>
    </div>
    <div class="kpi-card">
        <div style="width:36px;height:36px;border-radius:8px;background:#FEF3C7;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
            <svg style="width:18px;height:18px;color:#D97706;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
        </div>
        <div style="font-size:18px;font-weight:700;color:#1a1a1a;">@Model.PretsActifs</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Prêt(s) actifs</div>
    </div>
</div>

<!-- ===== MON TOUR ===== -->
@if (Model.PlanningParTontine.Any())
{
    foreach (var planning in Model.PlanningParTontine)
    {
        <div style="background:white;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,0.08);margin-bottom:20px;overflow:hidden;">

            <!-- En-tête -->
            <div style="background:linear-gradient(135deg,#0B5940,#0F6E56);padding:20px 24px;display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:rgba(255,255,255,0.6);margin-bottom:4px;">
                        Tontine
                    </div>
                    <h3 style="color:white;font-size:17px;font-weight:700;margin:0;">@planning.NomTontine</h3>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-bottom:2px;">Cotisation / séance</div>
                    <div style="font-size:20px;font-weight:800;color:white;">@F(planning.MontantCotisation)</div>
                    @if (!string.IsNullOrEmpty(planning.Frequence))
                    {
                        <div style="font-size:11px;color:rgba(255,255,255,0.5);">@planning.Frequence</div>
                    }
                </div>
            </div>

            <div style="padding:20px 24px;">
                <!-- Carte Mon Tour -->
                @if (planning.ADejaRecu)
                {
                    <div style="background:#F0FDF4;border:1.5px solid #6EE7B7;border-radius:12px;padding:18px 20px;margin-bottom:20px;display:flex;align-items:center;gap:14px;">
                        <div style="width:44px;height:44px;border-radius:50%;background:#059669;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg style="width:22px;height:22px;color:white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <div>
                            <div style="font-size:15px;font-weight:700;color:#065F46;">Vous avez déjà reçu votre versement</div>
                            <div style="font-size:13px;color:#059669;margin-top:2px;">Félicitations ! Votre tour est passé ce cycle.</div>
                        </div>
                    </div>
                }
                else
                {
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px;">
                        <!-- Numéro d'ordre -->
                        <div style="background:#F0FDF4;border-radius:12px;padding:16px;text-align:center;">
                            <div style="font-size:32px;font-weight:800;color:#0F6E56;line-height:1;">@planning.MonNumeroOrdre</div>
                            <div style="font-size:12px;color:#6B7280;margin-top:4px;">Mon numéro d'ordre</div>
                        </div>
                        <!-- Personnes avant moi -->
                        <div style="background:@(planning.PersonnesAvantMoi==0?"#D1FAE5":"#FEF3C7");border-radius:12px;padding:16px;text-align:center;">
                            <div style="font-size:32px;font-weight:800;color:@(planning.PersonnesAvantMoi==0?"#065F46":"#D97706");line-height:1;">@planning.PersonnesAvantMoi</div>
                            <div style="font-size:12px;color:#6B7280;margin-top:4px;">
                                @(planning.PersonnesAvantMoi == 0 ? "C'est bientôt votre tour !" : "Personne(s) avant vous")
                            </div>
                        </div>
                        <!-- Montant à recevoir -->
                        <div style="background:#EFF6FF;border-radius:12px;padding:16px;text-align:center;">
                            <div style="font-size:18px;font-weight:800;color:#1D4ED8;line-height:1.2;">@planning.MontantARecevoir.ToString("N0")</div>
                            <div style="font-size:11px;color:#6B7280;margin-top:4px;">FCFA à recevoir</div>
                        </div>
                    </div>
                }

                <!-- Progression -->
                @{
                    var pctRecu = planning.NombreTotal > 0 ? (int)((double)planning.NombreARecu / planning.NombreTotal * 100) : 0;
                }
                <div style="margin-bottom:20px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                        <span style="font-size:13px;color:#374151;font-weight:500;">Avancement du cycle</span>
                        <span style="font-size:12px;color:#6B7280;">@planning.NombreARecu / @planning.NombreTotal membres ont reçu</span>
                    </div>
                    <div style="background:#E5E7EB;border-radius:999px;height:8px;">
                        <div style="background:linear-gradient(90deg,#0F6E56,#1D9E75);border-radius:999px;height:8px;width:@pctRecu%;transition:width 0.5s;"></div>
                    </div>
                </div>

                <!-- Planning complet : tableau -->
                <details>
                    <summary style="font-size:13px;font-weight:600;color:#0F6E56;cursor:pointer;padding:8px 0;list-style:none;display:flex;align-items:center;gap:6px;">
                        <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        Voir le planning complet (@planning.NombreTotal membres)
                    </summary>
                    <div style="margin-top:12px;border:1px solid #E5E7EB;border-radius:10px;overflow:hidden;">
                        <table style="width:100%;border-collapse:collapse;font-size:13px;">
                            <thead>
                                <tr style="background:#F9FAFB;">
                                    <th style="padding:8px 14px;text-align:left;font-size:11px;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Ordre</th>
                                    <th style="padding:8px 14px;text-align:left;font-size:11px;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Membre</th>
                                    <th style="padding:8px 14px;text-align:left;font-size:11px;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Parts</th>
                                    <th style="padding:8px 14px;text-align:left;font-size:11px;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Statut</th>
                                    <th style="padding:8px 14px;text-align:right;font-size:11px;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ligne in planning.Lignes)
                                {
                                    var rowBg = ligne.EstMoi ? "#F0FDF4" : (ligne.ARecu ? "#FAFAFA" : "white");
                                    var ordreClr = ligne.EstMoi ? "#0F6E56" : "#374151";
                                    <tr class="planning-row @(ligne.EstMoi ? "planning-row-me" : "")" style="background:@rowBg;border-top:1px solid #F3F4F6;">
                                        <td style="padding:10px 14px;">
                                            <span style="display:inline-flex;width:28px;height:28px;border-radius:50%;
                                                         background:@(ligne.EstMoi?"#0F6E56":(ligne.ARecu?"#E5E7EB":"#F3F4F6"));
                                                         color:@(ligne.EstMoi?"white":(ligne.ARecu?"#6B7280":"#374151"));
                                                         font-size:12px;font-weight:700;align-items:center;justify-content:center;">
                                                @ligne.NumeroOrdre
                                            </span>
                                        </td>
                                        <td style="padding:10px 14px;">
                                            <span style="font-weight:@(ligne.EstMoi?"700":"500");color:@(ligne.EstMoi?"#0F6E56":"#111");">
                                                @ligne.NomMembre
                                                @if (ligne.EstMoi) { <span style="font-size:11px;color:#0F6E56;"> (vous)</span> }
                                            </span>
                                        </td>
                                        <td style="padding:10px 14px;color:#6B7280;">
                                            @(ligne.NombreParts == 0.5m ? "½" : ligne.NombreParts == 2m ? "×2" : "×1")
                                        </td>
                                        <td style="padding:10px 14px;">
                                            @if (ligne.ARecu)
                                            {
                                                <span style="background:#D1FAE5;color:#065F46;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">
                                                    Reçu — @ligne.MontantRecu.ToString("N0") FCFA
                                                </span>
                                            }
                                            else if (ligne.EstMoi)
                                            {
                                                <span style="background:#FEF3C7;color:#92400E;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">En attente</span>
                                            }
                                            else
                                            {
                                                <span style="background:#F3F4F6;color:#6B7280;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">En attente</span>
                                            }
                                        </td>
                                        <td style="padding:10px 14px;text-align:right;font-size:12px;color:#9CA3AF;">
                                            @(ligne.DateReception.HasValue ? ligne.DateReception.Value.ToString("dd/MM/yy") : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </details>
            </div>
        </div>
    }
}

<!-- Prochaines réunions -->
@if (Model.ProchainesReunions.Any())
{
    <div style="background:white;border-radius:16px;padding:24px;box-shadow:0 1px 6px rgba(0,0,0,0.07);margin-bottom:20px;">
        <h3 style="font-size:15px;font-weight:700;margin:0 0 16px;display:flex;align-items:center;gap:8px;color:#1a1a1a;">
            <svg style="width:16px;height:16px;color:#7C3AED;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Prochaines réunions
        </h3>
        <div style="display:flex;flex-direction:column;gap:10px;">
            @foreach (var r in Model.ProchainesReunions)
            {
                var jours = (int)(r.DateReunion - DateTime.Now).TotalDays;
                var urgence = jours <= 2 ? "#FEE2E2" : jours <= 7 ? "#FEF3C7" : "#F0FDF4";
                var urgenceClr = jours <= 2 ? "#DC2626" : jours <= 7 ? "#D97706" : "#059669";
                <div class="reunion-item" style="background:@urgence;">
                    <div style="text-align:center;min-width:48px;">
                        <div style="font-size:20px;font-weight:800;color:@urgenceClr;line-height:1;">@r.DateReunion.Day</div>
                        <div style="font-size:10px;font-weight:700;color:@urgenceClr;text-transform:uppercase;">@r.DateReunion.ToString("MMM")</div>
                    </div>
                    <div style="width:1px;height:36px;background:rgba(0,0,0,0.1);"></div>
                    <div style="flex:1;">
                        <div style="font-size:14px;font-weight:600;color:#1a1a1a;">@r.Objet</div>
                        @if (!string.IsNullOrEmpty(r.Lieu))
                        {
                            <div style="font-size:12px;color:#6B7280;margin-top:2px;">📍 @r.Lieu</div>
                        }
                    </div>
                    <div style="text-align:right;font-size:12px;font-weight:700;color:@urgenceClr;white-space:nowrap;">
                        @(jours == 0 ? "Aujourd'hui" : jours == 1 ? "Demain" : $"Dans {jours}j")
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Cotisations + Versements -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div style="background:white;border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <h3 style="font-size:14px;font-weight:700;margin:0 0 14px;display:flex;align-items:center;gap:8px;">
            <svg style="width:15px;height:15px;color:#0F6E56;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            Mes cotisations
            <a asp-action="MesCotisations" style="margin-left:auto;font-size:11px;color:#0F6E56;text-decoration:none;font-weight:500;">Voir tout →</a>
        </h3>
        @if (!Model.MesCotisations.Any())
        {
            <p style="color:#9CA3AF;font-size:13px;text-align:center;padding:16px 0;">Aucune cotisation ce cycle.</p>
        }
        else
        {
            @foreach (var c in Model.MesCotisations.Take(5))
            {
                var (bg, clr) = c.Statut switch {
                    "Payé"      => ("#D1FAE5","#065F46"),
                    "En retard" => ("#FEE2E2","#DC2626"),
                    _           => ("#FEF3C7","#D97706")
                };
                <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid #F4F4F2;">
                    <div>
                        <div style="font-size:13px;font-weight:600;">@c.LibelleTontine</div>
                        <div style="font-size:11px;color:#9CA3AF;">@c.DateCotisation.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="font-size:12px;font-weight:700;color:#0F6E56;">@c.Montant.ToString("N0")</span>
                        <span style="background:@bg;color:@clr;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;">@c.Statut</span>
                    </div>
                </div>
            }
        }
    </div>

    <div style="background:white;border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <h3 style="font-size:14px;font-weight:700;margin:0 0 14px;display:flex;align-items:center;gap:8px;">
            <svg style="width:15px;height:15px;color:#1D4ED8;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Mes versements reçus
            <a asp-action="MesVersements" style="margin-left:auto;font-size:11px;color:#0F6E56;text-decoration:none;font-weight:500;">Voir tout →</a>
        </h3>
        @if (!Model.MesVersements.Any())
        {
            <p style="color:#9CA3AF;font-size:13px;text-align:center;padding:16px 0;">Aucun versement reçu ce cycle.</p>
        }
        else
        {
            @foreach (var v in Model.MesVersements.Take(5))
            {
                <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid #F4F4F2;">
                    <div>
                        <div style="font-size:13px;font-weight:600;">@v.LibelleTontine</div>
                        <div style="font-size:11px;color:#9CA3AF;">@v.DateVersement.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div style="font-size:14px;font-weight:700;color:#1D4ED8;">@F(v.MontantNet)</div>
                </div>
            }
        }
    </div>
</div>
