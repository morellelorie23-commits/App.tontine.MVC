@model List<tontine.MVC.Models.MembreViewModel>
@{
    ViewData["Title"] = "Membres";
}

<div style="padding:8px 0;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <div>
            <h2 style="margin:0; font-size:22px; font-weight:600; color:#1a1a1a;">Gestion des membres</h2>
            <p style="margin:4px 0 0; color:#888780; font-size:14px;">@Model.Count membre(s) enregistré(s)</p>
        </div>
        <button onclick="ouvrirModal()"
                style="background:#0F6E56; color:white; border:none; border-radius:8px;
                       padding:10px 20px; font-size:14px; font-weight:500; cursor:pointer;
                       box-shadow:0 2px 8px rgba(15,110,86,0.3);">
            + Nouveau membre
        </button>
    </div>

    <div style="background:white; border-radius:12px; overflow:hidden;
                box-shadow:0 1px 4px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
            <thead>
                <tr style="background:linear-gradient(135deg, #0F6E56, #1D9E75);">
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Photo</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Nom</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Prénom</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Téléphone</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Email</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Ville</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Inscription</th>
                    <th style="padding:14px 18px; text-align:left; font-weight:500; color:white; font-size:13px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr style="border-bottom:1px solid #F1EFE8;"
                        onmouseover="this.style.background='#F8FDF9'"
                        onmouseout="this.style.background='white'">
                        <td style="padding:10px 18px;">
                            @if (!string.IsNullOrEmpty(m.Photo))
                            {
                                <img src="/uploads/@m.Photo"
                                     style="width:40px; height:40px; border-radius:50%;
                                                    object-fit:cover; border:2px solid #E1F5EE;" />
                            }
                            else
                            {
                                <div style="width:40px; height:40px; border-radius:50%;
                                                    background:#0F6E56; color:white;
                                                    display:flex; align-items:center; justify-content:center;
                                                    font-size:14px; font-weight:600;">
                                    @m.Nom.Substring(0, 1).ToUpper()@m.Prenom.Substring(0, 1).ToUpper()
                                </div>
                            }
                        </td>
                        <td style="padding:14px 18px; font-weight:600; color:#1a1a1a;">@m.Nom</td>
                        <td style="padding:14px 18px; color:#2C2C2A;">@m.Prenom</td>
                        <td style="padding:14px 18px; color:#5F5E5A;">@m.Telephone</td>
                        <td style="padding:14px 18px; color:#5F5E5A;">@m.Email</td>
                        <td style="padding:14px 18px;">
                            <span style="background:#E1F5EE; color:#085041; padding:3px 10px;
                                             border-radius:20px; font-size:12px; font-weight:500;">
                                @m.Ville
                            </span>
                        </td>
                        <td style="padding:14px 18px; color:#888780; font-size:13px;">
                            @m.DateInscription.ToString("dd/MM/yyyy")
                        </td>
                        <td style="padding:14px 18px;">
                            <div style="display:flex; gap:8px;">
                                <a asp-action="Edit" asp-route-id="@m.IdMembre"
                                   style="background:#FFF8E1; color:#F57F17; border:1px solid #FFE082;
                                              border-radius:6px; padding:6px 14px; font-size:12px;
                                              text-decoration:none; font-weight:500;">
                                    ✏️ Modifier
                                </a>
                                <button onclick="confirmerSuppression(@m.IdMembre, '@m.Nom @m.Prenom')"
                                        style="background:#FFEBEE; color:#C62828; border:1px solid #FFCDD2;
                                                   border-radius:6px; padding:6px 14px; font-size:12px;
                                                   font-weight:500; cursor:pointer;">
                                    🗑️ Supprimer
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" style="padding:48px; text-align:center; color:#888780;">
                            <div style="font-size:32px; margin-bottom:8px;">👥</div>
                            <div style="font-weight:500;">Aucun membre enregistré</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Ajout -->
<div id="modal-overlay"
     style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.5); z-index:1000; overflow-y:auto;">
    <div style="background:white; border-radius:16px; max-width:700px; margin:40px auto;
                padding:32px; position:relative; box-shadow:0 8px 32px rgba(0,0,0,0.2);">
        <div style="display:flex; justify-content:space-between; align-items:center;
                    margin-bottom:24px; padding-bottom:16px; border-bottom:1px solid #F1EFE8;">
            <div>
                <h3 style="margin:0; font-size:18px; font-weight:600; color:#1a1a1a;">Nouveau membre</h3>
                <p style="margin:4px 0 0; color:#888780; font-size:13px;">Remplissez les informations</p>
            </div>
            <button onclick="fermerModal()"
                    style="background:#F1EFE8; border:none; border-radius:50%;
                           width:32px; height:32px; font-size:16px; cursor:pointer; color:#5F5E5A;">
                ✕
            </button>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Photo -->
            <div style="text-align:center; margin-bottom:24px;">
                <div id="photo-preview"
                     style="width:80px; height:80px; border-radius:50%; background:#E1F5EE;
                            margin:0 auto 12px; display:flex; align-items:center;
                            justify-content:center; font-size:28px; overflow:hidden;
                            border:3px solid #0F6E56;">
                    👤
                </div>
                <label style="background:#F1EFE8; color:#0F6E56; border:1.5px solid #0F6E56;
                              border-radius:6px; padding:6px 16px; font-size:13px;
                              cursor:pointer; font-weight:500;">
                    📷 Choisir une photo
                    <input type="file" name="PhotoFile" accept="image/*" style="display:none;"
                           onchange="previewPhoto(this)" />
                </label>
            </div>

            <!-- Identité -->
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                <div style="width:4px; height:18px; background:#0F6E56; border-radius:2px;"></div>
                <span style="font-size:12px; font-weight:600; color:#0F6E56; text-transform:uppercase; letter-spacing:0.5px;">Identité</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Nom *</label>
                    <input name="Nom" required
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Prénom *</label>
                    <input name="Prenom" required
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Sexe</label>
                    <select name="Sexe"
                            style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                   border-radius:7px; font-size:13px; background:white; outline:none;">
                        <option value="">-- Choisir --</option>
                        <option value="M">Masculin</option>
                        <option value="F">Féminin</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Date de naissance</label>
                    <input name="DateNaissance" type="date"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;" />
                </div>
            </div>

            <!-- Contact -->
            <div style="border-top:1px dashed #E0E0E0; margin-bottom:18px;"></div>
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                <div style="width:4px; height:18px; background:#1D9E75; border-radius:2px;"></div>
                <span style="font-size:12px; font-weight:600; color:#1D9E75; text-transform:uppercase; letter-spacing:0.5px;">Contact</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Téléphone</label>
                    <input name="Telephone"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Email</label>
                    <input name="Email" type="email"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; margin-bottom:20px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Adresse</label>
                    <input name="Adresse"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Ville</label>
                    <input name="Ville"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Pays</label>
                    <select name="Pays"
                            style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                   border-radius:7px; font-size:13px; background:white; outline:none;">
                        <option value="">-- Choisir --</option>
                        <option value="Cameroun">Cameroun</option>
                        <option value="Sénégal">Sénégal</option>
                        <option value="Côte d'Ivoire">Côte d'Ivoire</option>
                        <option value="Mali">Mali</option>
                        <option value="Burkina Faso">Burkina Faso</option>
                        <option value="Guinée">Guinée</option>
                        <option value="Congo">Congo</option>
                        <option value="Gabon">Gabon</option>
                        <option value="Togo">Togo</option>
                        <option value="Bénin">Bénin</option>
                        <option value="Niger">Niger</option>
                        <option value="Tchad">Tchad</option>
                        <option value="France">France</option>
                        <option value="Belgique">Belgique</option>
                        <option value="Autre">Autre</option>
                    </select>
                </div>
            </div>

            <!-- Infos complémentaires -->
            <div style="border-top:1px dashed #E0E0E0; margin-bottom:18px;"></div>
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                <div style="width:4px; height:18px; background:#888780; border-radius:2px;"></div>
                <span style="font-size:12px; font-weight:600; color:#888780; text-transform:uppercase; letter-spacing:0.5px;">Informations complémentaires</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:24px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Profession</label>
                    <input name="Profession"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:5px;">Numéro CNI</label>
                    <input name="NumeroCni"
                           style="width:100%; padding:9px 12px; border:1.5px solid #E0E0E0;
                                  border-radius:7px; font-size:13px; outline:none;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>

            <!-- Boutons -->
            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:16px; border-top:1px solid #F1EFE8;">
                <button type="button" onclick="fermerModal()"
                        style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                               border-radius:8px; padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;">
                    Annuler
                </button>
                <button type="submit"
                        style="background:#0F6E56; color:white; border:none; border-radius:8px;
                               padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;
                               box-shadow:0 2px 8px rgba(15,110,86,0.3);">
                    Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Suppression -->
<div id="modal-suppression"
     style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.5); z-index:1000;">
    <div style="background:white; border-radius:16px; max-width:420px; margin:120px auto;
                padding:28px; box-shadow:0 8px 32px rgba(0,0,0,0.2);">
        <div style="text-align:center; margin-bottom:20px;">
            <div style="font-size:40px; margin-bottom:12px;">⚠️</div>
            <h3 style="margin:0; font-size:16px; font-weight:600; color:#1a1a1a;">Confirmer la suppression</h3>
            <p id="msg-suppression" style="margin:8px 0 0; color:#888780; font-size:14px;"></p>
        </div>
        <div style="background:#FFEBEE; border-radius:8px; padding:12px; margin-bottom:20px; font-size:13px; color:#C62828;">
            Cette action est irréversible.
        </div>
        <form id="form-suppression" method="post">
            @Html.AntiForgeryToken()
            <div style="display:flex; gap:12px; justify-content:center;">
                <button type="button" onclick="fermerSuppression()"
                        style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                               border-radius:8px; padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;">
                    Annuler
                </button>
                <button type="submit"
                        style="background:#C62828; color:white; border:none; border-radius:8px;
                               padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;
                               box-shadow:0 2px 8px rgba(198,40,40,0.3);">
                    🗑️ Supprimer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function ouvrirModal() {
            document.getElementById('modal-overlay').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }
        function fermerModal() {
            document.getElementById('modal-overlay').style.display = 'none';
            document.body.style.overflow = 'auto';
        }
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    const preview = document.getElementById('photo-preview');
                    preview.innerHTML = `<img src="${e.target.result}"
                        style="width:100%; height:100%; object-fit:cover; border-radius:50%;"/>`;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        function confirmerSuppression(id, nom) {
            document.getElementById('msg-suppression').textContent = `Voulez-vous supprimer : ${nom} ?`;
            document.getElementById('form-suppression').action = `/Membre/Delete/${id}`;
            document.getElementById('modal-suppression').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }
        function fermerSuppression() {
            document.getElementById('modal-suppression').style.display = 'none';
            document.body.style.overflow = 'auto';
        }
        document.getElementById('modal-overlay').addEventListener('click', function(e) {
            if (e.target === this) fermerModal();
        });
        document.getElementById('modal-suppression').addEventListener('click', function(e) {
            if (e.target === this) fermerSuppression();
        });
    </script>
}