@model tontine.MVC.Models.MembreViewModel
@{
    ViewData["Title"] = "Nouveau membre";
}

<div style="max-width:520px;">
    <div style="margin-bottom:24px;">
        <a asp-action="Index" style="color:#0F6E56; font-size:13px; text-decoration:none; font-weight:500;">
            ← Retour à la liste
        </a>
        <h2 style="margin:8px 0 4px; font-size:22px; font-weight:600; color:#1a1a1a;">Nouveau membre</h2>
        <p style="margin:0; color:#888780; font-size:14px;">Enregistrer un nouveau participant</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data"
          data-confirm="Voulez-vous créer ce membre ?"
          data-confirm-type="create">
        @Html.AntiForgeryToken()

        <div style="background:white; border-radius:12px; padding:28px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);">

            <!-- Photo -->
            <div style="text-align:center; margin-bottom:24px;">
                <div style="width:80px; height:80px; border-radius:50%; background:#E1F5EE;
                            margin:0 auto 12px; overflow:hidden; border:3px solid #0F6E56;
                            display:flex; align-items:center; justify-content:center; font-size:28px;">
                    <i data-lucide="user" style="width:32px;height:32px;color:#0F6E56;"></i>
                </div>
                <label style="background:#F1EFE8; color:#0F6E56; border:1.5px solid #0F6E56;
                              border-radius:6px; padding:6px 16px; font-size:13px;
                              cursor:pointer; font-weight:500;">
                    <i data-lucide="camera" style="width:13px;height:13px;vertical-align:middle;margin-right:4px;"></i>Ajouter une photo
                    <input type="file" name="PhotoFile" accept="image/*" style="display:none;" />
                </label>
            </div>

            <!-- Identité -->
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
                <div style="width:4px; height:20px; background:#0F6E56; border-radius:2px;"></div>
                <span style="font-size:13px; font-weight:600; color:#0F6E56; text-transform:uppercase; letter-spacing:0.5px;">Identité</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                <div>
                    <label asp-for="Nom" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Nom"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                    <span asp-validation-for="Nom" style="color:#C62828; font-size:12px;"></span>
                </div>
                <div>
                    <label asp-for="Prenom" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Prenom"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px;">
                <div>
                    <label asp-for="Sexe" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <select asp-for="Sexe"
                            style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                   border-radius:8px; font-size:14px; background:white; outline:none; box-sizing:border-box;">
                        <option value="">-- Choisir --</option>
                        <option value="M">Masculin</option>
                        <option value="F">Féminin</option>
                    </select>
                </div>
                <div>
                    <label asp-for="DateNaissance" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="DateNaissance" type="date"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" />
                </div>
            </div>

            <!-- Contact -->
            <div style="border-top:1px dashed #E0E0E0; margin-bottom:24px;"></div>
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
                <div style="width:4px; height:20px; background:#1D9E75; border-radius:2px;"></div>
                <span style="font-size:13px; font-weight:600; color:#1D9E75; text-transform:uppercase; letter-spacing:0.5px;">Contact</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                <div>
                    <label asp-for="Telephone" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Telephone"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label asp-for="Email" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Email" type="email"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:24px;">
                <div>
                    <label asp-for="Adresse" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Adresse"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label asp-for="Ville" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Ville"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label asp-for="Pays" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <select asp-for="Pays"
                            style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                   border-radius:8px; font-size:14px; background:white; outline:none; box-sizing:border-box;">
                        <option value="">-- Choisir --</option>
                        <option value="Cameroun">Cameroun</option>
                        <option value="Sénégal">Sénégal</option>
                        <option value="Côte d'Ivoire">Côte d'Ivoire</option>
                        <option value="Mali">Mali</option>
                        <option value="Burkina Faso">Burkina Faso</option>
                        <option value="Guinée">Guinée</option>
                        <option value="Congo">Congo</option>
                        <option value="Gabon">Gabon</option>
                        <option value="Togo">Togo</option>
                        <option value="Bénin">Bénin</option>
                        <option value="Niger">Niger</option>
                        <option value="Tchad">Tchad</option>
                        <option value="France">France</option>
                        <option value="Belgique">Belgique</option>
                        <option value="Autre">Autre</option>
                    </select>
                </div>
            </div>

            <!-- Infos complémentaires -->
            <div style="border-top:1px dashed #E0E0E0; margin-bottom:24px;"></div>
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
                <div style="width:4px; height:20px; background:#888780; border-radius:2px;"></div>
                <span style="font-size:13px; font-weight:600; color:#888780; text-transform:uppercase; letter-spacing:0.5px;">Informations complémentaires</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:28px;">
                <div>
                    <label asp-for="Profession" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Profession"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
                <div>
                    <label asp-for="NumeroCni" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="NumeroCni"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                </div>
            </div>

            <!-- Boutons -->
            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:20px; border-top:1px solid #F1EFE8;">
                <a asp-action="Index"
                   style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                          border-radius:8px; padding:10px 24px; font-size:14px;
                          text-decoration:none; font-weight:500;">
                    Annuler
                </a>
                <button type="submit"
                        style="background:#0F6E56; color:white; border:none; border-radius:8px;
                               padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;
                               box-shadow:0 2px 8px rgba(15,110,86,0.3);">
                    Créer le membre
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
