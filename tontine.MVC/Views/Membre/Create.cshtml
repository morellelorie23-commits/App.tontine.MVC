@model tontine.MVC.Models.MembreViewModel
@{
    ViewData["Title"] = "Nouveau membre";
}

@* Styles spécifiques pour les champs avec icône *@
<style>
    .field-icon-wrap { position:relative; }
    .field-icon-wrap .field-ico {
        position:absolute; left:12px; top:50%; transform:translateY(-50%);
        pointer-events:none; display:flex; align-items:center; color:#aaa;
    }
    .field-icon-wrap input,
    .field-icon-wrap select { padding-left:36px !important; }
    .section-badge {
        display:inline-flex; align-items:center; gap:8px;
        padding:5px 14px 5px 10px; border-radius:20px;
        font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px;
        margin-bottom:18px;
    }
    .inp {
        width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
        border-radius:8px; font-size:13px; outline:none; box-sizing:border-box;
        transition:border-color .2s;
    }
    .inp:focus { border-color:#0F6E56; }
    .sel {
        width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
        border-radius:8px; font-size:13px; background:white; outline:none; box-sizing:border-box;
        transition:border-color .2s;
    }
    .sel:focus { border-color:#0F6E56; }
    .lbl { font-size:12px; font-weight:600; color:#444; display:block; margin-bottom:5px; }
</style>

<div style="max-width:540px;">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:5px;color:#0F6E56;font-size:13px;text-decoration:none;font-weight:500;margin-bottom:16px;">
        <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Retour à la liste
    </a>

    <form asp-action="Create" method="post" enctype="multipart/form-data"
          data-confirm="Voulez-vous créer ce membre ?"
          data-confirm-type="create">
        @Html.AntiForgeryToken()

        <div style="background:white; border-radius:16px; overflow:hidden;
                    box-shadow:0 2px 8px rgba(0,0,0,0.08), 0 8px 24px rgba(0,0,0,0.05);">

            <!-- En-tête dégradé -->
            <div style="background:linear-gradient(135deg,#0B5940,#0F6E56,#1D9E75);padding:22px 28px;display:flex;align-items:center;gap:14px;">
                <div style="width:42px;height:42px;background:rgba(255,255,255,0.18);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i data-lucide="user-plus" style="width:20px;height:20px;color:white;"></i>
                </div>
                <div>
                    <h2 style="margin:0;font-size:18px;font-weight:700;color:white;">Nouveau membre</h2>
                    <p style="margin:2px 0 0;font-size:12px;color:rgba(255,255,255,0.75);">Enregistrer un nouveau participant à la tontine</p>
                </div>
            </div>

            <div style="padding:28px;">

                <!-- Photo -->
                <div style="text-align:center; margin-bottom:28px;">
                    <div id="photo-preview-create"
                         style="width:88px; height:88px; border-radius:50%; background:linear-gradient(135deg,#E1F5EE,#E8F8F2);
                                margin:0 auto 14px; overflow:hidden; border:3px solid #0F6E56;
                                display:flex; align-items:center; justify-content:center; box-shadow:0 4px 16px rgba(15,110,86,0.2);">
                        <i data-lucide="user" style="width:34px;height:34px;color:#0F6E56;"></i>
                    </div>
                    <label style="background:#E6F4EE; color:#0F6E56; border:1.5px solid #0F6E56;
                                  border-radius:20px; padding:7px 18px; font-size:12px;
                                  cursor:pointer; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
                        <i data-lucide="camera" style="width:13px;height:13px;"></i> Choisir une photo
                        <input type="file" name="PhotoFile" accept="image/*" style="display:none;"
                               onchange="previewPhotoCreate(this)" />
                    </label>
                </div>

                <!-- Section Identité -->
                <div class="section-badge" style="background:#E6F4EE;color:#0F6E56;">
                    <i data-lucide="id-card" style="width:14px;height:14px;"></i>
                    Identité
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                    <div>
                        <label asp-for="Nom" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="user" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Nom" class="inp" placeholder="Nom de famille" />
                        </div>
                        <span asp-validation-for="Nom" style="color:#C62828; font-size:11px;"></span>
                    </div>
                    <div>
                        <label asp-for="Prenom" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="user" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Prenom" class="inp" placeholder="Prénom" />
                        </div>
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:22px;">
                    <div>
                        <label asp-for="Sexe" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="users" style="width:14px;height:14px;"></i></div>
                            <select asp-for="Sexe" class="sel">
                                <option value="">-- Choisir --</option>
                                <option value="M">Masculin</option>
                                <option value="F">Féminin</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label asp-for="DateNaissance" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="calendar" style="width:14px;height:14px;"></i></div>
                            <input asp-for="DateNaissance" type="date" class="inp" />
                        </div>
                    </div>
                </div>

                <!-- Section Contact -->
                <div style="border-top:1px solid #F0F0F0; margin-bottom:22px;"></div>
                <div class="section-badge" style="background:#E3F2FD;color:#1565C0;">
                    <i data-lucide="phone" style="width:14px;height:14px;"></i>
                    Contact
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                    <div>
                        <label asp-for="Telephone" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="phone" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Telephone" class="inp" placeholder="237..." />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Email" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="mail" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Email" type="email" class="inp" placeholder="email@exemple.com" />
                        </div>
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; margin-bottom:22px;">
                    <div>
                        <label asp-for="Adresse" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="map-pin" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Adresse" class="inp" placeholder="Rue / quartier" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Ville" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="building-2" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Ville" class="inp" placeholder="Ville" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Pays" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="globe" style="width:14px;height:14px;"></i></div>
                            <select asp-for="Pays" class="sel">
                                <option value="">-- Choisir --</option>
                                <option value="Cameroun">Cameroun</option>
                                <option value="Sénégal">Sénégal</option>
                                <option value="Côte d'Ivoire">Côte d'Ivoire</option>
                                <option value="Mali">Mali</option>
                                <option value="Burkina Faso">Burkina Faso</option>
                                <option value="Guinée">Guinée</option>
                                <option value="Congo">Congo</option>
                                <option value="Gabon">Gabon</option>
                                <option value="Togo">Togo</option>
                                <option value="Bénin">Bénin</option>
                                <option value="Niger">Niger</option>
                                <option value="Tchad">Tchad</option>
                                <option value="France">France</option>
                                <option value="Belgique">Belgique</option>
                                <option value="Autre">Autre</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Section Infos complémentaires -->
                <div style="border-top:1px solid #F0F0F0; margin-bottom:22px;"></div>
                <div class="section-badge" style="background:#F3E5F5;color:#7B1FA2;">
                    <i data-lucide="briefcase" style="width:14px;height:14px;"></i>
                    Informations complémentaires
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:28px;">
                    <div>
                        <label asp-for="Profession" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="briefcase" style="width:14px;height:14px;"></i></div>
                            <input asp-for="Profession" class="inp" placeholder="Ex: Commerçant" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="NumeroCni" class="lbl"></label>
                        <div class="field-icon-wrap">
                            <div class="field-ico"><i data-lucide="credit-card" style="width:14px;height:14px;"></i></div>
                            <input asp-for="NumeroCni" class="inp" placeholder="N° CNI / Passeport" />
                        </div>
                    </div>
                </div>

                <!-- Boutons -->
                <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:20px; border-top:1px solid #F0F0F0;">
                    <a asp-action="Index"
                       style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                              border-radius:10px; padding:11px 24px; font-size:13px;
                              text-decoration:none; font-weight:500; display:inline-flex; align-items:center; gap:6px;">
                        <i data-lucide="x" style="width:14px;height:14px;"></i> Annuler
                    </a>
                    <button type="submit"
                            style="background:linear-gradient(135deg,#0F6E56,#1D9E75); color:white; border:none; border-radius:10px;
                                   padding:11px 24px; font-size:13px; font-weight:600; cursor:pointer;
                                   box-shadow:0 4px 14px rgba(15,110,86,0.35); display:inline-flex; align-items:center; gap:7px;">
                        <i data-lucide="check" style="width:15px;height:15px;"></i> Créer le membre
                    </button>
                </div>

            </div><!-- /padding -->
        </div><!-- /card -->
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
    function previewPhotoCreate(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('photo-preview-create');
                preview.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"/>';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    </script>
}
