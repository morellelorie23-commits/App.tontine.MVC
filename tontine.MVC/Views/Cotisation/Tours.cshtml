@model List<tontine.MVC.Models.TourViewModel>
@{
    ViewData["Title"] = "Tableau des tours";
    var tontines = ViewBag.Tontines as List<tontine.MVC.Models.TontineViewModel> ?? new();
    int idTontine = ViewBag.IdTontine ?? 0;
    var recu    = Model.Count(t => t.ARecu);
    var total   = Model.Count;
    var enCours = Model.FirstOrDefault(t => !t.ARecu);
}

<style>
    .kpi-row   { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }
    .kpi-card  { background:white; border-radius:12px; padding:18px 20px;
                 box-shadow:0 1px 4px rgba(0,0,0,0.07); display:flex; align-items:center; gap:14px; }
    .kpi-icon  { width:46px; height:46px; border-radius:12px;
                 display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
    .kpi-val   { font-size:22px; font-weight:700; color:#1a1a1a; line-height:1; }
    .kpi-lbl   { font-size:12px; color:#888780; margin-top:3px; }

    .tour-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; }

    .tour-card {
        background:white; border-radius:14px;
        box-shadow:0 2px 8px rgba(0,0,0,0.07);
        padding:20px; position:relative; overflow:hidden;
        border-left:4px solid #E0E0E0; transition:transform 0.18s, box-shadow 0.18s;
    }
    .tour-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,0.12); }
    .tour-card.recu   { border-left-color:#0F6E56; }
    .tour-card.actuel { border-left-color:#F57F17; background:linear-gradient(135deg,#FFF8F0 0%,white 100%); }

    .rang-badge {
        position:absolute; top:14px; right:14px;
        width:34px; height:34px; border-radius:50%;
        display:flex; align-items:center; justify-content:center;
        font-size:14px; font-weight:800;
    }
    .rang-badge.recu   { background:#E1F5EE; color:#0F6E56; }
    .rang-badge.actuel { background:#FFF3E0; color:#F57F17; }
    .rang-badge.attente{ background:#F4F2EB; color:#888780; }

    .membre-photo {
        width:48px; height:48px; border-radius:50%; object-fit:cover;
        border:2px solid #E1F5EE; margin-bottom:10px;
    }
    .membre-initiales {
        width:48px; height:48px; border-radius:50%;
        background:#0F6E56; color:white;
        display:flex; align-items:center; justify-content:center;
        font-size:18px; font-weight:700; margin-bottom:10px; flex-shrink:0;
    }
    .statut-pill {
        display:inline-flex; align-items:center; gap:5px;
        padding:4px 12px; border-radius:20px;
        font-size:11px; font-weight:700;
    }
    .pill-recu   { background:#E1F5EE; color:#0F6E56; }
    .pill-actuel { background:#FFF3E0; color:#F57F17; }
    .pill-attente{ background:#F4F2EB; color:#888780; }

    .progress-bar-wrap { background:#F4F2EB; border-radius:8px; height:8px; margin:16px 0 8px; overflow:hidden; }
    .progress-bar-fill { background:linear-gradient(90deg,#0F6E56,#1A8C6E); height:100%; border-radius:8px; transition:width 0.6s ease; }
</style>

<div style="background-image:url('/photo/cotisations.png');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,35,126,0.88) 0%,rgba(40,53,147,0.82) 60%,rgba(57,73,171,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Tontine - Organisation</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Tableau des tours</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">Qui reçoit la mise et quand</p>
    </div>
</div>

<!-- Sélecteur tontine + retour -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
    <div style="display:flex;align-items:center;gap:10px;">
        <label style="font-size:13px;font-weight:600;color:#444;">Tontine :</label>
        <select id="sel-tontine" onchange="changerTontine(this.value)"
                style="padding:8px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:13px;background:white;outline:none;">
            @foreach (var t in tontines)
            {
                <option value="@t.IdTontine" selected="@(t.IdTontine == idTontine ? "selected" : null)">@t.Libelle</option>
            }
        </select>
    </div>
    <a asp-action="Index" style="color:#0F6E56;font-size:13px;font-weight:500;text-decoration:none;">← Retour aux cotisations</a>
</div>

<!-- KPIs -->
<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-icon" style="background:#E1F5EE;color:#0F6E56;">✅</div>
        <div><div class="kpi-val">@recu</div><div class="kpi-lbl">Ont déjà reçu</div></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:#FFF3E0;color:#F57F17;">⏳</div>
        <div><div class="kpi-val">@(total - recu)</div><div class="kpi-lbl">En attente de tour</div></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:#E3F2FD;color:#1565C0;">👥</div>
        <div><div class="kpi-val">@total</div><div class="kpi-lbl">Membres au total</div></div>
    </div>
</div>

<!-- Barre de progression -->
@if (total > 0)
{
    var pct = (int)Math.Round((double)recu / total * 100);
    <div style="background:white;border-radius:12px;padding:18px 24px;margin-bottom:24px;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="font-size:13px;font-weight:600;color:#333;">Progression du cycle</span>
            <span style="font-size:13px;font-weight:700;color:#0F6E56;">@recu / @total membres</span>
        </div>
        <div class="progress-bar-wrap">
            <div class="progress-bar-fill" style="width:@(pct)%;"></div>
        </div>
        <div style="font-size:11px;color:#888780;text-align:right;margin-top:4px;">@pct% du cycle effectué</div>
    </div>
}

<!-- Grille des tours -->
<div class="tour-grid" id="tour-grid">
    @if (!Model.Any())
    {
        <div style="grid-column:1/-1;text-align:center;padding:60px;color:#888780;font-size:15px;">
            Aucun membre inscrit à cette tontine pour ce cycle.
        </div>
    }
    @foreach (var t in Model)
    {
        var cardClass = t.ARecu ? "recu" : (t == enCours ? "actuel" : "");
        var rangClass = t.ARecu ? "recu" : (t == enCours ? "actuel" : "attente");
        var pillClass = t.ARecu ? "pill-recu" : (t == enCours ? "pill-actuel" : "pill-attente");
        var statutLabel = t.ARecu ? "✓ Reçu" : (t == enCours ? "▶ Tour suivant" : "En attente");
        var initiales = string.Join("", t.NomMembre.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

        <div class="tour-card @cardClass">
            <div class="rang-badge @rangClass">#@t.Rang</div>
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                @if (!string.IsNullOrEmpty(t.PhotoUrl))
                {
                    <img src="@t.PhotoUrl" class="membre-photo" alt="@t.NomMembre" />
                }
                else
                {
                    <div class="membre-initiales">@initiales</div>
                }
                <div>
                    <div style="font-size:15px;font-weight:700;color:#1a1a1a;">@t.NomMembre</div>
                    @if (!string.IsNullOrEmpty(t.Matricule))
                    {
                        <div style="font-size:11px;color:#888780;font-weight:500;">@t.Matricule</div>
                    }
                </div>
            </div>

            <span class="statut-pill @pillClass">@statutLabel</span>

            @if (t.ARecu && t.DateVersement.HasValue)
            {
                <div style="margin-top:12px;padding:10px;background:#F0FAF6;border-radius:8px;font-size:12px;">
                    <div style="color:#888780;margin-bottom:2px;">Date du versement</div>
                    <div style="font-weight:700;color:#0F6E56;">@t.DateVersement.Value.ToString("dd MMMM yyyy")</div>
                    @if (t.MontantVerse.HasValue)
                    {
                        <div style="font-weight:600;color:#1A8C6E;margin-top:2px;">@t.MontantVerse.Value.ToString("N0") FCFA</div>
                    }
                </div>
            }
            @if (t == enCours && !t.ARecu)
            {
                <div style="margin-top:12px;padding:10px;background:#FFF8F0;border-radius:8px;font-size:12px;border:1px dashed #FFD600;">
                    <div style="color:#F57F17;font-weight:700;">⭐ Prochain bénéficiaire</div>
                    <div style="color:#888780;margin-top:2px;">En attente du versement</div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
function changerTontine(idTontine) {
    fetch('@Url.Action("ToursData", "Cotisation")?idTontine=' + idTontine)
        .then(r => r.json())
        .then(data => {
            renderTours(data);
        });
}

function renderTours(tours) {
    var grid = document.getElementById('tour-grid');
    if (!tours || tours.length === 0) {
        grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:#888780;font-size:15px;">Aucun membre inscrit.</div>';
        return;
    }
    var enCours = tours.find(t => !t.aRecu);
    grid.innerHTML = tours.map(function(t) {
        var isActuel = !t.aRecu && t === enCours;
        var cardClass = t.aRecu ? 'recu' : (isActuel ? 'actuel' : '');
        var rangClass = t.aRecu ? 'recu' : (isActuel ? 'actuel' : 'attente');
        var pillClass = t.aRecu ? 'pill-recu' : (isActuel ? 'pill-actuel' : 'pill-attente');
        var label    = t.aRecu ? '✓ Reçu' : (isActuel ? '▶ Tour suivant' : 'En attente');
        var init     = (t.nomMembre || '').split(' ').slice(0,2).map(function(w){ return w[0] || ''; }).join('').toUpperCase();
        var photoEl  = t.photoUrl
            ? '<img src="' + t.photoUrl + '" class="membre-photo" />'
            : '<div class="membre-initiales">' + init + '</div>';
        var versInfo = '';
        if (t.aRecu && t.dateVersement) {
            versInfo = '<div style="margin-top:12px;padding:10px;background:#F0FAF6;border-radius:8px;font-size:12px;"><div style="color:#888780;">Date du versement</div><div style="font-weight:700;color:#0F6E56;">' + new Date(t.dateVersement).toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'}) + '</div>' + (t.montantVerse ? '<div style="font-weight:600;color:#1A8C6E;">' + Number(t.montantVerse).toLocaleString('fr-FR') + ' FCFA</div>' : '') + '</div>';
        }
        if (isActuel) {
            versInfo = '<div style="margin-top:12px;padding:10px;background:#FFF8F0;border-radius:8px;font-size:12px;border:1px dashed #FFD600;"><div style="color:#F57F17;font-weight:700;">⭐ Prochain bénéficiaire</div><div style="color:#888780;margin-top:2px;">En attente du versement</div></div>';
        }
        return '<div class="tour-card ' + cardClass + '"><div class="rang-badge ' + rangClass + '">#' + t.rang + '</div><div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">' + photoEl + '<div><div style="font-size:15px;font-weight:700;">' + t.nomMembre + '</div>' + (t.matricule ? '<div style="font-size:11px;color:#888780;">' + t.matricule + '</div>' : '') + '</div></div><span class="statut-pill ' + pillClass + '">' + label + '</span>' + versInfo + '</div>';
    }).join('');
}
</script>
}
