@{ ViewData["Title"] = "Transfert de caisse"; }

<style>
    .compta-header { background:linear-gradient(135deg,#1A237E,#3949AB);margin:-26px -28px 24px -28px;
                     padding:24px 36px;display:flex;flex-direction:column;justify-content:flex-end; }
    .card { background:white;border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,.08);padding:28px; }
    .tab-btn { padding:9px 22px;border-radius:8px 8px 0 0;font-size:13px;font-weight:600;cursor:pointer;
               border:none;transition:all .15s; }
    .tab-btn.active { background:#1A237E;color:white; }
    .tab-btn:not(.active) { background:#EEF2FF;color:#3949AB; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .field-row { display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap; }
    .field-grp { display:flex;flex-direction:column;gap:5px; }
    .field-grp label { font-size:12px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.4px; }
    .field-grp input,.field-grp select { padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none; }
    .field-grp input:focus,.field-grp select:focus { border-color:#1A237E; }
    .billetage-grid { display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:16px; }
    .billet-tbl { width:100%;border-collapse:collapse; }
    .billet-tbl th { background:#F5F5F5;padding:7px 10px;font-size:11px;font-weight:700;text-transform:uppercase;color:#555;border-bottom:2px solid #E0E0E0; }
    .billet-tbl td { padding:5px 8px;border-bottom:1px solid #F0F0F0; }
    .billet-tbl td label { font-size:13px;color:#444; }
    .billet-tbl td input { width:90px;padding:6px 10px;border:1.5px solid #E0E0E0;border-radius:6px;font-size:13px;text-align:right; }
    .billet-tbl td .sous-total { width:110px;padding:6px 10px;border:none;background:#F9F9F9;border-radius:6px;font-size:13px;text-align:right;font-weight:600; }
    .total-billet-row td { font-weight:700;background:#EEF2FF;padding:8px 10px;font-size:13px; }
    .btn-verif  { background:#1565C0;color:white;border:none;border-radius:10px;padding:10px 22px;font-size:13px;font-weight:700;cursor:pointer; }
    .btn-enreg  { background:linear-gradient(135deg,#1B5E20,#388E3C);color:white;border:none;border-radius:10px;padding:10px 24px;font-size:13px;font-weight:700;cursor:pointer; }
    .btn-fermer { background:#757575;color:white;border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer; }
    .grid-valider { width:100%;border-collapse:collapse; }
    .grid-valider th { background:#F5F5F5;padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#444;border-bottom:2px solid #E0E0E0; }
    .grid-valider td { padding:10px 12px;border-bottom:1px solid #F0F0F0;font-size:13px; }
    .alert-msg { border-radius:8px;padding:12px 16px;font-size:13px;display:none;margin-bottom:16px; }
</style>

<div class="compta-header">
    <div style="font-size:11px;color:rgba(255,255,255,.6);font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;">Comptabilité OHADA</div>
    <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px;">Transfert de caisse</h2>
    <p style="color:rgba(255,255,255,.8);font-size:14px;margin:0;">Mouvements entre comptes de trésorerie</p>
</div>

<div style="display:flex;gap:4px;margin-bottom:0;">
    <button class="tab-btn active" onclick="switchTab('initier')">Initier le transfert de caisse</button>
    <button class="tab-btn" onclick="switchTab('valider')">Valider le transfert de caisse</button>
</div>

<div class="card" style="border-radius:0 14px 14px 14px;">
    <div id="alert-msg" class="alert-msg"></div>

    <!-- ── Onglet Initier ── -->
    <div id="tab-initier" class="tab-panel active">
        <div style="font-weight:700;font-size:14px;color:#1A237E;margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid #EEF2FF;">Détail opération</div>
        <div class="field-row">
            <div class="field-grp" style="flex:1;min-width:200px;">
                <label>Caisse départ</label>
                <select id="caisseDepart" onchange="updateLibelles()">
                    <option value="571001">571001 — Caisse espèces</option>
                    <option value="521001">521001 — Banque séquestre</option>
                    <option value="521002">521002 — Banque propre</option>
                    <option value="521100">521100 — Wallet MTN</option>
                    <option value="521200">521200 — Wallet Orange Money</option>
                </select>
            </div>
            <div class="field-grp" style="width:200px;">
                <label>Date du jour</label>
                <input type="date" id="dateOp" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="field-row">
            <div class="field-grp" style="flex:1;min-width:200px;">
                <label>Caisse destinatrice</label>
                <select id="caisseDestination" onchange="updateLibelles()">
                    <option value="521100">521100 — Wallet MTN</option>
                    <option value="521200">521200 — Wallet Orange Money</option>
                    <option value="521001">521001 — Banque séquestre</option>
                    <option value="521002">521002 — Banque propre</option>
                    <option value="571001">571001 — Caisse espèces</option>
                </select>
            </div>
        </div>
        <div class="field-row">
            <div class="field-grp" style="width:180px;"><label>Montant</label><input type="number" id="montant" placeholder="0" step="1" oninput="calcBilletage()" /></div>
            <div class="field-grp" style="width:160px;"><label>Num pièce</label><input type="text" id="numPiece" placeholder="TRF-001" /></div>
            <div class="field-grp" style="flex:1;min-width:200px;"><label>Motif</label><input type="text" id="motif" placeholder="Motif du transfert" /></div>
        </div>

        <div style="font-weight:700;font-size:14px;color:#1A237E;margin:20px 0 12px;padding-bottom:8px;border-bottom:2px solid #EEF2FF;">Billetage</div>
        <div class="billetage-grid">
            <div>
                <table class="billet-tbl">
                    <thead><tr><th>Coupure</th><th>Quantité</th><th>Sous-total</th></tr></thead>
                    <tbody>
                        <tr><td><label>Billet de 10 000</label></td><td><input type="number" class="qte-billet" data-val="10000" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total" data-val="10000" readonly value="0" /></td></tr>
                        <tr><td><label>Billet de 5 000</label></td><td><input type="number" class="qte-billet" data-val="5000" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total" data-val="5000" readonly value="0" /></td></tr>
                        <tr><td><label>Billet de 2 000</label></td><td><input type="number" class="qte-billet" data-val="2000" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total" data-val="2000" readonly value="0" /></td></tr>
                        <tr><td><label>Billet de 1 000</label></td><td><input type="number" class="qte-billet" data-val="1000" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total" data-val="1000" readonly value="0" /></td></tr>
                        <tr><td><label>Billet de 500</label></td><td><input type="number" class="qte-billet" data-val="500" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total" data-val="500" readonly value="0" /></td></tr>
                        <tr class="total-billet-row"><td colspan="2">Total billet :</td><td><input id="total-billet" class="sous-total" readonly value="0" /></td></tr>
                    </tbody>
                </table>
            </div>
            <div>
                <table class="billet-tbl">
                    <thead><tr><th>Coupure</th><th>Quantité</th><th>Sous-total</th></tr></thead>
                    <tbody>
                        <tr><td><label>Pièce de 500</label></td><td><input type="number" class="qte-piece" data-val="500" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="500" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 100</label></td><td><input type="number" class="qte-piece" data-val="100" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="100" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 50</label></td><td><input type="number" class="qte-piece" data-val="50" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="50" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 25</label></td><td><input type="number" class="qte-piece" data-val="25" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="25" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 10</label></td><td><input type="number" class="qte-piece" data-val="10" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="10" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 5</label></td><td><input type="number" class="qte-piece" data-val="5" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="5" readonly value="0" /></td></tr>
                        <tr><td><label>Pièce de 1</label></td><td><input type="number" class="qte-piece" data-val="1" placeholder="0" oninput="calcBilletage()" /></td><td><input class="sous-total-p" data-val="1" readonly value="0" /></td></tr>
                        <tr class="total-billet-row"><td colspan="2">Total pièces :</td><td><input id="total-pieces" class="sous-total" readonly value="0" /></td></tr>
                    </tbody>
                </table>
                <div style="text-align:right;margin-top:10px;">
                    <button type="button" onclick="calcTotal()" style="background:#1A237E;color:white;border:none;border-radius:8px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Calculer Total</button>
                </div>
            </div>
        </div>

        <div id="zone-info" style="background:#F5F5F5;border-radius:8px;padding:12px 16px;margin-top:16px;font-size:13px;color:#555;min-height:44px;"></div>

        <hr style="margin:20px 0;border:1px solid #EEF2FF;" />
        <div style="display:flex;gap:12px;">
            <button class="btn-verif"  onclick="verifier()">Vérification</button>
            <button class="btn-enreg"  onclick="enregistrer()">Enregistrer</button>
            <button class="btn-fermer" onclick="window.location.href='@Url.Action("Journal","GrandLivre")'">Fermer</button>
        </div>
    </div>

    <!-- ── Onglet Valider ── -->
    <div id="tab-valider" class="tab-panel">
        <p style="color:#888;font-size:13px;margin-bottom:16px;">Transferts en attente de validation :</p>
        <table class="grid-valider">
            <thead><tr>
                <th>Date opération</th><th>Caisse départ</th><th>Caisse destinatrice</th><th style="text-align:right;">Montant</th>
            </tr></thead>
            <tbody id="body-valider">
                <tr><td colspan="4" style="text-align:center;color:#aaa;padding:30px;">Aucun transfert en attente</td></tr>
            </tbody>
        </table>
        <div style="margin-top:20px;display:flex;gap:12px;">
            <button class="btn-fermer" onclick="window.location.href='@Url.Action("Journal","GrandLivre")'">Fermer</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
var libelles = {
    '571001':'Caisse espèces','521001':'Banque séquestre','521002':'Banque propre',
    '521100':'Wallet MTN Mobile Money','521200':'Wallet Orange Money'
};

function switchTab(tab) {
    ['initier','valider'].forEach(t => {
        document.getElementById('tab-'+t).classList.toggle('active', t===tab);
    });
    document.querySelectorAll('.tab-btn').forEach((b,i) =>
        b.classList.toggle('active', (i===0&&tab==='initier')||(i===1&&tab==='valider')));
}

function updateLibelles() {}

function calcBilletage() {
    var tb = 0;
    document.querySelectorAll('.qte-billet').forEach(inp => {
        var v = parseInt(inp.value)||0, d = parseInt(inp.dataset.val)||0, st = v*d;
        inp.closest('tr').querySelector('.sous-total').value = st.toLocaleString('fr-FR');
        tb += st;
    });
    document.getElementById('total-billet').value = tb.toLocaleString('fr-FR');

    var tp = 0;
    document.querySelectorAll('.qte-piece').forEach(inp => {
        var v = parseInt(inp.value)||0, d = parseInt(inp.dataset.val)||0, st = v*d;
        inp.closest('tr').querySelector('.sous-total-p').value = st.toLocaleString('fr-FR');
        tp += st;
    });
    document.getElementById('total-pieces').value = tp.toLocaleString('fr-FR');
}

function calcTotal() {
    calcBilletage();
    var tb = [...document.querySelectorAll('.qte-billet')].reduce((s,i)=>{return s+(parseInt(i.value)||0)*(parseInt(i.dataset.val)||0);},0);
    var tp = [...document.querySelectorAll('.qte-piece')].reduce((s,i)=>{return s+(parseInt(i.value)||0)*(parseInt(i.dataset.val)||0);},0);
    document.getElementById('montant').value = tb + tp;
    document.getElementById('zone-info').textContent = 'Total billetage : ' + (tb+tp).toLocaleString('fr-FR') + ' FCFA';
}

function verifier() {
    var dep = document.getElementById('caisseDepart').value;
    var dst = document.getElementById('caisseDestination').value;
    var mnt = parseFloat(document.getElementById('montant').value)||0;
    var info = document.getElementById('zone-info');
    if (dep === dst) { info.textContent = '⚠ Caisse départ et destination identiques.'; info.style.color='#B71C1C'; return; }
    if (mnt <= 0)   { info.textContent = '⚠ Montant invalide.'; info.style.color='#B71C1C'; return; }
    info.style.color = '#1B5E20';
    info.textContent = '✓ Vérification OK — ' + mnt.toLocaleString('fr-FR') + ' FCFA de ' + (libelles[dep]||dep) + ' vers ' + (libelles[dst]||dst);
}

function showAlert(type, msg) {
    var el = document.getElementById('alert-msg');
    el.style.background = type==='ok' ? '#E8F5E9' : '#FFEBEE';
    el.style.border     = '1px solid ' + (type==='ok' ? '#C8E6C9' : '#FFCDD2');
    el.style.color      = type==='ok' ? '#1B5E20' : '#B71C1C';
    el.textContent = msg; el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 6000);
}

async function enregistrer() {
    var dep  = document.getElementById('caisseDepart').value;
    var dst  = document.getElementById('caisseDestination').value;
    var mnt  = parseFloat(document.getElementById('montant').value)||0;
    if (dep===dst || mnt<=0) { verifier(); return; }

    var payload = {
        compteDepart: dep, libelleDepart: libelles[dep]||dep,
        compteDestination: dst, libelleDestination: libelles[dst]||dst,
        montant: mnt,
        dateOperation: document.getElementById('dateOp').value,
        numPiece: document.getElementById('numPiece').value || null,
        motif: document.getElementById('motif').value || null
    };

    var r = await fetch('@Url.Action("TransfertCaissePost","GrandLivre")', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify(payload)
    });
    if (r.ok) {
        var d = await r.json();
        showAlert('ok', 'Transfert enregistré — écriture N°' + d.idEcriture);
    } else {
        var msg = await r.text(); showAlert('err', msg || 'Erreur lors du transfert.');
    }
}
</script>
}
