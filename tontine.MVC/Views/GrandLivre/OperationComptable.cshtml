@{ ViewData["Title"] = "Saisie d'écriture comptable"; }

<style>
    .compta-header { background:linear-gradient(135deg,#1A237E,#3949AB);margin:-26px -28px 24px -28px;
                     padding:24px 36px;display:flex;flex-direction:column;justify-content:flex-end; }
    .card { background:white;border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,.08);padding:28px; }
    .tab-btn { padding:9px 20px;border-radius:8px 8px 0 0;font-size:13px;font-weight:600;cursor:pointer;
               border:none;transition:all .15s; }
    .tab-btn.active { background:#1A237E;color:white; }
    .tab-btn:not(.active) { background:#EEF2FF;color:#3949AB; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .grid-lignes { width:100%;border-collapse:collapse; }
    .grid-lignes th { background:#F5F5F5;padding:9px 10px;font-size:11px;font-weight:700;color:#444;
                      text-align:left;text-transform:uppercase;border-bottom:2px solid #E0E0E0; }
    .grid-lignes td { padding:6px 6px; }
    .grid-lignes td input,.grid-lignes td select { width:100%;padding:7px 10px;border:1.5px solid #E0E0E0;
        border-radius:6px;font-size:13px;outline:none; }
    .grid-lignes td input:focus,.grid-lignes td select:focus { border-color:#3949AB; }
    .totaux-row td { font-weight:700;background:#F0F4FF;border-top:2px solid #3949AB;padding:8px 10px;font-size:13px; }
    .btn-add { background:#E8F5E9;color:#1B5E20;border:none;border-radius:6px;padding:6px 14px;
               font-size:12px;font-weight:700;cursor:pointer;margin-top:8px; }
    .btn-enreg { background:linear-gradient(135deg,#1B5E20,#388E3C);color:white;border:none;border-radius:10px;
                 padding:12px 32px;font-size:14px;font-weight:700;cursor:pointer; }
    .btn-fermer { background:#757575;color:white;border:none;border-radius:10px;
                  padding:12px 24px;font-size:14px;font-weight:700;cursor:pointer; }
    .alert-err { background:#FFEBEE;border:1px solid #FFCDD2;border-radius:8px;padding:12px 16px;
                 color:#B71C1C;font-size:13px;display:none;margin-bottom:16px; }
    .alert-ok  { background:#E8F5E9;border:1px solid #C8E6C9;border-radius:8px;padding:12px 16px;
                 color:#1B5E20;font-size:13px;display:none;margin-bottom:16px; }
</style>

<div class="compta-header">
    <div style="font-size:11px;color:rgba(255,255,255,.6);font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;">Comptabilité OHADA</div>
    <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px;">Saisie d'écriture comptable</h2>
    <p style="color:rgba(255,255,255,.8);font-size:14px;margin:0;">Partie double — Σ Débits = Σ Crédits</p>
</div>

<!-- En-tête commune -->
<div class="card" style="margin-bottom:20px;">
    <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end;">
        <div>
            <label style="font-size:12px;font-weight:700;color:#555;display:block;margin-bottom:5px;">Date</label>
            <input type="date" id="dateEcriture" value="@DateTime.Now.ToString("yyyy-MM-dd")"
                   style="padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;" />
        </div>
        <div>
            <label style="font-size:12px;font-weight:700;color:#555;display:block;margin-bottom:5px;">Journal</label>
            <select id="codeJournal" style="padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;min-width:180px;">
                <option value="CA">CA - Caisse</option>
                <option value="BQ">BQ - Banque</option>
                <option value="VT">VT - Virements</option>
                <option value="OD" selected>OD - Opérations diverses</option>
            </select>
        </div>
        <div style="flex:1;min-width:200px;">
            <label style="font-size:12px;font-weight:700;color:#555;display:block;margin-bottom:5px;">Libellé de l'écriture</label>
            <input type="text" id="libelle" placeholder="Description de l'opération"
                   style="width:100%;padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;" />
        </div>
        <div>
            <label style="font-size:12px;font-weight:700;color:#555;display:block;margin-bottom:5px;">N° Pièce</label>
            <input type="text" id="piece" placeholder="ex: FAC-001"
                   style="padding:10px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;width:140px;" />
        </div>
        <div style="margin-left:auto;font-size:12px;color:#666;">
            Journal N° : <strong id="journalNum">—</strong>
        </div>
    </div>
</div>

<!-- Onglets Mono / Multi -->
<div style="display:flex;gap:4px;margin-bottom:0;">
    <button class="tab-btn active" onclick="switchTab('mono')">Mono-compte</button>
    <button class="tab-btn" onclick="switchTab('multi')">Multi-compte</button>
</div>

<div class="card" style="border-radius:0 14px 14px 14px;">
    <div id="alert-err" class="alert-err"></div>
    <div id="alert-ok"  class="alert-ok"></div>

    <!-- ── Mono-compte ── -->
    <div id="tab-mono" class="tab-panel active">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
            <!-- Débit -->
            <div>
                <div style="font-weight:700;font-size:13px;color:#C62828;margin-bottom:10px;border-bottom:2px solid #FFCDD2;padding-bottom:6px;">DÉBIT</div>
                <table class="grid-lignes" id="tbl-mono-debit">
                    <thead><tr>
                        <th>N° ligne</th>
                        <th>Compte débité</th>
                        <th>Libellé</th>
                        <th style="text-align:right;">Montant débit</th>
                    </tr></thead>
                    <tbody id="body-mono-debit">
                        <tr>
                            <td style="width:70px;"><input type="text" value="1" readonly style="background:#F9F9F9;text-align:center;" /></td>
                            <td style="width:160px;"><input type="text" class="cpt-debit" placeholder="571001" /></td>
                            <td><input type="text" class="lib-debit" placeholder="Libellé compte" /></td>
                            <td style="width:140px;"><input type="number" class="mnt-debit" placeholder="0" step="1" oninput="calcTotaux()" /></td>
                        </tr>
                    </tbody>
                    <tfoot><tr class="totaux-row">
                        <td colspan="3" style="text-align:right;">Total débit :</td>
                        <td id="total-mono-debit" style="text-align:right;">0</td>
                    </tr></tfoot>
                </table>
            </div>
            <!-- Crédit -->
            <div>
                <div style="font-weight:700;font-size:13px;color:#0F6E56;margin-bottom:10px;border-bottom:2px solid #C8E6C9;padding-bottom:6px;">CRÉDIT</div>
                <table class="grid-lignes" id="tbl-mono-credit">
                    <thead><tr>
                        <th>N° ligne</th>
                        <th>Compte crédité</th>
                        <th>Libellé</th>
                        <th style="text-align:right;">Montant crédit</th>
                    </tr></thead>
                    <tbody id="body-mono-credit">
                        <tr>
                            <td style="width:70px;"><input type="text" value="1" readonly style="background:#F9F9F9;text-align:center;" /></td>
                            <td style="width:160px;"><input type="text" class="cpt-credit" placeholder="4671001" /></td>
                            <td><input type="text" class="lib-credit" placeholder="Libellé compte" /></td>
                            <td style="width:140px;"><input type="number" class="mnt-credit" placeholder="0" step="1" oninput="calcTotaux()" /></td>
                        </tr>
                    </tbody>
                    <tfoot><tr class="totaux-row">
                        <td colspan="3" style="text-align:right;">Total crédit :</td>
                        <td id="total-mono-credit" style="text-align:right;">0</td>
                    </tr></tfoot>
                </table>
            </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;font-size:13px;">
            <span>Équilibre :</span>
            <span id="equilibre-mono" style="font-weight:700;color:#888;">—</span>
        </div>
    </div>

    <!-- ── Multi-compte ── -->
    <div id="tab-multi" class="tab-panel">
        <table class="grid-lignes" style="margin-bottom:8px;">
            <thead><tr>
                <th style="width:50px;">N°</th>
                <th style="width:130px;">Compte</th>
                <th style="width:80px;">Sens</th>
                <th>Libellé compte</th>
                <th>Libellé ligne</th>
                <th style="width:130px;text-align:right;">Montant</th>
                <th style="width:36px;"></th>
            </tr></thead>
            <tbody id="body-multi">
                <tr>
                    <td><input type="text" value="1" readonly style="background:#F9F9F9;text-align:center;width:40px;" /></td>
                    <td><input type="text" class="m-cpt" placeholder="571001" /></td>
                    <td><select class="m-sens" onchange="calcTotaux()"><option value="D">Débit</option><option value="C">Crédit</option></select></td>
                    <td><input type="text" class="m-libcpt" placeholder="Caisse espèces" /></td>
                    <td><input type="text" class="m-liblig" placeholder="Description ligne" /></td>
                    <td><input type="number" class="m-mnt" placeholder="0" step="1" oninput="calcTotaux()" style="text-align:right;" /></td>
                    <td><button type="button" onclick="supprimerLigne(this)" style="background:none;border:none;color:#C62828;font-size:16px;cursor:pointer;">×</button></td>
                </tr>
            </tbody>
        </table>
        <button class="btn-add" onclick="ajouterLigne()">+ Ajouter une ligne</button>

        <div style="display:flex;gap:24px;margin-top:16px;font-size:13px;">
            <span>Total débits : <strong id="total-multi-d" style="color:#C62828;">0</strong></span>
            <span>Total crédits : <strong id="total-multi-c" style="color:#0F6E56;">0</strong></span>
            <span id="equilibre-multi" style="font-weight:700;color:#888;">—</span>
        </div>
    </div>

    <hr style="margin:20px 0;border:1px solid #F0F0F0;" />
    <div style="display:flex;gap:12px;">
        <button class="btn-enreg" onclick="enregistrer()">Enregistrer</button>
        <button class="btn-fermer" onclick="window.location.href='@Url.Action("Journal","GrandLivre")'">Fermer</button>
    </div>
</div>

@section Scripts {
<script>
var modeActif = 'mono';

function switchTab(tab) {
    modeActif = tab;
    document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', (i===0&&tab==='mono')||(i===1&&tab==='multi')));
    document.getElementById('tab-mono').classList.toggle('active', tab==='mono');
    document.getElementById('tab-multi').classList.toggle('active', tab==='multi');
}

function calcTotaux() {
    var td = [...document.querySelectorAll('#body-mono-debit .mnt-debit')].reduce((s,e) => s + (parseFloat(e.value)||0), 0);
    var tc = [...document.querySelectorAll('#body-mono-credit .mnt-credit')].reduce((s,e) => s + (parseFloat(e.value)||0), 0);
    document.getElementById('total-mono-debit').textContent  = td.toLocaleString('fr-FR');
    document.getElementById('total-mono-credit').textContent = tc.toLocaleString('fr-FR');
    var eq = document.getElementById('equilibre-mono');
    if (td > 0 && Math.abs(td-tc) < 0.01) { eq.textContent = '✓ Équilibré'; eq.style.color='#1B5E20'; }
    else { eq.textContent = td > 0 ? '⚠ Déséquilibre : ' + (td-tc).toLocaleString('fr-FR') : '—'; eq.style.color='#C62828'; }

    var md = [...document.querySelectorAll('#body-multi .m-mnt')].reduce((s,e,i) => {
        var sens = document.querySelectorAll('#body-multi .m-sens')[i].value;
        return s + (sens==='D' ? (parseFloat(e.value)||0) : 0);
    }, 0);
    var mc = [...document.querySelectorAll('#body-multi .m-mnt')].reduce((s,e,i) => {
        var sens = document.querySelectorAll('#body-multi .m-sens')[i].value;
        return s + (sens==='C' ? (parseFloat(e.value)||0) : 0);
    }, 0);
    document.getElementById('total-multi-d').textContent = md.toLocaleString('fr-FR');
    document.getElementById('total-multi-c').textContent = mc.toLocaleString('fr-FR');
    var em = document.getElementById('equilibre-multi');
    if (md > 0 && Math.abs(md-mc) < 0.01) { em.textContent = '✓ Équilibré'; em.style.color='#1B5E20'; }
    else { em.textContent = md > 0 ? '⚠ Déséquilibre' : '—'; em.style.color='#C62828'; }
}

function ajouterLigne() {
    var tbody = document.getElementById('body-multi');
    var n = tbody.rows.length + 1;
    var tr = tbody.insertRow();
    tr.innerHTML = `<td><input type="text" value="${n}" readonly style="background:#F9F9F9;text-align:center;width:40px;" /></td>
        <td><input type="text" class="m-cpt" placeholder="571001" /></td>
        <td><select class="m-sens" onchange="calcTotaux()"><option value="D">Débit</option><option value="C">Crédit</option></select></td>
        <td><input type="text" class="m-libcpt" placeholder="Libellé compte" /></td>
        <td><input type="text" class="m-liblig" placeholder="Description" /></td>
        <td><input type="number" class="m-mnt" placeholder="0" step="1" oninput="calcTotaux()" style="text-align:right;" /></td>
        <td><button type="button" onclick="supprimerLigne(this)" style="background:none;border:none;color:#C62828;font-size:16px;cursor:pointer;">×</button></td>`;
}

function supprimerLigne(btn) {
    var tr = btn.closest('tr');
    if (document.getElementById('body-multi').rows.length > 1) { tr.remove(); calcTotaux(); }
}

function showAlert(type, msg) {
    var el = document.getElementById(type === 'ok' ? 'alert-ok' : 'alert-err');
    el.textContent = msg; el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 5000);
}

function buildLignes() {
    if (modeActif === 'mono') {
        var lignes = [];
        document.querySelectorAll('#body-mono-debit tr').forEach(tr => {
            var cpt = tr.querySelector('.cpt-debit')?.value;
            var lib = tr.querySelector('.lib-debit')?.value;
            var mnt = parseFloat(tr.querySelector('.mnt-debit')?.value || 0);
            if (cpt && mnt > 0) lignes.push({ sens:'D', compteOhada:cpt, libelleCompte:lib||cpt, libelleLigne:lib||'Débit', montant:mnt });
        });
        document.querySelectorAll('#body-mono-credit tr').forEach(tr => {
            var cpt = tr.querySelector('.cpt-credit')?.value;
            var lib = tr.querySelector('.lib-credit')?.value;
            var mnt = parseFloat(tr.querySelector('.mnt-credit')?.value || 0);
            if (cpt && mnt > 0) lignes.push({ sens:'C', compteOhada:cpt, libelleCompte:lib||cpt, libelleLigne:lib||'Crédit', montant:mnt });
        });
        return lignes;
    } else {
        var rows = document.querySelectorAll('#body-multi tr');
        var lignes = [];
        rows.forEach((tr,i) => {
            var cpt  = tr.querySelector('.m-cpt')?.value;
            var sens = tr.querySelector('.m-sens')?.value;
            var lc   = tr.querySelector('.m-libcpt')?.value;
            var ll   = tr.querySelector('.m-liblig')?.value;
            var mnt  = parseFloat(tr.querySelector('.m-mnt')?.value || 0);
            if (cpt && mnt > 0) lignes.push({ sens, compteOhada:cpt, libelleCompte:lc||cpt, libelleLigne:ll||sens, montant:mnt });
        });
        return lignes;
    }
}

async function enregistrer() {
    var lignes = buildLignes();
    if (lignes.length < 2) { showAlert('err','Au moins 2 lignes requises.'); return; }
    var totalD = lignes.filter(l=>l.sens==='D').reduce((s,l)=>s+l.montant,0);
    var totalC = lignes.filter(l=>l.sens==='C').reduce((s,l)=>s+l.montant,0);
    if (Math.abs(totalD-totalC) > 0.01) { showAlert('err','Déséquilibre : Débits='+totalD.toFixed(0)+' Crédits='+totalC.toFixed(0)); return; }

    var payload = {
        codeJournal: document.getElementById('codeJournal').value,
        dateEcriture: document.getElementById('dateEcriture').value,
        pieceJustificative: document.getElementById('piece').value || 'OD-'+Date.now(),
        libelle: document.getElementById('libelle').value || 'Écriture manuelle',
        lignes
    };

    var r = await fetch('@Url.Action("OperationComptable","GrandLivre")', {
        method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value||''},
        body: JSON.stringify(payload)
    });
    if (r.ok) {
        var d = await r.json();
        document.getElementById('journalNum').textContent = d.idEcriture;
        showAlert('ok', 'Écriture N°' + d.idEcriture + ' enregistrée avec succès.');
    } else {
        var msg = await r.text(); showAlert('err', msg || 'Erreur lors de l\'enregistrement.');
    }
}
</script>
}
