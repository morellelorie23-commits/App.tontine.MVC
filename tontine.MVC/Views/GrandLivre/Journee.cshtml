@model tontine.MVC.Models.JourneeComptableViewModel?
@{ ViewData["Title"] = "Journée comptable"; }

<style>
    .compta-header { background:linear-gradient(135deg,#1A237E,#3949AB);margin:-26px -28px 24px -28px;
                     padding:24px 36px;display:flex;flex-direction:column;justify-content:flex-end; }
    .card { background:white;border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,.08);padding:32px; }
    .field-label { font-size:12px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px; }
    .field-val { font-size:22px;font-weight:800;color:#1a1a1a; }
    .badge-ouverte { background:#E8F5E9;color:#1B5E20;padding:5px 14px;border-radius:20px;font-size:13px;font-weight:700; }
    .badge-fermee  { background:#FFEBEE;color:#B71C1C;padding:5px 14px;border-radius:20px;font-size:13px;font-weight:700; }
    .badge-aucune  { background:#F5F5F5;color:#757575;padding:5px 14px;border-radius:20px;font-size:13px;font-weight:700; }
    .btn-ouvrir { background:linear-gradient(135deg,#1B5E20,#388E3C);color:white;border:none;border-radius:10px;
                  padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .2s; }
    .btn-fermer { background:linear-gradient(135deg,#B71C1C,#D32F2F);color:white;border:none;border-radius:10px;
                  padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .2s; }
    .btn-ouvrir:hover,.btn-fermer:hover { opacity:.88; }
</style>

<div class="compta-header">
    <div style="font-size:11px;color:rgba(255,255,255,.6);font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;">Comptabilité OHADA</div>
    <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px;">Journée comptable</h2>
    <p style="color:rgba(255,255,255,.8);font-size:14px;margin:0;">Ouverture et fermeture des journées comptables</p>
</div>

<div class="card" style="max-width:620px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:32px;">
        <div style="font-size:13px;color:#888;margin-bottom:8px;">Journée ouverte :</div>
        @if (Model != null && Model.Statut == "Ouverte")
        {
            <span class="badge-ouverte" style="font-size:16px;padding:8px 24px;">
                @Model.DateJournee.ToString("dd/MM/yyyy")
            </span>
        }
        else
        {
            <span class="badge-aucune" style="font-size:14px;padding:8px 24px;">Aucune journée ouverte</span>
        }
    </div>

    @if (Model != null && Model.Statut == "Ouverte")
    {
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;">
            <div>
                <div class="field-label">Date journée</div>
                <div class="field-val">@Model.DateJournee.ToString("dd/MM/yyyy")</div>
            </div>
            <div>
                <div class="field-label">Statut</div>
                <div><span class="badge-ouverte">Ouverte</span></div>
            </div>
            <div>
                <div class="field-label">Ouverture</div>
                <div style="font-size:14px;color:#444;">@Model.DateOuverture.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div>
                <div class="field-label">Ouvert par</div>
                <div style="font-size:14px;color:#444;">@Model.OuvertPar</div>
            </div>
        </div>

        <div style="display:flex;gap:12px;justify-content:center;">
            <form asp-action="FermerJournee" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn-fermer"
                        onclick="return confirm('Fermer la journée du @Model.DateJournee.ToString("dd/MM/yyyy") ?')">
                    Fermer la journée
                </button>
            </form>
        </div>
    }
    else
    {
        <form asp-action="OuvrirJournee" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:20px;">
                <label class="field-label" for="dateJournee">Date de la journée à ouvrir</label>
                <input type="date" id="dateJournee" name="dateJournee"
                       value="@DateTime.Now.ToString("yyyy-MM-dd")"
                       style="width:100%;padding:12px 16px;border:1.5px solid #E0E0E0;border-radius:10px;font-size:15px;" />
            </div>
            <div style="display:flex;justify-content:center;">
                <button type="submit" class="btn-ouvrir">Ouvrir la journée</button>
            </div>
        </form>
    }
</div>
