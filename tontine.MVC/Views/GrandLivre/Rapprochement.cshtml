@model tontine.MVC.Models.RapprochementViewModel
@{
    ViewData["Title"] = "Rapprochement bancaire";
    var tontines  = ViewBag.Tontines as List<tontine.MVC.Models.TontineViewModel> ?? new();
    int idTontine = ViewBag.IdTontine ?? 0;
}

<style>
    .card { background:white;border-radius:12px;padding:24px 28px;box-shadow:0 1px 4px rgba(0,0,0,.07); }
    .row2 { display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px; }
    .ligne-rapp { display:flex;justify-content:space-between;align-items:center;
                  padding:10px 0;border-bottom:1px solid #F4F4F2;font-size:13px; }
    .ligne-rapp:last-child { border-bottom:none; }
    .label { color:#555;font-weight:500; }
    .val { font-weight:700;font-size:14px; }
    .val.pos { color:#0F6E56; }
    .val.neg { color:#C62828; }
    .val.neutral { color:#1565C0; }
    .section-title { font-size:11px;font-weight:700;color:#888;text-transform:uppercase;
                     letter-spacing:.8px;margin-bottom:14px; }
    .status-box { border-radius:10px;padding:16px 20px;margin-bottom:20px; }
</style>

<div style="background:linear-gradient(135deg,#6A1B9A 0%,#8E24AA 100%);
            margin:-26px -28px 24px -28px;padding:24px 36px;min-height:80px;
            display:flex;flex-direction:column;justify-content:flex-end;">
    <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px;">Rapprochement bancaire</h2>
    <p style="color:rgba(255,255,255,.8);font-size:14px;margin:0;">
        Vérification de cohérence entre le livre comptable et le relevé bancaire
    </p>
</div>

<!-- Sélecteur tontine + solde banque -->
<form method="get" asp-action="Rapprochement" asp-controller="GrandLivre"
      style="display:flex;align-items:flex-end;gap:16px;margin-bottom:20px;flex-wrap:wrap;">
    <div>
        <label style="font-size:13px;font-weight:600;color:#444;display:block;margin-bottom:6px;">Tontine :</label>
        <select name="idTontine" style="padding:8px 12px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:13px;background:white;">
            @foreach (var t in tontines)
            {
                <option value="@t.IdTontine" selected="@(t.IdTontine == idTontine ? "selected" : null)">@t.Libelle</option>
            }
        </select>
    </div>
    <div>
        <label style="font-size:13px;font-weight:600;color:#444;display:block;margin-bottom:6px;">
            Solde réel banque (FCFA) :
        </label>
        <input type="number" name="soldeReelBanque" value="@ViewBag.SoldeReelBanque"
               placeholder="Saisir le solde du relevé"
               style="padding:8px 12px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:13px;width:220px;" />
    </div>
    <button type="submit"
            style="padding:9px 20px;background:#6A1B9A;color:white;border:none;border-radius:8px;
                   font-size:13px;font-weight:600;cursor:pointer;">
        Calculer
    </button>
    <a asp-controller="GrandLivre" asp-action="Index"
       style="color:#0F6E56;font-size:13px;font-weight:500;text-decoration:none;align-self:center;">
        ← Grand Livre
    </a>
</form>

<!-- Bandeau statut équilibre interne -->
@{
    var eq = Model.Equilibre;
}
<div class="status-box" style="background:@(eq ? "#E8F5E9" : "#FFEBEE");border-left:4px solid @(eq ? "#388E3C" : "#C62828");">
    <div style="font-size:14px;font-weight:700;color:@(eq ? "#1B5E20" : "#B71C1C");">
        @(eq ? "✓ Équilibre interne confirmé" : "⚠ Déséquilibre interne détecté")
    </div>
    <div style="font-size:13px;color:#666;margin-top:4px;">
        Solde livre comptable : <strong>@Model.SoldeLivreComptable.ToString("N0") FCFA</strong> -
        Solde transactions : <strong>@Model.SoldeTransactions.ToString("N0") FCFA</strong> -
        Écart interne : <strong>@Model.EcartInterne.ToString("N0") FCFA</strong>
    </div>
</div>

<div class="row2">
    <!-- Livre comptable -->
    <div class="card">
        <div class="section-title">Livre comptable - @Model.CompteSequestre</div>

        <div class="ligne-rapp">
            <span class="label">Total cotisations reçues</span>
            <span class="val pos">@Model.TotalCotisations.ToString("N0") FCFA</span>
        </div>
        <div class="ligne-rapp">
            <span class="label">Total versements effectués</span>
            <span class="val neg">@Model.TotalVersements.ToString("N0") FCFA</span>
        </div>
        <div class="ligne-rapp" style="margin-top:8px;padding-top:12px;border-top:2px solid #E0E0E0;">
            <span class="label" style="font-weight:700;">Solde livre comptable</span>
            <span class="val @(Model.SoldeLivreComptable >= 0 ? "pos" : "neg")" style="font-size:18px;">
                @Model.SoldeLivreComptable.ToString("N0") FCFA
            </span>
        </div>
    </div>

    <!-- Rapprochement banque -->
    <div class="card">
        <div class="section-title">Rapprochement avec relevé bancaire</div>

        @if (Model.SoldeReelBanque.HasValue)
        {
            <div class="ligne-rapp">
                <span class="label">Solde relevé bancaire</span>
                <span class="val neutral">@Model.SoldeReelBanque.Value.ToString("N0") FCFA</span>
            </div>
            <div class="ligne-rapp">
                <span class="label">Solde livre comptable</span>
                <span class="val @(Model.SoldeLivreComptable >= 0 ? "pos" : "neg")">@Model.SoldeLivreComptable.ToString("N0") FCFA</span>
            </div>
            <div class="ligne-rapp" style="margin-top:8px;padding-top:12px;border-top:2px solid #E0E0E0;">
                <span class="label" style="font-weight:700;">Écart relevé / livre</span>
                @{
                    var ecartB = Model.EcartBanque ?? 0;
                }
                <span class="val @(Math.Abs(ecartB) < 1 ? "pos" : "neg")" style="font-size:18px;">
                    @ecartB.ToString("N0") FCFA
                    @(Math.Abs(ecartB) < 1 ? " ✓" : " ⚠")
                </span>
            </div>
            @if (Math.Abs(ecartB) >= 1)
            {
                <div style="margin-top:14px;background:#FFF3E0;border-radius:8px;padding:12px 14px;font-size:12px;color:#E65100;">
                    <strong>Action requise :</strong> Vérifiez les transactions en attente, les frais bancaires
                    non comptabilisés, ou les erreurs de saisie.
                </div>
            }
        }
        else
        {
            <div style="text-align:center;padding:32px;color:#888780;font-size:13px;">
                Saisissez le solde du relevé bancaire<br/>
                pour calculer l'écart de rapprochement.
            </div>
        }
    </div>
</div>

<!-- Explication OHADA -->
<div class="card" style="border-top:3px solid #6A1B9A;">
    <div class="section-title">Règles OHADA applicables</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;font-size:13px;">
        <div>
            <div style="font-weight:700;color:#6A1B9A;margin-bottom:4px;">Compte séquestre</div>
            <div style="color:#555;">@Model.CompteSequestre - Fonds membres, non disponibles pour l'opérateur.</div>
        </div>
        <div>
            <div style="font-weight:700;color:#0F6E56;margin-bottom:4px;">Principe de séparation</div>
            <div style="color:#555;">Les fonds de la tontine sont distincts des fonds propres de l'opérateur (COBAC).</div>
        </div>
        <div>
            <div style="font-weight:700;color:#1565C0;margin-bottom:4px;">Fréquence rapprochement</div>
            <div style="color:#555;">Rapprochement mensuel obligatoire. Archiver le relevé bancaire correspondant.</div>
        </div>
    </div>
</div>
