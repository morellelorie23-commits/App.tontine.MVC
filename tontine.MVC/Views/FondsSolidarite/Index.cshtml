@model List<tontine.MVC.Models.FondsSolidariteViewModel>
@{
    ViewData["Title"] = "Fonds de solidarité";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Fonds de solidarité</h2>
        <p class="page-subtitle">Gérez les fonds d'entraide pour ce cycle</p>
    </div>
    <a asp-action="Create" class="btn-primary-tontine">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nouveau fonds
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5">
        <div style="font-size:64px;margin-bottom:16px;">💚</div>
        <h4 style="color:#374151;">Aucun fonds de solidarité</h4>
        <p style="color:#6B7280;">Créez un fonds pour permettre aux membres de s'entraider.</p>
        <a asp-action="Create" class="btn-primary-tontine mt-3">Créer un fonds</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var f in Model)
        {
            var pct = f.TotalCollecte > 0 ? (int)(f.TotalDepense / f.TotalCollecte * 100) : 0;
            <div class="col-md-6 col-lg-4">
                <div class="card h-100" style="border-radius:16px;border:none;box-shadow:0 2px 12px rgba(0,0,0,0.08);overflow:hidden;">
                    <!-- Header -->
                    <div style="background:linear-gradient(135deg,#065F46,#059669);padding:20px;color:white;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="mb-1 fw-bold">@f.Nom</h5>
                                @if (!string.IsNullOrEmpty(f.Description))
                                {
                                    <p style="font-size:13px;opacity:0.85;margin:0;">@f.Description</p>
                                }
                            </div>
                            <span style="background:rgba(255,255,255,0.2);border-radius:8px;padding:4px 10px;font-size:12px;white-space:nowrap;">
                                @f.MontantParMembre.ToString("N0") FCFA/membre
                            </span>
                        </div>
                        <!-- Solde -->
                        <div class="mt-3 p-2" style="background:rgba(255,255,255,0.15);border-radius:10px;">
                            <div class="d-flex justify-content-between">
                                <span style="font-size:12px;opacity:0.8;">Solde disponible</span>
                                <span class="fw-bold">@f.Solde.ToString("N0") FCFA</span>
                            </div>
                            <div style="background:rgba(255,255,255,0.2);border-radius:4px;height:6px;margin-top:6px;">
                                <div style="background:white;border-radius:4px;height:6px;width:@(Math.Min(pct,100))%;"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-1" style="font-size:11px;opacity:0.7;">
                                <span>Dépensé @pct%</span>
                                <span>Total collecté : @f.TotalCollecte.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                    <!-- Body -->
                    <div class="card-body p-3">
                        <div class="row g-2 text-center mb-3">
                            <div class="col-4">
                                <div style="background:#F0FDF4;border-radius:8px;padding:10px;">
                                    <div class="fw-bold" style="color:#065F46;">@f.NombreContributions</div>
                                    <div style="font-size:11px;color:#6B7280;">Contributions</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div style="background:#FFF7ED;border-radius:8px;padding:10px;">
                                    <div class="fw-bold" style="color:#C2410C;">@f.NombreDemandes</div>
                                    <div style="font-size:11px;color:#6B7280;">Demandes</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div style="background:#FEF3C7;border-radius:8px;padding:10px;">
                                    <div class="fw-bold" style="color:#D97706;">@f.NombreDemandesEnAttente</div>
                                    <div style="font-size:11px;color:#6B7280;">En attente</div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="Detail" asp-route-id="@f.IdFonds"
                               class="btn btn-sm flex-fill"
                               style="background:#065F46;color:white;border-radius:8px;font-weight:500;">
                                Gérer
                            </a>
                            <a asp-action="Edit" asp-route-id="@f.IdFonds"
                               class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('Supprimer ce fonds ?')">
                                <input type="hidden" name="id" value="@f.IdFonds" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:8px;">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
