@model tontine.MVC.Models.ContributionFondsViewModel
@{
    ViewData["Title"] = "Ajouter une contribution";
}

<div style="margin-bottom:24px;">
    <a asp-action="Detail" asp-route-id="@Model.IdFonds"
       style="color:#0F6E56;font-size:13px;text-decoration:none;font-weight:500;">
        ← Retour au fonds
    </a>
    <h2 style="margin:8px 0 4px;font-size:24px;font-weight:700;color:#1a1a1a;">Ajouter une contribution</h2>
    <p style="margin:0;color:#888780;font-size:14px;">Enregistrer le versement d'un membre au fonds de solidarité</p>
</div>

<form asp-action="AjouterContribution" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IdFonds" />

    <div style="display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start;">

        <!-- Colonne principale -->
        <div>

            <!-- Membre contributeur -->
            <div style="background:white;border-radius:12px;padding:32px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);margin-bottom:20px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
                    <div style="width:4px;height:22px;background:#0F6E56;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#0F6E56;text-transform:uppercase;letter-spacing:0.6px;">Membre contributeur</span>
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;">Sélectionner le membre</label>
                    <select asp-for="IdMembre" asp-items="ViewBag.Membres"
                            style="width:100%;padding:12px 16px;border:1.5px solid #E5E7EB;border-radius:10px;
                                   font-size:14px;background:white;outline:none;color:#111;"
                            onfocus="this.style.borderColor='#0F6E56';this.style.boxShadow='0 0 0 3px rgba(15,110,86,0.08)'"
                            onblur="this.style.borderColor='#E5E7EB';this.style.boxShadow='none'">
                        <option value="">-- Sélectionner un membre --</option>
                    </select>
                    <span asp-validation-for="IdMembre" style="color:#DC2626;font-size:12px;display:block;margin-top:4px;"></span>
                </div>
            </div>

            <!-- Notes -->
            <div style="background:white;border-radius:12px;padding:32px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
                    <div style="width:4px;height:22px;background:#888780;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.6px;">
                        Notes <span style="font-weight:400;color:#9CA3AF;font-size:12px;text-transform:none;letter-spacing:0;">(optionnel)</span>
                    </span>
                </div>
                <div>
                    <label asp-for="Notes" style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;"></label>
                    <textarea asp-for="Notes" rows="5"
                              placeholder="Mode de paiement utilisé (cash, Mobile Money), référence de transaction, commentaire libre..."
                              style="width:100%;padding:12px 16px;border:1.5px solid #E5E7EB;border-radius:10px;
                                     font-size:14px;outline:none;resize:vertical;color:#111;line-height:1.6;"
                              onfocus="this.style.borderColor='#0F6E56';this.style.boxShadow='0 0 0 3px rgba(15,110,86,0.08)'"
                              onblur="this.style.borderColor='#E5E7EB';this.style.boxShadow='none'"></textarea>
                </div>
            </div>
        </div>

        <!-- Colonne latérale -->
        <div>

            <!-- Montant -->
            <div style="background:white;border-radius:12px;padding:28px;box-shadow:0 1px 4px rgba(0,0,0,0.08),0 4px 16px rgba(0,0,0,0.04);margin-bottom:16px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
                    <div style="width:4px;height:22px;background:#1D9E75;border-radius:2px;"></div>
                    <span style="font-size:13px;font-weight:700;color:#1D9E75;text-transform:uppercase;letter-spacing:0.6px;">Montant versé</span>
                </div>

                <div>
                    <label asp-for="Montant" style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:8px;"></label>
                    <div style="display:flex;align-items:center;border:1.5px solid #E5E7EB;border-radius:10px;overflow:hidden;"
                         id="montant-wrap">
                        <input asp-for="Montant" type="number" min="1" step="500" placeholder="0"
                               style="flex:1;padding:14px 16px;border:none;font-size:26px;font-weight:800;
                                      outline:none;color:#065F46;background:white;min-width:0;"
                               onfocus="document.getElementById('montant-wrap').style.borderColor='#0F6E56';document.getElementById('montant-wrap').style.boxShadow='0 0 0 3px rgba(15,110,86,0.08)'"
                               onblur="document.getElementById('montant-wrap').style.borderColor='#E5E7EB';document.getElementById('montant-wrap').style.boxShadow='none'" />
                        <span style="padding:0 16px;background:#F9FAFB;color:#6B7280;font-size:13px;font-weight:700;
                                     border-left:1.5px solid #E5E7EB;align-self:stretch;display:flex;align-items:center;">
                            FCFA
                        </span>
                    </div>
                    <span asp-validation-for="Montant" style="color:#DC2626;font-size:12px;display:block;margin-top:4px;"></span>
                </div>
            </div>

            <!-- Info -->
            <div style="background:#F0FDF4;border:1.5px solid #6EE7B7;border-radius:12px;padding:20px;">
                <div style="font-size:13px;font-weight:700;color:#065F46;margin-bottom:10px;">💡 À savoir</div>
                <ul style="margin:0;padding-left:18px;font-size:13px;color:#374151;line-height:1.9;">
                    <li>La contribution est enregistrée immédiatement</li>
                    <li>Le solde du fonds est mis à jour en temps réel</li>
                    <li>Aucun reçu automatique n'est généré pour l'instant</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Barre d'actions -->
    <div style="background:white;border-radius:12px;padding:20px 28px;margin-top:8px;
                box-shadow:0 1px 4px rgba(0,0,0,0.08);display:flex;justify-content:flex-end;gap:12px;align-items:center;">
        <a asp-action="Detail" asp-route-id="@Model.IdFonds"
           style="background:white;color:#5F5E5A;border:1.5px solid #D1D5DB;border-radius:10px;
                  padding:11px 28px;font-size:14px;text-decoration:none;font-weight:600;">
            Annuler
        </a>
        <button type="submit"
                style="background:linear-gradient(135deg,#0F6E56,#1D9E75);color:white;border:none;
                       border-radius:10px;padding:11px 32px;font-size:14px;font-weight:700;
                       cursor:pointer;box-shadow:0 2px 8px rgba(15,110,86,0.35);">
            ✓ Enregistrer la contribution
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
