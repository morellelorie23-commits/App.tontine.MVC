odel List<tontine.MVC.Models.GarantViewModel>
@{
    ViewData["Title"] = "Garants / Répondants";
}

<div style="background-image:url('/photo/garant.jfif');background-size:cover;background-position:center;margin:-26px -28px 24px -28px;position:relative;overflow:hidden;min-height:90px;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(7,60,42,0.88) 0%,rgba(11,89,64,0.82) 60%,rgba(15,110,86,0.70) 100%);"></div>
    <div style="position:absolute;inset:0;padding:20px 36px;display:flex;flex-direction:column;justify-content:flex-end;">
        <div style="font-size:11px;color:rgba(255,255,255,0.65);font-weight:600;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px;">Sécurité</div>
        <h2 style="color:white;font-size:22px;font-weight:700;margin:0 0 4px 0;">Garants / Répondants</h2>
        <p style="color:rgba(255,255,255,0.85);font-size:15px;margin:0;">@Model.Count garant(s) enregistré(s)</p>
    </div>
</div>
<div style="padding:8px 0;">
    @if (TempData["Success"] != null) {
        <div style="margin-bottom:12px; padding:12px; background:#E6F4EE; border-left:4px solid #0F6E56; border-radius:6px; color:#085041;">@TempData["Success"]</div>
    }

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <div>
            <h2 style="margin:0; font-size:22px; font-weight:600; color:#1a1a1a;">Garants / Répondants</h2>
            <p style="margin:4px 0 0; color:#888780; font-size:14px;">
                @Model.Count garant(s) enregistré(s) - chaque membre doit avoir un garant pour emprunter
            </p>
        </div>
        <a asp-action="Create" style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:500; text-decoration:none; display:inline-flex; align-items:center; gap:6px;">
            <i data-lucide="user-plus" style="width:16px;height:16px;"></i> + Nouveau garant
        </a>
    </div>

    <div style="background:#FFF8E1; border-left:4px solid #F57C00; border-radius:8px; padding:14px 18px; margin-bottom:20px; font-size:13px; color:#5D4037; display:flex; align-items:flex-start; gap:12px;">
        <i data-lucide="shield" style="width:20px;height:20px;color:#F57C00;flex-shrink:0;margin-top:1px;"></i>
        <div>
            <strong>Règle d'éligibilité aux prêts :</strong> Un membre ne peut obtenir un prêt que s'il a un garant enregistré
            et qu'il n'a pas de prêt actif non remboursé. Le garant sera contacté en cas de défaut de paiement.
        </div>
    </div>

    <div style="background:white; border-radius:12px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.08);">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
            <thead>
                <tr style="background:linear-gradient(135deg, #0F6E56, #1D9E75); color:white;">
                    <th style="padding:14px 18px; text-align:left;">Membre cautionné</th>
                    <th style="padding:14px 18px; text-align:left;">Garant (Répondant)</th>
                    <th style="padding:14px 18px; text-align:left;">Téléphone</th>
                    <th style="padding:14px 18px; text-align:left;">Relation</th>
                    <th style="padding:14px 18px; text-align:left;">Email</th>
                    <th style="padding:14px 18px; text-align:left;">Depuis</th>
                    <th style="padding:14px 18px; text-align:left;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model) {
                    <tr style="border-bottom:1px solid #F1EFE8;" onmouseover="this.style.background='#F8FDF9'" onmouseout="this.style.background='white'">
                        <td style="padding:14px 18px;">
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:34px; height:34px; border-radius:50%; background:#0F6E56; color:white; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:13px; flex-shrink:0;">
                                    @(g.NomMembre?.Substring(0,1).ToUpper() ?? "?")
                                </div>
                                <span style="font-weight:500;">@g.NomMembre</span>
                            </div>
                        </td>
                        <td style="padding:14px 18px; font-weight:600;">@g.Nom @g.Prenom</td>
                        <td style="padding:14px 18px;">
                            <a href="tel:@g.Telephone" style="color:#0F6E56; text-decoration:none;">@g.Telephone</a>
                        </td>
                        <td style="padding:14px 18px;">
                            @if (!string.IsNullOrEmpty(g.Relation)) {
                                <span style="background:#E8F5E9; color:#2E7D32; padding:3px 10px; border-radius:12px; font-size:12px; font-weight:500;">@g.Relation</span>
                            } else {
                                <span style="color:#888780;">-</span>
                            }
                        </td>
                        <td style="padding:14px 18px; color:#888780; font-size:13px;">@(g.Email ?? "-")</td>
                        <td style="padding:14px 18px; color:#888780; font-size:12px;">@g.DateAjout.ToString("dd/MM/yyyy")</td>
                        <td style="padding:14px 18px;">
                            <div style="display:flex; gap:8px;">
                                <a asp-action="Edit" asp-route-id="@g.IdGarant" style="background:#FFF8E1; color:#F57F17; border:1px solid #FFE082; border-radius:6px; padding:6px 12px; text-decoration:none; font-size:13px; display:inline-flex; align-items:center; gap:4px;">
                                    <i data-lucide="pencil" style="width:13px;height:13px;"></i> Modifier
                                </a>
                                <a asp-action="Delete" asp-route-id="@g.IdGarant" style="background:#FFEBEE; color:#C62828; border:1px solid #FFCDD2; border-radius:6px; padding:6px 12px; text-decoration:none; font-size:13px; display:inline-flex; align-items:center; gap:4px;">
                                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i> Supprimer
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr>
                        <td colspan="7" style="padding:48px; text-align:center; color:#888780;">
                            <div style="margin-bottom:8px; display:flex; justify-content:center;"><i data-lucide="shield-off" style="width:36px;height:36px;opacity:.4;"></i></div>
                            <div style="font-weight:500;">Aucun garant enregistré</div>
                            <div style="font-size:12px; margin-top:4px;">Enregistrez les garants des membres pour activer l'éligibilité aux prêts.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

