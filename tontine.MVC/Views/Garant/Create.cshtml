@model tontine.MVC.Models.GarantViewModel
@using tontine.MVC.Models
@{
    ViewData["Title"] = "Nouveau garant";
}

<div style="max-width:600px; margin:30px auto; padding:24px; background:white; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h2 style="margin:0 0 6px; font-size:20px; font-weight:600;">Nouveau garant / répondant</h2>
    <p style="margin:0 0 24px; color:#888780; font-size:13px;">Le garant sera contacté en cas de défaut de paiement du membre cautionné.</p>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="margin-bottom:12px; padding:12px; background:#FFEBEE; border-left:4px solid #C62828; border-radius:6px; color:#B71C1C;">
                <div style="font-weight:500;">Erreurs</div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p style="margin:4px 0 0; font-size:13px;">› @error.ErrorMessage</p>
                }
            </div>
        }

        <div style="display:grid; gap:16px;">
            <div>
                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Membre cautionné *</label>
                <select asp-for="IdMembre" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;">
                    <option value="">-- Sélectionner un membre --</option>
                    @foreach (var m in ViewData["Membres"] as List<MembreViewModel> ?? new())
                    {
                        <option value="@m.IdMembre">@m.Nom @m.Prenom</option>
                    }
                </select>
                @Html.ValidationMessageFor(x => x.IdMembre)
            </div>

            <div style="background:#EBF5FF; border-left:3px solid #1976D2; border-radius:6px; padding:10px 14px; font-size:12px; color:#0D47A1;">
                <strong>Informations du garant (répondant)</strong> - la personne qui répond de ce membre
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Nom *</label>
                    <input asp-for="Nom" type="text" placeholder="Nom du garant" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    @Html.ValidationMessageFor(x => x.Nom)
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Prénom *</label>
                    <input asp-for="Prenom" type="text" placeholder="Prénom du garant" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    @Html.ValidationMessageFor(x => x.Prenom)
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Téléphone *</label>
                    <input asp-for="Telephone" type="tel" placeholder="+33 6 00 00 00 00" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    @Html.ValidationMessageFor(x => x.Telephone)
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Email</label>
                    <input asp-for="Email" type="email" placeholder="garant@email.com" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                    @Html.ValidationMessageFor(x => x.Email)
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Relation avec le membre</label>
                    <select asp-for="Relation" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;">
                        <option value="">-- Relation --</option>
                        <option value="Famille">Famille</option>
                        <option value="Ami(e)">Ami(e)</option>
                        <option value="Collègue">Collègue</option>
                        <option value="Voisin(e)">Voisin(e)</option>
                        <option value="Autre">Autre</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Adresse</label>
                    <input asp-for="Adresse" type="text" placeholder="Adresse du garant" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-size:14px;" />
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:12px;">
                <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px; text-decoration:none; font-weight:500; font-size:14px;">Annuler</a>
                <button type="submit" style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 24px; font-weight:500; cursor:pointer; font-size:14px;">Enregistrer le garant</button>
            </div>
        </div>
    </form>
</div>
