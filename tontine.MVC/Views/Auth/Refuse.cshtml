@{
    Layout = null;
    ViewData["Title"] = "Accès refusé";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Accès refusé - TontineApp</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F4F6F9; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: white; border-radius: 16px; padding: 56px 48px; text-align: center; max-width: 440px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
        .icon { width: 72px; height: 72px; background: #FFF3F3; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; }
        h1 { font-size: 22px; font-weight: 700; color: #1a1a1a; margin-bottom: 12px; }
        p { font-size: 14px; color: #888780; line-height: 1.6; margin-bottom: 32px; }
        a { display: inline-block; background: #0F6E56; color: white; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; }
        a:hover { background: #0B5940; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
        </div>
        <h1>Accès refusé</h1>
        <p>Vous n'avez pas les permissions nécessaires pour accéder à cette page. Contactez un administrateur si vous pensez qu'il s'agit d'une erreur.</p>
        <a href="/Home/Index">Retour au tableau de bord</a>
    </div>
</body>
</html>
