@model tontine.MVC.Models.MembrePosteCycleViewModel
@{
    ViewData["Title"] = "Nouvelle attribution";
}

<div style="max-width:600px; margin:30px auto; padding:24px; background:white; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h2 style="margin:0 0 24px; font-size:20px; font-weight:600;">Nouvelle attribution de rôle</h2>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid) {
            <div style="margin-bottom:12px; padding:12px; background:#FFEBEE; border-left:4px solid #C62828; border-radius:6px; color:#B71C1C;">
                <div style="font-weight:500;">Erreur</div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors)) {
                    <p style="margin:4px 0 0; font-size:13px;">› @error.ErrorMessage</p>
                }
            </div>
        }

        <div style="display:grid; gap:12px;">
            <div>
                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Membre *</label>
                <select asp-for="IdMembre" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">
                    <option value="">-- Sélectionner --</option>
                    @foreach(var m in ViewData["Membres"] as List<MembreViewModel> ?? new()) {
                        <option value="@m.IdMembre">@m.Nom @m.Prenom</option>
                    }
                </select>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Poste *</label>
                    <select asp-for="IdPoste" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">
                        <option value="">-- Sélectionner --</option>
                        @foreach(var p in ViewData["Postes"] as List<PosteViewModel> ?? new()) {
                            <option value="@p.IdPoste">@p.LibellePoste</option>
                        }
                    </select>
                </div>

                <div>
                    <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Cycle</label>
                    <div style="padding:10px; border:1.5px solid #0F6E56; border-radius:8px; font-size:14px; background:#F0FAF6; color:#0F6E56; font-weight:500;">
                        @ViewData["CycleNom"]
                    </div>
                    <input asp-for="IdCycle" type="hidden" />
                </div>
            </div>

            <div>
                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Tontine *</label>
                <select asp-for="IdTontine" required style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px;">
                    <option value="">-- Sélectionner --</option>
                    @foreach(var t in ViewData["Tontines"] as List<TontineViewModel> ?? new()) {
                        <option value="@t.IdTontine">@t.Libelle</option>
                    }
                </select>
            </div>

            <div>
                <label style="font-size:12px; font-weight:500; color:#444; display:block; margin-bottom:6px;">Commentaire</label>
                <textarea asp-for="Commentaire" style="width:100%; padding:10px; border:1.5px solid #E0E0E0; border-radius:8px; font-family:inherit; resize:vertical; min-height:100px;"></textarea>
            </div>
        </div>

        <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:24px;">
            <a asp-action="Index" style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7; border-radius:8px; padding:10px 24px; text-decoration:none;">Annuler</a>
            <button type="submit" style="background:#0F6E56; color:white; border:none; border-radius:8px; padding:10px 24px; cursor:pointer;">Enregistrer</button>
        </div>
    </form>
</div>
