@model tontine.MVC.Models.RapportViewModel
@{ ViewData["Title"] = "Rapports détaillés"; string F(decimal v) => v.ToString("N0") + " FCFA"; }

<style>
    .kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
    .kpi      { background:white; border-radius:12px; padding:20px; box-shadow:0 1px 4px rgba(0,0,0,0.07); }
    .kpi-val  { font-size:22px; font-weight:700; color:#1a1a1a; }
    .kpi-lbl  { font-size:12px; color:#888; margin-top:4px; }
    .kpi-icon { width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:12px; }
    .section  { background:white;border-radius:12px;padding:24px;box-shadow:0 1px 4px rgba(0,0,0,0.07);margin-bottom:20px; }
    .section h3 { font-size:15px;font-weight:700;color:#1a1a1a;margin:0 0 16px 0;display:flex;align-items:center;gap:8px; }
    .bar-row  { display:flex;align-items:center;gap:12px;margin-bottom:10px; }
    .bar-lbl  { width:160px;font-size:13px;color:#444;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
    .bar-track{ flex:1;background:#F4F6F9;border-radius:99px;height:8px; }
    .bar-fill { background:linear-gradient(90deg,#0F6E56,#1D9E75);border-radius:99px;height:8px; }
    .bar-val  { font-size:12px;color:#666;width:130px;text-align:right; }
    @@media (max-width:900px) { .kpi-grid { grid-template-columns:repeat(2,1fr); } }
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
    <div>
        <h2 style="margin:0 0 4px;font-size:22px;font-weight:700;">Rapports détaillés</h2>
        <p style="color:#888;font-size:14px;margin:0;">Vue d'ensemble financière et opérationnelle</p>
    </div>
    <a asp-action="ExportPdf" target="_blank"
       style="background:#C62828;color:white;border:none;border-radius:8px;padding:10px 18px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;box-shadow:0 2px 8px rgba(198,40,40,0.3);">
        <i data-lucide="file-down" style="width:15px;height:15px;"></i> Exporter PDF
    </a>
</div>

<!-- KPIs financiers -->
<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-icon" style="background:#E6F4EE;"><i data-lucide="trending-up" style="width:20px;height:20px;color:#0F6E56;"></i></div>
        <div class="kpi-val">@F(Model.TotalCotisations)</div>
        <div class="kpi-lbl">Total cotisations collectées</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon" style="background:#E8F5E9;"><i data-lucide="arrow-down-circle" style="width:20px;height:20px;color:#2E7D32;"></i></div>
        <div class="kpi-val">@F(Model.TotalVersements)</div>
        <div class="kpi-lbl">Total versements effectués</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon" style="background:#FFF8E1;"><i data-lucide="banknote" style="width:20px;height:20px;color:#F9A825;"></i></div>
        <div class="kpi-val">@F(Model.TotalPrets)</div>
        <div class="kpi-lbl">Total prêts accordés</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon" style="background:#E3F2FD;"><i data-lucide="check-circle-2" style="width:20px;height:20px;color:#1565C0;"></i></div>
        <div class="kpi-val">@F(Model.TotalRembourse)</div>
        <div class="kpi-lbl">Total remboursé</div>
    </div>
</div>

<!-- Statuts cotisations & prêts -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div class="section">
        <h3><i data-lucide="credit-card" style="width:16px;height:16px;color:#0F6E56;"></i> Statuts des cotisations</h3>
        @{ var totalCot = Model.CotisationsPayees + Model.CotisationsEnAttente + Model.CotisationsEnRetard; }
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <div style="flex:1;min-width:100px;background:#E6F4EE;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#0F6E56;">@Model.CotisationsPayees</div>
                <div style="font-size:12px;color:#085041;margin-top:4px;">Payées</div>
            </div>
            <div style="flex:1;min-width:100px;background:#FFF8E1;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#F9A825;">@Model.CotisationsEnAttente</div>
                <div style="font-size:12px;color:#E65100;margin-top:4px;">En attente</div>
            </div>
            <div style="flex:1;min-width:100px;background:#FFEBEE;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#C62828;">@Model.CotisationsEnRetard</div>
                <div style="font-size:12px;color:#C62828;margin-top:4px;">En retard</div>
            </div>
        </div>
    </div>
    <div class="section">
        <h3><i data-lucide="landmark" style="width:16px;height:16px;color:#0F6E56;"></i> Statuts des prêts</h3>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <div style="flex:1;min-width:100px;background:#E3F2FD;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#1565C0;">@Model.PretsApprouves</div>
                <div style="font-size:12px;color:#1565C0;margin-top:4px;">Approuvés</div>
            </div>
            <div style="flex:1;min-width:100px;background:#E6F4EE;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#0F6E56;">@Model.PretsRembourses</div>
                <div style="font-size:12px;color:#085041;margin-top:4px;">Remboursés</div>
            </div>
            <div style="flex:1;min-width:100px;background:#FFEBEE;border-radius:10px;padding:16px;text-align:center;">
                <div style="font-size:28px;font-weight:800;color:#C62828;">@Model.PretsEnRetard</div>
                <div style="font-size:12px;color:#C62828;margin-top:4px;">En retard</div>
            </div>
        </div>
    </div>
</div>

<!-- Cotisations par cycle -->
@if (Model.ParCycle.Any())
{
    var maxCycle = Model.ParCycle.Values.Max();
    <div class="section">
        <h3><i data-lucide="calendar" style="width:16px;height:16px;color:#0F6E56;"></i> Cotisations par cycle</h3>
        @foreach (var kv in Model.ParCycle.OrderByDescending(x => x.Value))
        {
            var pct = maxCycle > 0 ? (double)kv.Value / (double)maxCycle * 100 : 0;
            <div class="bar-row">
                <div class="bar-lbl" title="@kv.Key">@kv.Key</div>
                <div class="bar-track"><div class="bar-fill" style="width:@(pct.ToString("0"))%;"></div></div>
                <div class="bar-val">@F(kv.Value)</div>
            </div>
        }
    </div>
}

<!-- Versements par tontine -->
@if (Model.ParTontine.Any())
{
    var maxTontine = Model.ParTontine.Values.Max();
    <div class="section">
        <h3><i data-lucide="users" style="width:16px;height:16px;color:#0F6E56;"></i> Versements par tontine</h3>
        @foreach (var kv in Model.ParTontine.OrderByDescending(x => x.Value))
        {
            var pct = maxTontine > 0 ? (double)kv.Value / (double)maxTontine * 100 : 0;
            <div class="bar-row">
                <div class="bar-lbl" title="@kv.Key">@kv.Key</div>
                <div class="bar-track"><div class="bar-fill" style="width:@(pct.ToString("0"))%;background:linear-gradient(90deg,#1565C0,#42A5F5);"></div></div>
                <div class="bar-val">@F(kv.Value)</div>
            </div>
        }
    </div>
}

<!-- Top 10 membres -->
@if (Model.TopMembres.Any())
{
    var maxM = Model.TopMembres.Values.Max();
    <div class="section">
        <h3><i data-lucide="trophy" style="width:16px;height:16px;color:#F9A825;"></i> Top 10 contributeurs</h3>
        @{ int rank = 1; }
        @foreach (var kv in Model.TopMembres)
        {
            var pct = maxM > 0 ? (double)kv.Value / (double)maxM * 100 : 0;
            <div class="bar-row">
                <div style="width:24px;height:24px;border-radius:50%;background:@(rank<=3?"#0F6E56":"#E0E0E0");color:@(rank<=3?"white":"#666");font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">@rank</div>
                <div class="bar-lbl" title="@kv.Key">@kv.Key</div>
                <div class="bar-track"><div class="bar-fill" style="width:@(pct.ToString("0"))%;background:linear-gradient(90deg,#F9A825,#FFD54F);"></div></div>
                <div class="bar-val">@F(kv.Value)</div>
            </div>
            rank++;
        }
    </div>
}
