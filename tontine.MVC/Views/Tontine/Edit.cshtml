@model tontine.MVC.Models.TontineViewModel
@{
    ViewData["Title"] = "Modifier la tontine";
}

<div style="max-width:480px;">
    <div style="margin-bottom:24px;">
        <a asp-action="Index" style="color:#0F6E56; font-size:13px; text-decoration:none; font-weight:500;">
            ← Retour à la liste
        </a>
        <h2 style="margin:8px 0 4px; font-size:22px; font-weight:600; color:#1a1a1a;">Modifier la tontine</h2>
        <p style="margin:0; color:#888780; font-size:14px;">@Model.Libelle</p>
    </div>

    <form asp-action="Edit" method="post"
      data-confirm="Voulez-vous enregistrer les modifications de cette tontine ?"
      data-confirm-type="edit">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdTontine" />

        <div style="background:white; border-radius:12px; padding:20px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);">

            <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
                <div style="width:4px; height:20px; background:#0F6E56; border-radius:2px;"></div>
                <span style="font-size:13px; font-weight:600; color:#0F6E56; text-transform:uppercase; letter-spacing:0.5px;">Informations</span>
            </div>

            <div style="display:grid; gap:16px; margin-bottom:24px;">
                <div>
                    <label asp-for="Libelle" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Libelle"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                    <span asp-validation-for="Libelle" style="color:#C62828; font-size:12px;"></span>
                </div>

                <div>
                    <label asp-for="Montant" style="font-size:13px; font-weight:500; color:#444; display:block; margin-bottom:6px;"></label>
                    <input asp-for="Montant" type="number" step="0.01"
                           style="width:100%; padding:10px 14px; border:1.5px solid #E0E0E0;
                                  border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0F6E56'"
                           onblur="this.style.borderColor='#E0E0E0'" />
                    <span asp-validation-for="Montant" style="color:#C62828; font-size:12px;"></span>
                </div>

                <div>
                    <label asp-for="Frequence" style="font-size:13px; font-weight:600; color:#0F6E56; display:block; margin-bottom:10px;"></label>
                    <div style="display:flex; gap:10px;">
                        <label style="padding:10px 16px; border-radius:8px; border:1.5px solid #E0E0E0; cursor:pointer; font-size:14px;">
                            <input type="radio" asp-for="Frequence" value="Journalier" /> Journalier
                        </label>
                        <label style="padding:10px 16px; border-radius:8px; border:1.5px solid #E0E0E0; cursor:pointer; font-size:14px;">
                            <input type="radio" asp-for="Frequence" value="Hebdomadaire" /> Hebdomadaire
                        </label>
                        <label style="padding:10px 16px; border-radius:8px; border:1.5px solid #E0E0E0; cursor:pointer; font-size:14px;">
                            <input type="radio" asp-for="Frequence" value="Mensuel" /> Mensuel
                        </label>
                    </div>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:20px; border-top:1px solid #F1EFE8;">
                <a asp-action="Index"
                   style="background:white; color:#5F5E5A; border:1.5px solid #D3D1C7;
                          border-radius:8px; padding:10px 24px; font-size:14px;
                          text-decoration:none; font-weight:500;">
                    Annuler
                </a>
                <button type="submit"
                        style="background:#F57F17; color:white; border:none; border-radius:8px;
                               padding:10px 24px; font-size:14px; font-weight:500; cursor:pointer;
                               box-shadow:0 2px 8px rgba(245,127,23,0.3);">
                    Enregistrer les modifications
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
